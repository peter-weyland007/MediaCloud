{
  "ConnectionStrings": {
    "MediaCloud": "Data Source=data/mediacloud.db"
  },
  "Jwt": {
    "Issuer": "MediaCloud.Api",
    "Audience": "MediaCloud.Web",
    "SigningKey": "dev-only-change-me-super-long-signing-key-32+",
    "ExpiresMinutes": 480
  },
  "Auth": {
    "AllowSelfRegistration": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
