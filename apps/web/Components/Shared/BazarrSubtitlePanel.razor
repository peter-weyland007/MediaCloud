@inject HttpClient Http
@inject AuthorizedApiRequestFactory RequestFactory

<section style="margin-top:1rem; display:grid; gap:1rem;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.75rem; flex-wrap:wrap;">
        <div>
            <p class="card-label">SUBTITLES</p>
            <p class="card-note" style="margin:0.35rem 0 0;">Live subtitle availability and missing-target status from Bazarr.</p>
        </div>
        @if (_status is not null)
        {
            <span style="@GetBadgeStyle(_status.Status)">@GetBadgeLabel(_status.Status)</span>
        }
    </div>

    <div id="subtitle-panel-content" style="display:grid; gap:0.85rem;">
        @if (_loading)
        {
            <p class="card-note">Loading Bazarr subtitle status…</p>
        }
        else if (_status is null)
        {
            <p class="card-note">Bazarr subtitle status is unavailable.</p>
        }
        else
        {
            <div class="subtitle-summary-grid">
                <div>
                    <p class="card-label">SOURCE</p>
                    <p style="margin:0.35rem 0 0;">@DisplayValue(_status.InstanceName)</p>
                    <p class="card-note" style="margin-top:0.25rem;">Target: @DisplayValue(_status.TargetKind) · External ID: @(_status.ExternalId?.ToString() ?? "—")</p>
                </div>
                <div>
                    <p class="card-label">SUMMARY</p>
                    <p style="margin:0.35rem 0 0;">@DisplayValue(_status.Summary)</p>
                    <p class="card-note" style="margin-top:0.25rem;">Monitored: @(_status.Monitored ? "Yes" : "No") · Checked: @FormatTimestamp(_status.CheckedAtUtc)</p>
                </div>
            </div>

            @if (_status.EpisodeFileCount > 0)
            {
                <div>
                    <p class="card-label">SERIES COVERAGE</p>
                    <p style="margin:0.35rem 0 0;">Episodes tracked: @_status.EpisodeFileCount</p>
                    <p style="margin:0.15rem 0 0;">Missing targets: @_status.MissingEpisodeCount</p>
                </div>
            }

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                <div>
                    <p class="card-label">Available subtitles</p>
                    <p style="margin:0.35rem 0 0;">@FormatList(_status.AvailableSubtitles)</p>
                </div>
                <div>
                    <p class="card-label">Missing targets</p>
                    <p style="margin:0.35rem 0 0;">@FormatList(_status.MissingSubtitles)</p>
                </div>
            </div>
        }
    </div>
</section>

<style>
    .subtitle-summary-grid {
        display: grid;
        grid-template-columns: minmax(180px, 0.8fr) minmax(360px, 1.6fr);
        gap: 0.85rem;
        align-items: start;
    }

    @@media (max-width: 920px) {
        .subtitle-summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter, EditorRequired] public long LibraryItemId { get; set; }

    private bool _loading = true;
    private BazarrSubtitleStatusDto? _status;

    protected override Task OnParametersSetAsync()
        => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _status = null;

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{LibraryItemId}/bazarr-subtitles");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            _status = await response.Content.ReadFromJsonAsync<BazarrSubtitleStatusDto>();
        }
        catch
        {
            _status = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatList(IReadOnlyList<string>? values)
        => values is { Count: > 0 } ? string.Join(", ", values.Where(x => !string.IsNullOrWhiteSpace(x))) : "—";

    private static string DisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatTimestamp(DateTimeOffset value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private static string GetBadgeLabel(string? status)
        => (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "missing" => "Missing",
            "covered" => "Covered",
            _ => "Unavailable"
        };

    private static string GetBadgeStyle(string? status)
        => (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "missing" => BadgeStyle("rgba(249,115,22,0.18)", "#fdba74", "rgba(249,115,22,0.45)"),
            "covered" => BadgeStyle("rgba(16,185,129,0.18)", "#86efac", "rgba(16,185,129,0.45)"),
            _ => BadgeStyle("rgba(148,163,184,0.18)", "#cbd5e1", "rgba(148,163,184,0.35)")
        };

    private static string BadgeStyle(string background, string color, string border)
        => $"display:inline-block; padding:0.2rem 0.52rem; border-radius:999px; font-size:0.78rem; font-weight:700; background:{background}; color:{color}; border:1px solid {border};";
}
