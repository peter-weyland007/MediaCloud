@page "/issues"
@attribute [Authorize]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar

<PageTitle>Issues</PageTitle>

<h1>Issues</h1>
<p class="subtitle">Track runtime mismatches and runtime probe failures so bad files and metadata drift are visible in one place.</p>

<div class="card" style="margin-bottom:1rem;">
    <div style="display:flex; gap:0.6rem; align-items:end; flex-wrap:wrap;">
        <div class="form-group" style="min-width:180px;">
            <label>Status</label>
            <select class="input" @bind="_statusFilter" @bind:after="OnFiltersChangedAsync">
                <option value="Open">Open</option>
                <option value="Resolved">Resolved</option>
                <option value="">All</option>
            </select>
        </div>

        <div class="form-group" style="min-width:180px;">
            <label>Issue Type</label>
            <select class="input" @bind="_issueTypeFilter" @bind:after="OnFiltersChangedAsync">
                @foreach (var option in _issueTypeOptions)
                {
                    <option value="@option.Key">@option.Label</option>
                }
            </select>
        </div>

        <div class="form-group" style="min-width:180px;">
            <label>Media Type</label>
            <select class="input" @bind="_mediaTypeFilter" @bind:after="OnFiltersChangedAsync">
                @foreach (var option in MediaTypeOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <div class="form-group" style="min-width:110px;">
            <label>Page Size</label>
            <select class="input" value="@_pageSize" @onchange="OnPageSizeChangedAsync">
                @foreach (var option in PageSizeOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </div>

        <button class="button-secondary" @onclick="ReloadAsync" disabled="@_loading">@(_loading ? "Refreshing..." : "Refresh")</button>
    </div>
</div>

<div class="card">
    <div style="display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; align-items:center; margin-bottom:0.75rem;">
        <span class="card-note">Page @CurrentPageDisplay of @TotalPages · Showing @PageStartRow-@PageEndRow of @_totalCount issues</span>
        <div style="display:flex; gap:0.5rem; align-items:end; flex-wrap:wrap;">
            <div class="form-group" style="min-width:120px; margin:0;">
                <label>Jump to page</label>
                <input class="input" type="number" min="1" max="@TotalPages" value="@_jumpPageText" @onchange="OnJumpPageChanged" />
            </div>
            <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                <MudButton ButtonType="ButtonType.Button" Color="Color.Secondary" OnClick="GoToPageAsync" Disabled="@_loading">Go</MudButton>
                <MudButton ButtonType="ButtonType.Button" Color="Color.Secondary" OnClick="PreviousPageAsync" Disabled="@(_loading || _pageIndex == 0)">Previous</MudButton>
                <MudButton ButtonType="ButtonType.Button" Color="Color.Secondary" OnClick="NextPageAsync" Disabled="@(_loading || !CanGoNext)">Next</MudButton>
            </MudButtonGroup>
        </div>
    </div>

    @if (_loading)
    {
        <p class="card-note">Loading issues…</p>
    }
    else if (_issues.Count == 0)
    {
        <p class="card-note">No issues found for the selected filter.</p>
    }
    else
    {
        <table class="data-table" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("detected")'>Detected @SortGlyph("detected")</button></th>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("item")'>Item @SortGlyph("item")</button></th>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("type")'>Issue Type @SortGlyph("type")</button></th>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("media")'>Media Type @SortGlyph("media")</button></th>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("severity")'>Severity @SortGlyph("severity")</button></th>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("status")'>Status @SortGlyph("status")</button></th>
                    <th style="text-align:left; padding:0.5rem;"><button style="all:unset; cursor:pointer;" @onclick='() => ToggleSortAsync("difference")'>Details @SortGlyph("difference")</button></th>
                    <th style="text-align:left; padding:0.5rem;">Summary</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _issues)
                {
                    var mismatchDetails = ParseRuntimeMismatchDetails(row.DetailsJson);
                    var probeDetails = ParseRuntimeProbeFailureDetails(row.DetailsJson);
                    <tr>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);">@row.LastDetectedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);">
                            <a href="@GetItemHref(row)" style="color:#93c5fd; text-decoration:none;">@GetItemDisplayName(row)</a>
                        </td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);"><span style="@GetIssueTypeBadgeStyle(row.IssueType)">@LibraryIssuePresentation.GetIssueTypeLabel(row.IssueType)</span></td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);">@(string.IsNullOrWhiteSpace(row.MediaType) ? "—" : row.MediaType)</td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);"><span style="@GetSeverityBadgeStyle(row.Severity)">@row.Severity</span></td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);">@row.Status</td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);">
                            @if (string.Equals(row.IssueType, "runtime_probe_failed", StringComparison.OrdinalIgnoreCase))
                            {
                                <div>@(string.IsNullOrWhiteSpace(probeDetails?.FilePath) ? "Probe failed" : Path.GetFileName(probeDetails.FilePath))</div>
                                @if (!string.IsNullOrWhiteSpace(probeDetails?.ProbeError))
                                {
                                    <div style="color:#cbd5e1; font-size:0.8rem; margin-top:0.2rem;">@TrimForCell(probeDetails.ProbeError)</div>
                                }
                            }
                            else if (mismatchDetails is null)
                            {
                                <span>—</span>
                            }
                            else
                            {
                                <span>Δ @mismatchDetails.DiffMinutes.ToString("0.##")m (@mismatchDetails.DiffPercent.ToString("0.##")%)</span>
                            }
                        </td>
                        <td style="padding:0.5rem; border-top:1px solid rgba(148,163,184,0.15);">@row.Summary</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private bool _loading = true;
    private string _statusFilter = "Open";
    private string _issueTypeFilter = string.Empty;
    private string _mediaTypeFilter = "All";
    private string _sortBy = "detected";
    private string _sortDir = "desc";
    private int _pageIndex;
    private int _pageSize = 50;
    private int _totalCount;
    private string _jumpPageText = "1";
    private readonly List<LibraryIssueDto> _issues = [];
    private List<IssueTypeOption> _issueTypeOptions = [new(string.Empty, "All")];

    private static readonly IReadOnlyList<string> MediaTypeOptions = ["All", "Movie", "Episode", "Series", "Album", "Track", "Artist"];
    private static readonly IReadOnlyList<int> PageSizeOptions = [25, 50, 100];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Math.Max(_totalCount, 1) / (double)_pageSize));
    private int CurrentPageDisplay => Math.Min(_pageIndex + 1, TotalPages);
    private bool CanGoNext => (_pageIndex + 1) < TotalPages;
    private int PageStartRow => _totalCount == 0 ? 0 : (_pageIndex * _pageSize) + 1;
    private int PageEndRow => _totalCount == 0 ? 0 : Math.Min(_totalCount, (_pageIndex * _pageSize) + _issues.Count);

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task OnFiltersChangedAsync()
    {
        _pageIndex = 0;
        await ReloadAsync();
    }

    private async Task OnPageSizeChangedAsync(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var size) && PageSizeOptions.Contains(size))
        {
            _pageSize = size;
            _pageIndex = 0;
            await ReloadAsync();
        }
    }

    private void OnJumpPageChanged(ChangeEventArgs args)
        => _jumpPageText = args.Value?.ToString() ?? string.Empty;

    private async Task GoToPageAsync()
    {
        if (!int.TryParse(_jumpPageText, out _))
        {
            Snackbar.Add("Enter a valid page number.", Severity.Warning);
            _jumpPageText = CurrentPageDisplay.ToString();
            return;
        }

        var targetPageIndex = LibraryIssuePresentation.ResolveJumpPageIndex(_jumpPageText, TotalPages);
        if (targetPageIndex == _pageIndex)
        {
            _jumpPageText = CurrentPageDisplay.ToString();
            return;
        }

        _pageIndex = targetPageIndex;
        await ReloadAsync();
    }

    private async Task NextPageAsync()
    {
        if (CanGoNext)
        {
            _pageIndex++;
            await ReloadAsync();
        }
    }

    private async Task PreviousPageAsync()
    {
        if (_pageIndex > 0)
        {
            _pageIndex--;
            await ReloadAsync();
        }
    }

    private async Task ToggleSortAsync(string field)
    {
        if (string.Equals(_sortBy, field, StringComparison.OrdinalIgnoreCase))
        {
            _sortDir = string.Equals(_sortDir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
        }
        else
        {
            _sortBy = field;
            _sortDir = field == "detected" ? "desc" : "asc";
        }

        _pageIndex = 0;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            var query = new List<string>
            {
                $"pageIndex={_pageIndex}",
                $"pageSize={_pageSize}",
                $"sortBy={Uri.EscapeDataString(_sortBy)}",
                $"sortDir={Uri.EscapeDataString(_sortDir)}"
            };

            if (!string.IsNullOrWhiteSpace(_statusFilter))
            {
                query.Add($"status={Uri.EscapeDataString(_statusFilter)}");
            }

            if (!string.IsNullOrWhiteSpace(_issueTypeFilter))
            {
                query.Add($"issueType={Uri.EscapeDataString(_issueTypeFilter)}");
            }

            if (!string.Equals(_mediaTypeFilter, "All", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(_mediaTypeFilter))
            {
                query.Add($"mediaType={Uri.EscapeDataString(_mediaTypeFilter)}");
            }

            using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/library/issues?{string.Join("&", query)}");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load issues ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LibraryIssuePageDto>() ?? new LibraryIssuePageDto([], 0, 0, _pageSize, []);
            _issues.Clear();
            _issues.AddRange(payload.Items);
            _totalCount = payload.TotalCount;
            _pageIndex = payload.PageIndex;
            _pageSize = payload.PageSize;
            _jumpPageText = CurrentPageDisplay.ToString();
            _issueTypeOptions = [new(string.Empty, "All"), .. payload.AvailableIssueTypes.Select(x => new IssueTypeOption(x, LibraryIssuePresentation.GetIssueTypeLabel(x)))];

            if (!string.IsNullOrWhiteSpace(_issueTypeFilter) && !_issueTypeOptions.Any(x => string.Equals(x.Key, _issueTypeFilter, StringComparison.OrdinalIgnoreCase)))
            {
                _issueTypeFilter = string.Empty;
            }
        }
        catch
        {
            Snackbar.Add("Failed to load issues.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetItemHref(LibraryIssueDto issue)
        => MediaItemRoutes.GetDetailsHref(issue.MediaType, issue.LibraryItemId);

    private static string TrimForCell(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        var singleLine = value.Replace("\r", " ").Replace("\n", " ").Trim();
        return singleLine.Length <= 120 ? singleLine : $"{singleLine[..117]}...";
    }

    private string SortGlyph(string field)
        => !string.Equals(_sortBy, field, StringComparison.OrdinalIgnoreCase)
            ? "↕"
            : (string.Equals(_sortDir, "asc", StringComparison.OrdinalIgnoreCase) ? "↑" : "↓");

    private static string GetItemDisplayName(LibraryIssueDto issue)
    {
        var title = (issue.LibraryItemTitle ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(title)) return title;
        return issue.LibraryItemId > 0
            ? MediaItemRoutes.GetFallbackDisplayName(issue.MediaType, issue.LibraryItemId)
            : "Unknown item";
    }

    private static string GetSeverityBadgeStyle(string severity)
    {
        const string baseStyle = "display:inline-block; padding:0.2rem 0.52rem; border-radius:999px; font-size:0.78rem; font-weight:700; letter-spacing:0.01em;";
        var value = (severity ?? string.Empty).Trim().ToLowerInvariant();
        return value switch
        {
            "critical" => baseStyle + "background:rgba(239,68,68,0.22); color:#fecaca; border:1px solid rgba(239,68,68,0.65);",
            "high" => baseStyle + "background:rgba(249,115,22,0.22); color:#fed7aa; border:1px solid rgba(249,115,22,0.65);",
            "warning" => baseStyle + "background:rgba(234,179,8,0.22); color:#fde68a; border:1px solid rgba(234,179,8,0.65);",
            _ => baseStyle + "background:rgba(148,163,184,0.18); color:#cbd5e1; border:1px solid rgba(148,163,184,0.35);"
        };
    }

    private static string GetIssueTypeBadgeStyle(string issueType)
    {
        const string baseStyle = "display:inline-block; padding:0.2rem 0.52rem; border-radius:999px; font-size:0.78rem; font-weight:700; letter-spacing:0.01em;";
        var value = (issueType ?? string.Empty).Trim().ToLowerInvariant();
        return value switch
        {
            "runtime_probe_failed" => baseStyle + "background:rgba(168,85,247,0.22); color:#e9d5ff; border:1px solid rgba(168,85,247,0.65);",
            "runtime_mismatch" => baseStyle + "background:rgba(59,130,246,0.22); color:#bfdbfe; border:1px solid rgba(59,130,246,0.65);",
            _ => baseStyle + "background:rgba(148,163,184,0.18); color:#cbd5e1; border:1px solid rgba(148,163,184,0.35);"
        };
    }

    private static RuntimeMismatchDetails? ParseRuntimeMismatchDetails(string? detailsJson)
    {
        if (string.IsNullOrWhiteSpace(detailsJson)) return null;

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(detailsJson);
            var root = doc.RootElement;
            var diffMinutes = root.TryGetProperty("diffMinutes", out var diffMinutesElement) ? diffMinutesElement.GetDouble() : 0;
            var diffPercent = root.TryGetProperty("diffPercent", out var diffPercentElement) ? diffPercentElement.GetDouble() : 0;
            var thresholdMinutes = root.TryGetProperty("thresholdMinutes", out var thresholdElement) ? thresholdElement.GetDouble() : 0;
            return new RuntimeMismatchDetails(diffMinutes, diffPercent, thresholdMinutes);
        }
        catch
        {
            return null;
        }
    }

    private static RuntimeProbeFailureDetails? ParseRuntimeProbeFailureDetails(string? detailsJson)
    {
        if (string.IsNullOrWhiteSpace(detailsJson)) return null;

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(detailsJson);
            var root = doc.RootElement;
            var filePath = root.TryGetProperty("filePath", out var filePathElement) ? filePathElement.GetString() ?? string.Empty : string.Empty;
            var probeError = root.TryGetProperty("probeError", out var probeErrorElement) ? probeErrorElement.GetString() ?? string.Empty : string.Empty;
            var exitCode = root.TryGetProperty("exitCode", out var exitCodeElement) && exitCodeElement.ValueKind != System.Text.Json.JsonValueKind.Null
                ? exitCodeElement.GetInt32()
                : (int?)null;
            return new RuntimeProbeFailureDetails(filePath, probeError, exitCode);
        }
        catch
        {
            return null;
        }
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private record LibraryIssuePageDto(IReadOnlyList<LibraryIssueDto> Items, int TotalCount, int PageIndex, int PageSize, IReadOnlyList<string> AvailableIssueTypes);

    private record IssueTypeOption(string Key, string Label);

    private record LibraryIssueDto(
        long Id,
        long LibraryItemId,
        string IssueType,
        string Severity,
        string Status,
        string Summary,
        string SuggestedAction,
        string DetailsJson,
        DateTimeOffset FirstDetectedAtUtc,
        DateTimeOffset LastDetectedAtUtc,
        DateTimeOffset? ResolvedAtUtc,
        string LibraryItemTitle,
        string MediaType);

    private record RuntimeMismatchDetails(
        double DiffMinutes,
        double DiffPercent,
        double ThresholdMinutes);

    private record RuntimeProbeFailureDetails(
        string FilePath,
        string ProbeError,
        int? ExitCode);
}
