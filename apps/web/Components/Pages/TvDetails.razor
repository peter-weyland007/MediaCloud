            "subtitle_missing" => new ManualIssueRemediationPlan("wrong_language", "Search Sonarr for a replacement with the subtitle tracks you expect."),
            "subtitle_language_mismatch" => new ManualIssueRemediationPlan("wrong_language", "Search Sonarr for a replacement with the correct subtitle language."),
            "audio_out_of_sync" => new ManualIssueRemediationPlan("playback_failure", "Search Sonarr for a replacement when the episode plays but the audio timing is broken."),
            "wrong_version" => new ManualIssueRemediationPlan("wrong_version", "Search Sonarr for the correct version/cut of this episode."),
            "quality_issue" => new ManualIssueRemediationPlan("quality_issue", "Search Sonarr for a better-quality episode release."),
            "corrupt_file" => new ManualIssueRemediationPlan("corrupt_file", "Search Sonarr for a replacement because this episode file looks corrupt or unplayable."),
