@page "/media/tv-shows/{Id:long}"
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthorizedApiRequestFactory RequestFactory
@using web.Components.Shared

<PageTitle>@(_item?.DisplayTitle is { Length: > 0 } title ? $"{title} · TV Details" : "TV Details")</PageTitle>

@if (_loading)
{
    <p class="card-note">Loading TV details…</p>
}
else if (_item is null || !IsTvItem(_item.MediaType))
{
    <h1>TV item not found</h1>
    <a href="/media/tv-shows" style="color:#93c5fd; text-decoration:none;">← Back to TV Shows</a>
}
else
{
    <MediaDetailHeader BackHref="/media/tv-shows"
                       BackLabel="Back to TV Shows"
                       Title="@_item.DisplayTitle"
                       Subtitle="@BuildSubtitle()"
                       Note="@(_parentSeries is not null && IsEpisode(_item.MediaType) ? $"Series: {_parentSeries.DisplayTitle}" : null)" />

    <MediaItemDetailBody Item="_item"
                         OverviewEmptyText="No description is currently available for this TV item."
                         AnalyzeButtonLabel="Analyze file"
                         IsAnalyzing="_probingRuntime"
                         OnAnalyze="@ProbeRuntimeNowAsync" />

    <BazarrSubtitlePanel LibraryItemId="@_item.Id" />

    <MediaEpisodeTable Episodes="_episodes" />
}

@code {
    [Parameter] public long Id { get; set; }

    private bool _loading = true;
    private bool _probingRuntime;
    private string _statusMessage = string.Empty;
    private MediaItemDetailDto? _item;
    private MediaItemDetailDto? _parentSeries;
    private readonly List<MediaItemDetailDto> _episodes = [];

    protected override Task OnParametersSetAsync()
        => LoadItemAsync();

    private async Task LoadItemAsync(bool clearStatusMessage = true)
    {
        _loading = true;
        if (clearStatusMessage)
        {
            _statusMessage = string.Empty;
        }

        _item = null;
        _parentSeries = null;
        _episodes.Clear();

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            _item = await response.Content.ReadFromJsonAsync<MediaItemDetailDto>();
            if (_item is null || !IsTvItem(_item.MediaType))
            {
                return;
            }

            if (IsEpisode(_item.MediaType))
            {
                using var parentRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{_item.Id}/series-parent");
                using var parentResponse = await Http.SendAsync(parentRequest);
                if (parentResponse.IsSuccessStatusCode)
                {
                    _parentSeries = await parentResponse.Content.ReadFromJsonAsync<MediaItemDetailDto>();
                }
            }
            else if (IsSeries(_item.MediaType))
            {
                using var episodesRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{_item.Id}/episodes");
                using var episodesResponse = await Http.SendAsync(episodesRequest);
                if (episodesResponse.IsSuccessStatusCode)
                {
                    var episodes = await episodesResponse.Content.ReadFromJsonAsync<List<MediaItemDetailDto>>() ?? [];
                    _episodes.AddRange(episodes.OrderBy(x => x.DisplayTitle));
                }
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ProbeRuntimeNowAsync()
    {
        if (_item is null)
        {
            return;
        }

        _probingRuntime = true;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/reprobe-runtime");
            using var response = await Http.SendAsync(request);
            var payload = await response.Content.ReadFromJsonAsync<LibraryItemRuntimeProbeResponse>();
            _statusMessage = response.IsSuccessStatusCode
                ? (string.IsNullOrWhiteSpace(payload?.Message) ? "Runtime analysis completed." : payload.Message)
                : $"Runtime analysis failed (HTTP {(int)response.StatusCode}).";

            if (response.IsSuccessStatusCode)
            {
                await LoadItemAsync(clearStatusMessage: false);
            }
        }
        catch
        {
            _statusMessage = "Runtime analysis failed.";
        }
        finally
        {
            _probingRuntime = false;
        }
    }


    private string BuildSubtitle()
    {
        if (_item is null)
        {
            return string.Empty;
        }

        if (IsEpisode(_item.MediaType))
        {
            return _item.Year.HasValue ? $"Episode · {_item.Year.Value}" : "Episode";
        }

        return _item.Year.HasValue ? $"Series · {_item.Year.Value}" : "Series";
    }

    private static bool IsTvItem(string mediaType)
        => IsEpisode(mediaType) || IsSeries(mediaType);

    private static bool IsEpisode(string mediaType)
        => string.Equals(mediaType, "Episode", StringComparison.OrdinalIgnoreCase);

    private static bool IsSeries(string mediaType)
        => string.Equals(mediaType, "Series", StringComparison.OrdinalIgnoreCase);

}
