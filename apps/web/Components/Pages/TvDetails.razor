    private IReadOnlyList<string> GetSearchReplacementRequestSteps()
    {
        var plan = GetSelectedIssueRemediationPlan();
        return RemediationRequestSteps.Build(
            providerName: "Sonarr",
            itemLabel: "episode",
            issueType: _selectedManualIssueType,
            reasonKey: plan?.ReasonKey,
            profileStep: GetSearchReplacementRequestProfileStep());
    }

    private string GetSearchReplacementRequestProfileStep()
    {
        if (_item is null)
        {
            return "re-check the current acquisition profile before queueing the request.";
        }

        var profile = string.IsNullOrWhiteSpace(_item.QualityProfile) ? "(unset)" : _item.QualityProfile.Trim();
        var normalizedProfile = profile.ToLowerInvariant();
        var issueType = (_selectedManualIssueType ?? string.Empty).Trim().ToLowerInvariant();

        if (issueType is "audio_language_mismatch" or "subtitle_missing" or "subtitle_language_mismatch" or "wrong_language")
        {
            return LooksLikeGenericLanguageProfile(normalizedProfile)
                ? $"likely stop and ask for profile review first because '{profile}' looks too generic for language-driven remediation"
                : $"use the current '{profile}' profile because it already looks specific enough for language-driven remediation";
        }

        if (issueType == "quality_issue")
        {
            return LooksLikeLowCeilingQualityProfile(normalizedProfile)
                ? $"likely stop and ask for profile review first because '{profile}' caps upgrades too low"
                : $"use the current '{profile}' profile because it still allows higher-quality replacements";
        }

        return $"use the current '{profile}' profile because it does not block this remediation path";
    }

    private static bool LooksLikeGenericLanguageProfile(string normalizedProfile)
        => string.IsNullOrWhiteSpace(normalizedProfile)
           || normalizedProfile is "any" or "default"
           || (!normalizedProfile.Contains("english")
               && !normalizedProfile.Contains("eng")
               && !normalizedProfile.Contains("multi")
               && !normalizedProfile.Contains("dub")
               && !normalizedProfile.Contains("sub")
               && !normalizedProfile.Contains("dual")
               && !normalizedProfile.Contains("original"));

    private static bool LooksLikeLowCeilingQualityProfile(string normalizedProfile)
        => normalizedProfile.Contains("sd")
           || normalizedProfile.Contains("dvd")
           || normalizedProfile.Contains("480")
           || normalizedProfile.Contains("576")
           || normalizedProfile.Contains("720")
           || normalizedProfile.Contains("low")
           || normalizedProfile.Contains("mobile");

    private static string BuildManualIssueSummary(ManualIssueOption option, string notes)
        => $"{option.DefaultSummary} Note: {notes.Trim()}";

    private static string ExtractIssueNotes(string detailsJson)
    {
        if (string.IsNullOrWhiteSpace(detailsJson)) return "—";

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(detailsJson);
            if (doc.RootElement.TryGetProperty("notes", out var notes) && notes.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                var value = notes.GetString();
                return string.IsNullOrWhiteSpace(value) ? "—" : value;
            }
        }
        catch
        {
            // ignore malformed details
        }

        return "—";
    }

