@page "/media/music/{Id:long}"
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthorizedApiRequestFactory RequestFactory
@using web.Components.Shared

<PageTitle>@(_item?.DisplayTitle is { Length: > 0 } title ? $"{title} · Music Details" : "Music Details")</PageTitle>

@if (_loading)
{
    <p class="card-note">Loading music details…</p>
}
else if (_item is null || !IsMusicItem(_item.MediaType))
{
    <h1>Music item not found</h1>
    <a href="/media/music" style="color:#93c5fd; text-decoration:none;">← Back to Music</a>
}
else
{
    <MediaDetailHeader BackHref="/media/music"
                       BackLabel="Back to Music"
                       Title="@_item.DisplayTitle"
                       Subtitle="@GetSubtitle(_item)" />

    <MediaItemDetailBody Item="_item"
                         OverviewEmptyText="No description is currently available for this music item."
                         AnalyzeButtonLabel="Analyze file"
                         IsAnalyzing="_probingRuntime"
                         OnAnalyze="@ProbeRuntimeNowAsync" />

    <section class="card" style="margin-top:1rem;">
        <p class="card-label">SOURCE LINKS</p>
        @if (_sourceLinks.Count == 0)
        {
            <p class="card-note">No source links recorded for this item yet.</p>
        }
        else
        {
            <table style="width:100%; border-collapse:collapse; font-size:0.88rem; margin-top:0.45rem;">
                <thead>
                    <tr style="text-align:left; border-bottom:1px solid rgba(148,163,184,0.25);">
                        <th style="padding:0.35rem 0.4rem;">Source</th>
                        <th style="padding:0.35rem 0.4rem;">Instance</th>
                        <th style="padding:0.35rem 0.4rem;">Source Title</th>
                        <th style="padding:0.35rem 0.4rem;">External</th>
                        <th style="padding:0.35rem 0.4rem;">Last Seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var source in _sourceLinks)
                    {
                        <tr style="border-bottom:1px solid rgba(148,163,184,0.12); vertical-align:top;">
                            <td style="padding:0.35rem 0.4rem;">@FormatSourceServiceLabel(source.ServiceKey)</td>
                            <td style="padding:0.35rem 0.4rem;">@DisplayValue(source.InstanceName)</td>
                            <td style="padding:0.35rem 0.4rem;">@DisplaySourceTitle(source)</td>
                            <td style="padding:0.35rem 0.4rem;">@FormatExternalRef(source)</td>
                            <td style="padding:0.35rem 0.4rem;">@source.LastSeenAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter] public long Id { get; set; }

    private bool _loading = true;
    private bool _probingRuntime;
    private string _statusMessage = string.Empty;
    private MediaItemDetailDto? _item;
    private readonly List<LibraryItemSourceLinkDto> _sourceLinks = [];

    protected override Task OnParametersSetAsync()
        => LoadItemAsync();

    private async Task LoadItemAsync(bool clearStatusMessage = true)
    {
        _loading = true;
        if (clearStatusMessage)
        {
            _statusMessage = string.Empty;
        }

        _item = null;
        _sourceLinks.Clear();

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            _item = await response.Content.ReadFromJsonAsync<MediaItemDetailDto>();
            if (_item is null || !IsMusicItem(_item.MediaType))
            {
                _item = null;
                return;
            }

            using var sourceRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{_item.Id}/sources");
            using var sourceResponse = await Http.SendAsync(sourceRequest);
            if (!sourceResponse.IsSuccessStatusCode)
            {
                return;
            }

            var payload = await sourceResponse.Content.ReadFromJsonAsync<List<LibraryItemSourceLinkDto>>() ?? [];
            _sourceLinks.AddRange(payload);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ProbeRuntimeNowAsync()
    {
        if (_item is null)
        {
            return;
        }

        _probingRuntime = true;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/reprobe-runtime");
            using var response = await Http.SendAsync(request);
            var payload = await response.Content.ReadFromJsonAsync<LibraryItemRuntimeProbeResponse>();
            _statusMessage = response.IsSuccessStatusCode
                ? (string.IsNullOrWhiteSpace(payload?.Message) ? "Runtime analysis completed." : payload.Message)
                : $"Runtime analysis failed (HTTP {(int)response.StatusCode}).";

            if (response.IsSuccessStatusCode)
            {
                await LoadItemAsync(clearStatusMessage: false);
            }
        }
        catch
        {
            _statusMessage = "Runtime analysis failed.";
        }
        finally
        {
            _probingRuntime = false;
        }
    }

    private static bool IsMusicItem(string mediaType)
        => string.Equals(mediaType, "Artist", StringComparison.OrdinalIgnoreCase)
           || string.Equals(mediaType, "Album", StringComparison.OrdinalIgnoreCase)
           || string.Equals(mediaType, "Track", StringComparison.OrdinalIgnoreCase);

    private static string GetSubtitle(MediaItemDetailDto item)
    {
        var bits = new List<string>();

        if (!string.IsNullOrWhiteSpace(item.MediaType))
        {
            bits.Add(item.MediaType);
        }

        if (item.Year.HasValue)
        {
            bits.Add(item.Year.Value.ToString());
        }

        return bits.Count == 0 ? "Music item" : string.Join(" · ", bits);
    }

    private static string DisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string DisplaySourceTitle(LibraryItemSourceLinkDto source)
        => string.IsNullOrWhiteSpace(source.SourceTitle) ? DisplayValue(source.SourceSortTitle) : source.SourceTitle;

    private static string FormatExternalRef(LibraryItemSourceLinkDto source)
    {
        var external = string.IsNullOrWhiteSpace(source.ExternalId) ? "—" : source.ExternalId;
        return string.IsNullOrWhiteSpace(source.ExternalType) ? external : $"{source.ExternalType}: {external}";
    }

    private static string FormatSourceServiceLabel(string? serviceKey)
        => (serviceKey ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "lidarr" => "Lidarr",
            "plex" => "Plex",
            "musicbrainz" => "MusicBrainz",
            _ => DisplayValue(serviceKey)
        };

}
