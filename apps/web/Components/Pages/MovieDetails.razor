    ];

    private int OpenIssueCount => _issues.Count(x => string.Equals(x.Status, "Open", StringComparison.OrdinalIgnoreCase));
    private int ResolvedIssueCount => _issues.Count(x => string.Equals(x.Status, "Resolved", StringComparison.OrdinalIgnoreCase));

    protected override Task OnParametersSetAsync()
        => LoadItemAsync();

    private RenderFragment RenderRemediationV2SimpleContent() => @<section class="movie-remediation-scroll-shell">
        <div style="display:grid; gap:1rem;">
            <p class="card-note">A simple answer-first view for end users.</p>

            <div style="display:grid; grid-template-columns:minmax(0, 1fr) minmax(22rem, 22rem); gap:0.75rem; align-items:start;">
                <div style="grid-column:1; grid-row:1; border:1px solid rgba(51,65,85,0.65); border-radius:0.75rem; padding:0.8rem; background:rgba(2,6,23,0.35); display:grid; gap:0.3rem; align-content:start; height:100%;">
                    <p class="card-label">REMEDIATION STEPS</p>
                    <table style="width:100%; border-collapse:collapse; align-self:start;">
                        <thead>
                            <tr style="border-bottom:1px solid rgba(51,65,85,0.55);">
                                <th scope="col" style="text-align:left; padding:0 0 0.45rem; color:#94a3b8; font-size:0.7rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase;">Step</th>
                                <th scope="col" style="text-align:right; width:22%; padding:0 0 0.45rem; color:#94a3b8; font-size:0.7rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var actionSteps = GetRemediationV2ActionSteps(); }
                            @for (var index = 0; index < actionSteps.Count; index++)
                            {
                                var step = actionSteps[index];
                                <tr style="@(index < actionSteps.Count - 1 ? "border-bottom:1px solid rgba(30,41,59,0.6);" : string.Empty)">
                                    <td style="padding:0.65rem 0.65rem 0.65rem 0; vertical-align:top;">
                                        <div style="display:flex; align-items:flex-start; gap:0.45rem; min-height:2rem;">
                                            <span aria-hidden="true" style="color:@(step.Completed ? "#86efac" : step.IsCurrent ? "#93c5fd" : "#64748b"); font-size:0.9rem; line-height:1.35; width:1rem; flex:0 0 1rem; text-align:center;">@(step.Completed ? "☑" : "☐")</span>
                                            <span class="card-note" style="color:@(step.Completed ? "#94a3b8" : step.IsCurrent ? "#e2e8f0" : "#cbd5e1"); text-decoration:@(step.Completed ? "line-through" : "none"); line-height:1.35;">@step.Label</span>
                                        </div>
                                    </td>
                                    <td style="padding:0.65rem 0 0.65rem 0.65rem; width:22%; vertical-align:top; text-align:right;">
                                        @if (!step.Completed && step.IsCurrent && string.Equals(step.Label, "Analyze this file", StringComparison.Ordinal))
                                        {
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Info"
                                                       Size="Size.Small"
                                                       Style="min-width:auto; padding:0; text-transform:none; font-weight:600;"
                                                       OnClick="ScanDetectMetricsAsync"
                                                       Disabled="@_probingRuntime">@(_probingRuntime ? "Scanning..." : "Run scan")</MudButton>
                                        }
                                        else if (!step.Completed && step.IsCurrent && string.Equals(step.Label, "Queue a compatibility fix", StringComparison.Ordinal))
                                        {
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Info"
                                                       Size="Size.Small"
                                                       Style="min-width:auto; padding:0; text-transform:none; font-weight:600;"
                                                       OnClick="QueueCompatibilityActionAsync"
                                                       Disabled="@_queueingCompatibilityAction">@(_queueingCompatibilityAction ? "Queueing..." : "Queue fix")</MudButton>
                                        }
                                        else if (step.Completed)
                                        {
                                            <span class="card-note" style="color:#94a3b8;">Done</span>
                                        }
                                        else if (string.Equals(step.Label, "Review the profile comparison", StringComparison.Ordinal))
                                        {
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Info"
                                                       Size="Size.Small"
                                                       Style="min-width:auto; padding:0; text-transform:none; font-weight:600;"
                                                       OnClick="FocusProfileComparisonAsync">View comparison</MudButton>
                                        }
                                        else if (step.IsCurrent && string.Equals(step.Label, "Choose which action to take", StringComparison.Ordinal))
                                        {
                                            <span class="card-note" style="color:#93c5fd;">Review actions below</span>
                                        }
                                        else if (step.IsCurrent && step.Label.StartsWith("Wait", StringComparison.Ordinal))
                                        {
                                            <span class="card-note" style="color:#93c5fd;">In progress</span>
                                        }
                                        else if (step.IsCurrent && string.Equals(step.Label, "Verify playback after the fix finishes", StringComparison.Ordinal))
                                        {
                                            <span class="card-note" style="color:#93c5fd;">After fix</span>
                                        }
                                        else
                                        {
                                            <span class="card-note" style="color:#64748b;">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (GetRemediationV2ShowDecisionButtons())
                    {
                        <div style="display:grid; gap:0.55rem; padding-top:0.75rem; border-top:1px solid rgba(51,65,85,0.55); margin-top:0.75rem;">
