    private static string GetRemediationHistoryActionLabel(LibraryRemediationJobDto job)
    {
        if (job is null)
        {
            return "—";
        }

        if (!string.IsNullOrWhiteSpace(job.RequestedAction))
        {
            return job.RequestedAction.Replace('_', ' ');
        }

        if (!string.IsNullOrWhiteSpace(job.CommandName))
        {
            return job.CommandName.Replace('_', ' ');
        }

        if (!string.IsNullOrWhiteSpace(job.ReleaseSummary))
        {
            return job.ReleaseSummary;
        }

        return "—";
    }

    private static string GetRemediationHistoryDownloadTypeLabel(LibraryRemediationJobDto job)
    {
        if (!string.IsNullOrWhiteSpace(job.DownloadType))
        {
            return job.DownloadType.Trim();
