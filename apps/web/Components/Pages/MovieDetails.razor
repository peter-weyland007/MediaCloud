    private static bool ShouldShowCompatibilityPill(string? status)
        => (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "match" => false,
            "allowed" => false,
            _ => true
        };

    private static bool ShouldShowPreferredHint(MediaCompatibilityComparisonRowResponse row)
    {
        if (row is null || string.IsNullOrWhiteSpace(row.SelectedProfileValue))
        {
            return false;
        }

        return (row.Status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "outside profile" => true,
            "disc image" => true,
            "allowed" => string.Equals(row.Label, "Container", StringComparison.OrdinalIgnoreCase)
                || string.Equals(row.Label, "Video codec", StringComparison.OrdinalIgnoreCase)
                || string.Equals(row.Label, "Audio", StringComparison.OrdinalIgnoreCase),
            _ => false
        };
    }

