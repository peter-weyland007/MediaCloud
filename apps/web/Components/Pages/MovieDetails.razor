                    }
                    else
                    {
                        <div style="display:grid; gap:0.1rem; align-content:start;">
                            <table style="width:100%; border-collapse:collapse; table-layout:fixed; align-self:start;">
                                <thead>
                                    <tr style="border-bottom:1px solid rgba(51,65,85,0.55);">
                                        <th scope="col" style="text-align:left; padding:0 0.6rem 0.45rem 0; color:#94a3b8; font-size:0.7rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; width:40%;">Item</th>
                                        <th scope="col" style="text-align:left; padding:0 0.6rem 0.45rem 0; color:#94a3b8; font-size:0.7rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; width:30%;">Actual</th>
                                        <th scope="col" style="text-align:left; padding:0 0 0.45rem; color:#94a3b8; font-size:0.7rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; width:30%;">Preferred</th>
