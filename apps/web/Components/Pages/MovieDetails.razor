            && !string.IsNullOrWhiteSpace(GetRecommendedCommandPreview())
            && !_compatibilityJobs.Any(x => string.Equals(x.Status, "Queued", StringComparison.OrdinalIgnoreCase) || string.Equals(x.Status, "Running", StringComparison.OrdinalIgnoreCase));

