    private static bool IsMeaningfulCompatibilityMismatch(MediaCompatibilityComparisonRowResponse row)
    {
        if (row is null)
        {
            return false;
        }

        var status = (row.Status ?? string.Empty).Trim().ToLowerInvariant();
        if (status is "outside profile" or "disc image")
        {
            return true;
        }

        return !string.Equals(DisplayValue(row.InspectedValue), DisplayValue(row.SelectedProfileValue), StringComparison.OrdinalIgnoreCase);
    }

