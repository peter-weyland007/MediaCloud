    private IReadOnlyList<MediaCompatibilityComparisonRowResponse> GetRemediationV2ProfileComparisonRows()
    {
        var comparisonRows = _compatibilityRecommendation?.ComparisonRows ?? [];
        if (comparisonRows.Count == 0)
        {
            return [];
        }

        return comparisonRows
            .Where(row => ShouldShowPreferredHint(row)
                || string.Equals((row.Status ?? string.Empty).Trim(), "Outside profile", StringComparison.OrdinalIgnoreCase)
                || string.Equals((row.Status ?? string.Empty).Trim(), "Disc image", StringComparison.OrdinalIgnoreCase))
            .OrderBy(row =>
            {
                var index = Array.IndexOf(RemediationV2ProfileComparisonOrder, row.Label);
                return index < 0 ? int.MaxValue : index;
            })
            .ThenBy(row => row.Label, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private IReadOnlyList<MediaCompatibilityComparisonRowResponse> GetVisibleRemediationV2ProfileComparisonRows()
    {
        var rows = GetRemediationV2ProfileComparisonRows();
        return _remediationV2ShowAllComparisons
