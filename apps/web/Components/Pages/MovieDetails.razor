    private static string GetSmokeTestOutcomeHeadline(MediaPlaybackSmokeTestResponse smokeTest)
    {
        if (smokeTest.SampleSucceeded && string.Equals(smokeTest.VerdictSeverity, "danger", StringComparison.OrdinalIgnoreCase))
        {
            return "The test worked, but the original file still looks like a poor broad-compatibility match.";
        }

        if (smokeTest.SampleSucceeded)
        {
            return "The smoke test worked and MediaCloud created a short sample successfully.";
        }

        if (smokeTest.SampleAttempted)
        {
            return "MediaCloud tried to create a sample, but the smoke test did not finish cleanly.";
        }

        return "MediaCloud prepared the smoke test but has not run it yet.";
    }

    private static string GetSmokeTestOperatorPlainLanguage(MediaPlaybackSmokeTestResponse smokeTest)
    {
        if (smokeTest.SampleSucceeded && string.Equals(smokeTest.VerdictSeverity, "danger", StringComparison.OrdinalIgnoreCase))
        {
            return "The ffmpeg path is working, so the tool can create a sample. The warning is about the original file format, not the smoke-test pipeline.";
        }

        if (smokeTest.SampleSucceeded)
        {
            return "MediaCloud proved it can process this file into a short sample. Use the compatibility recommendation below to decide whether the original file is good enough to keep as-is.";
        }

        if (smokeTest.SampleAttempted)
        {
            return "This is still an execution problem. Fix the error first, then trust any compatibility recommendation tied to the sample output.";
        }

        return "No sample evidence yet. Run the test to separate toolchain problems from actual playback compatibility problems.";
    }

