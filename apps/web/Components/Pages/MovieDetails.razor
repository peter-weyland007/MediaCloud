    private async Task SyncSourceAsync(LibraryItemSourceStatusDto source)
    {
        if (_item is null || !source.CanSync || string.IsNullOrWhiteSpace(source.ServiceKey))
        {
            return;
        }

        _syncingServices.Add(source.ServiceKey);

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/sources/{source.ServiceKey}/sync");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{source.DisplayName} sync failed (HTTP {(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LibraryItemSourceSyncResponse>();
            if (payload?.SyncedAtUtc is { } syncedAtUtc)
            {
                _sourceSyncRanAtByService[source.ServiceKey] = syncedAtUtc;
            }
            Snackbar.Add(payload?.Message ?? $"{source.DisplayName} sync finished.", payload?.Success == true ? Severity.Success : Severity.Warning);
            await LoadItemAsync(clearStatusMessage: false);
        }
        catch
        {
            Snackbar.Add($"{source.DisplayName} sync failed.", Severity.Error);
        }
        finally
        {
            _syncingServices.Remove(source.ServiceKey);
        }
    }

    private List<LibraryItemSourceLinkDto> GetSourceLinks(LibraryItemSourceStatusDto source)
        => _sourceLinks
            .Where(x => string.Equals(x.ServiceKey, source.ServiceKey, StringComparison.OrdinalIgnoreCase)
                && (source.IntegrationId is null || x.IntegrationId == source.IntegrationId.Value))
            .ToList();

    private static string FormatRuntime(double? minutes)
    {
        if (!minutes.HasValue)
        {
            return "—";
        }

        var totalMinutes = (int)Math.Round(minutes.Value, MidpointRounding.AwayFromZero);
        var hours = totalMinutes / 60;
        var remainingMinutes = totalMinutes % 60;

        if (hours <= 0)
        {
            return $"{remainingMinutes}m";
        }

        if (remainingMinutes <= 0)
        {
            return $"{hours}h";
        }

        return $"{hours}h {remainingMinutes}m";
    }

    private static string FormatList(IReadOnlyList<string>? values)
        => values is { Count: > 0 } ? string.Join(", ", values.Where(x => !string.IsNullOrWhiteSpace(x))) : "—";

    private static string DisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatRemediationV2ComparisonValue(string? label, string? value)
    {
        var display = DisplayValue(value);
        if (display == "—")
        {
            return display;
        }

        return (label ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "container" => NormalizeContainerDisplayValue(display),
            "video codec" => NormalizeCodecDisplayValue(display),
            "subtitles" => NormalizeSubtitleDisplayValue(display),
            _ => display
        };
    }

    private static string NormalizeContainerDisplayValue(string value)
        => value.Trim().ToLowerInvariant() switch
        {
            "matroska,webm" => "MKV",
            "matroska/webm" => "MKV",
            "matroska" => "MKV",
            "mkv" => "MKV",
            "mov,mp4,m4a,3gp,3g2,mj2" => "MP4",
            "mp4" => "MP4",
            "iso" => "ISO",
            _ => value.ToUpperInvariant()
        };

    private static string NormalizeCodecDisplayValue(string value)
        => value.Trim().ToLowerInvariant() switch
        {
            "h264" => "H.264",
            "avc" => "H.264",
            "hevc" => "HEVC",
            "h265" => "H.265",
            "aac" => "AAC",
            _ => value.ToUpperInvariant()
        };

    private static string NormalizeSubtitleDisplayValue(string value)
        => value.Trim().ToLowerInvariant() switch
        {
            "hdmv_pgs_subtitle" => "PGS",
            "pgs" => "PGS",
            "dvd_subtitle" => "VobSub",
            "vobsub" => "VobSub",
            "mov_text" => "Text",
            "text subtitles only" => "Text subtitles only",
            "image subtitles allowed" => "Image subtitles allowed",
            "text preferred" => "Text preferred",
            "none detected" => "None detected",
            _ => value.ToUpperInvariant()
        };

    private static string FormatLastSyncedTimestamp(DateTimeOffset? value)
        => value.HasValue && value.Value.Year > 1900
            ? value.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : "—";

    private static string FormatBoolLabel(bool? value)
        => value.HasValue ? (value.Value ? "Yes" : "No") : "—";

    private string BuildOverviewRuntimeSummary()
    {
        var actual = FormatRuntime(_item?.ActualRuntimeMinutes);
        var reported = FormatRuntime(_item?.RuntimeMinutes);

        if (actual != "—")
        {
            return actual;
        }

        return reported;
    }

    private string BuildOverviewYearAndRatingSummary()
    {
        var year = DisplayValue(_item?.Year?.ToString());
