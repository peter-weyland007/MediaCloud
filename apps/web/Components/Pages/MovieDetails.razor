@page "/media/movies/{Id:long}"
@attribute [Authorize]
@implements IDisposable
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthorizedApiRequestFactory RequestFactory
@inject IJSRuntime JSRuntime
@using web.Components.Shared

<PageTitle>@(_item?.DisplayTitle is { Length: > 0 } title ? $"{title} · Movie Details" : "Movie Details")</PageTitle>

@if (_loading)
{
    <p class="card-note">Loading movie details…</p>
}
else if (_item is null)
{
    <h1>Movie not found</h1>
    <a href="/media/movies" style="color:#93c5fd; text-decoration:none;">← Back to Movies</a>
}
else
{
    <MediaDetailHeader BackHref="/media/movies"
                       BackLabel="Back to Movies"
                       Title="@_item.DisplayTitle"
                       Subtitle="@($"{_item.Year} · {_item.MediaType}")" />

    <section class="movie-detail-tabs-shell" style="margin-top:1rem;">
        <MudTabs Class="movie-detail-tabs" Position="Position.Left" Rounded="true" @bind-ActivePanelIndex="_activeMovieDetailTabIndex">
            <MudTabPanel Text="Overview">
                <div class="movie-overview-hero">
                    <div class="movie-overview-facts-row">
                        <span>@BuildOverviewYearAndRatingSummary()</span>
                        <span>@BuildOverviewRuntimeSummary()</span>
                    </div>

                    <div class="movie-overview-meta-grid">
                        <div class="movie-overview-meta-item movie-overview-meta-item--full-width">
                            <p class="movie-overview-meta-label">Path</p>
                            <p class="movie-overview-meta-value">@BuildOverviewPathSummary()</p>
                        </div>
                        <div class="movie-overview-meta-item">
                            <p class="movie-overview-meta-label">Profile</p>
                            <p class="movie-overview-meta-value">@DisplayValue(_item.QualityProfile)</p>
                        </div>
                        <div class="movie-overview-meta-item">
                            <p class="movie-overview-meta-label">Playability</p>
                            <p class="movie-overview-meta-value">@DisplayValue(_item.PlayabilityScore)</p>
                        </div>
                        <div class="movie-overview-meta-item">
                            <p class="movie-overview-meta-label">Sources</p>
                            <p class="movie-overview-meta-value">@BuildOverviewSourceServicesSummary()</p>
                        </div>
                        <div class="movie-overview-meta-item">
                            <p class="movie-overview-meta-label">Availability</p>
                            <p class="movie-overview-meta-value movie-overview-status @GetOverviewStatusClass()">@GetOverviewStatusLabel()</p>
                        </div>
                        <div class="movie-overview-meta-break" aria-hidden="true"></div>
                        <div class="movie-overview-meta-item movie-overview-meta-item--full-width">
                            <div class="movie-overview-language-row">
                                <div class="movie-overview-meta-item">
                                    <p class="movie-overview-meta-label">Audio</p>
                                    <p class="movie-overview-meta-value">@FormatList(_item.AudioLanguages)</p>
                                </div>
                                <div class="movie-overview-meta-item">
                                    <p class="movie-overview-meta-label">Subtitle Languages</p>
                                    <p class="movie-overview-meta-value">@FormatList(_item.SubtitleLanguages)</p>
                                </div>
                            </div>
                        </div>
                        <div class="movie-overview-meta-item">
                            <p class="movie-overview-meta-label">TMDB</p>
                            <p class="movie-overview-meta-value">@DisplayValue(_item.TmdbId?.ToString())</p>
                        </div>
                        <div class="movie-overview-meta-item">
                            <p class="movie-overview-meta-label">IMDb</p>
                            <p class="movie-overview-meta-value">@DisplayValue(_item.ImdbId)</p>
                        </div>
                    </div>

                    <div class="movie-overview-summary-block">
                        <p class="movie-overview-meta-label">Overview</p>
                        @if (string.IsNullOrWhiteSpace(_item.Description))
                        {
                            <p class="card-note">No description is currently available for this movie.</p>
                        }
                        else
                        {
                            <p class="movie-overview-summary-text">@_item.Description</p>
                        }
                    </div>
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Source Services">
        <section class="movie-detail-source-panel" style="margin-top:1rem;">
            <div style="display:flex; justify-content:space-between; gap:0.75rem; align-items:start; flex-wrap:wrap;">
                <div>
                    <p class="card-label">SOURCE SERVICES</p>
                    <p class="card-note" style="margin:0.35rem 0 0;">Sync a specific source for this movie, then refresh the detail metrics immediately.</p>
                </div>
            </div>

            @if (_sourceStatuses.Count == 0)
            {
                <p class="card-note" style="margin-top:0.75rem;">No source service status is available for this movie.</p>
            }
            else
            {
                <div style="display:grid; gap:0.75rem; margin-top:0.75rem;">
                    @foreach (var source in _sourceStatuses)
                    {
                        var sourceLinks = GetSourceLinks(source);
                        var hasRecordedSync = _sourceSyncRanAtByService.TryGetValue(source.ServiceKey, out var recordedSyncAtUtc);
                        var effectiveSyncedAtUtc = hasRecordedSync ? recordedSyncAtUtc : source.LastSyncedAtUtc;
                        <div style="width:100%; border:1px solid rgba(51,65,85,0.85); border-radius:0.75rem; padding:0.8rem; background:rgba(15,23,42,0.65); display:grid; gap:0.7rem;">
                            <div style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:0.75rem; align-items:start;">
                                <div style="display:grid; gap:0.35rem; min-width:0;">
                                    <div style="display:flex; gap:0.45rem; align-items:center; flex-wrap:wrap;">
                                        <strong>@BuildServiceHeader(source)</strong>
                                        <span style="@GetSourceLinkBadgeStyle(source)">@BuildSourceBadgeLabel(source)</span>
                                    </div>
                                    <span class="card-note">Matched item: @BuildPrimaryMatchedItemSummary(sourceLinks, source.ServiceKey)</span>
                                </div>

                                <div style="display:flex; flex-direction:column; gap:0.2rem; align-items:flex-end; align-self:start; min-width:0;">
                                    <MudButton Class="media-btn media-btn--primary"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Style="min-width:7rem;"
                                               OnClick='() => SyncSourceAsync(source)'
                                               Disabled='@(!source.CanSync || _syncingServices.Contains(source.ServiceKey))'>@(_syncingServices.Contains(source.ServiceKey) ? "Syncing..." : "SYNC")</MudButton>
                                    <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Last synced: @FormatLastSyncedTimestamp(effectiveSyncedAtUtc)</span>
                                </div>
                            </div>

                            <div style="display:grid; gap:0.3rem;">
                                @if (sourceLinks.Count > 0)
                                {
                                    @foreach (var link in sourceLinks)
                                    {
                                        if (!ReferenceEquals(link, sourceLinks[0]))
                                        {
                                            <span class="card-note">Matched item: @BuildMatchedItemSummary(link)</span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span class="card-note">@BuildExternalIdLabel(source.ServiceKey): —</span>
                                }
                            </div>

                        </div>
                    }
                </div>
            }
        </section>
            </MudTabPanel>
            <MudTabPanel Text="File & Identifiers">
    <MediaItemDetailBody Item="_item"
                         OverviewEmptyText="No description is currently available for this movie."
                         AnalyzeButtonLabel="Analyze file"
                         IsAnalyzing="_probingRuntime"
                         ShowOverviewSection="false"
                         ShowSourceServicesSummary="false"
                         FlattenMetricsPanel="true"
                         AnalyzeButtonBelowPrimaryFile="true"
                         OnAnalyze="@ProbeRuntimeNowAsync" />
            </MudTabPanel>
            <MudTabPanel Text="Subtitles">
    <BazarrSubtitlePanel LibraryItemId="@_item.Id" />
            </MudTabPanel>
            <MudTabPanel Text="File Remediation">
                @RenderRemediationV2SimpleContent()
            </MudTabPanel>
            <MudTabPanel Text="Media File Issues">
    <section class="movie-issues-scroll-shell">
        <div>
            <p class="card-label">MEDIA FILE ISSUES</p>
            <p class="card-note">Open: @OpenIssueCount · Resolved: @ResolvedIssueCount</p>
        </div>

        <div id="movie-issues-panel" class="movie-issues-panel-fill" style="display:grid; gap:1rem;">
            <div style="display:grid; gap:0.75rem; padding-top:0.15rem; border-top:1px solid rgba(51,65,85,0.65);">
                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.75rem;">
                    <div class="form-group" style="margin:0;">
                        <label for="movie-issue-type">Issue type</label>
                        <InputSelect id="movie-issue-type" class="input" @bind-Value="_issueForm.IssueType">
                            @foreach (var option in IssueTypeOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label for="movie-issue-status">Status</label>
                        <InputSelect id="movie-issue-status" class="input" @bind-Value="_issueForm.Status">
                            <option value="Open">Open</option>
                            <option value="Resolved">Resolved</option>
                        </InputSelect>
                    </div>
                    <div class="form-group" style="margin:0; display:flex; flex-direction:column; justify-content:flex-end;">
                        <label>Severity</label>
                        <span class="card-note">Auto-set from issue type after save.</span>
                    </div>
                </div>

                <div class="form-group" style="margin:0;">
                    <label for="movie-issue-summary">Summary</label>
                    <InputText id="movie-issue-summary" class="input" @bind-Value="_issueForm.Summary" />
                </div>

                <div style="display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; align-items:start;">
                    <div>
                        @if (!string.IsNullOrWhiteSpace(_issuesStatusMessage))
                        {
                            <p class="card-note" style="margin:0;">@_issuesStatusMessage</p>
                        }
                    </div>
                    <MudButton Class="media-btn media-btn--primary"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="CreateIssueAsync"
                               Disabled="@_savingIssue">@(_savingIssue ? "Saving..." : "Save issue")</MudButton>
                </div>
            </div>

            <div style="display:grid; gap:0.75rem;">
                @if (_issuesLoading)
                {
                    <p class="card-note">Loading issue history…</p>
                }
                else if (_issues.Count == 0)
                {
                    <p class="card-note">No issues have been recorded for this media file yet.</p>
                }
                else
                {
                    @foreach (var issue in _issues)
                    {
                        <div style="border:1px solid rgba(51,65,85,0.85); border-radius:0.75rem; padding:0.8rem; background:rgba(15,23,42,0.65); display:grid; gap:0.5rem;">
                            <div style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:0.75rem; align-items:start;">
                                <div style="display:grid; gap:0.35rem; min-width:0;">
                                    <div style="display:flex; gap:0.45rem; align-items:center; flex-wrap:wrap;">
                                        <strong>@GetIssueTypeLabel(issue.IssueType)</strong>
                                        <span style="@GetIssueStatusBadgeStyle(issue.Status)">@issue.Status</span>
                                        <span style="@GetIssueSeverityBadgeStyle(issue.Severity)">@issue.Severity</span>
                                    </div>
                                    <span>@issue.Summary</span>
                                    @if (!string.IsNullOrWhiteSpace(issue.IssueNotes))
                                    {
                                        <span class="card-note">@issue.IssueNotes</span>
                                    }
                                </div>

                                <div style="display:flex; flex-direction:column; gap:0.2rem; align-items:flex-end; min-width:0;">
                                    @if (string.Equals(issue.Status, "Open", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <MudButton Class="media-btn media-btn--primary"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick='() => ResolveIssueAsync(issue)'
                                                   Disabled="@_resolvingIssueIds.Contains(issue.Id)">@(_resolvingIssueIds.Contains(issue.Id) ? "Resolving..." : "Resolve")</MudButton>
                                    }
                                    <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Reported: @FormatIssueTimestamp(issue.ReportedAtUtc ?? issue.FirstDetectedAtUtc)</span>
                                    <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Updated: @FormatIssueTimestamp(issue.LastDetectedAtUtc)</span>
                                    @if (issue.ResolvedAtUtc.HasValue)
                                    {
                                        <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Resolved: @FormatIssueTimestamp(issue.ResolvedAtUtc.Value)</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
            </MudTabPanel>
        </MudTabs>
    </section>
}
<style>
    .movie-overview-hero {
        display: grid;
        gap: 1.15rem;
        padding: 0.25rem 0.15rem 0.35rem;
    }

    .movie-overview-facts-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem 1rem;
        align-items: center;
        color: #e5e7eb;
        font-size: 0.98rem;
    }

    .movie-overview-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.16rem 0.58rem;
        border: 1px solid rgba(148,163,184,0.38);
        border-radius: 999px;
        color: #f8fafc;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        background: rgba(15,23,42,0.55);
    }

    .movie-overview-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
        gap: 1rem 1.35rem;
    }

    .movie-overview-meta-item {
        display: grid;
        gap: 0.22rem;
        min-width: 0;
    }

    .movie-overview-meta-item--full-width {
        grid-column: 1 / -1;
    }

    .movie-overview-meta-break {
        grid-column: 1 / -1;
        height: 0;
    }

    .movie-overview-language-row {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem 1.35rem;
    }

    .movie-overview-language-row .movie-overview-meta-item {
        gap: 0.22rem;
    }

    .movie-overview-meta-label {
        margin: 0;
        color: #94a3b8;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .movie-overview-meta-value {
        margin: 0;
        color: #f8fafc;
        font-size: 1rem;
        line-height: 1.45;
        word-break: break-word;
    }

    .movie-overview-status {
        position: relative;
        padding-left: 0.8rem;
    }

    .movie-overview-status::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.18rem;
        bottom: 0.18rem;
        width: 0.22rem;
        border-radius: 999px;
        background: rgba(148,163,184,0.7);
    }

    .movie-overview-status--good::before {
        background: #22c55e;
    }

    .movie-overview-status--warn::before {
        background: #f59e0b;
    }

    .movie-overview-summary-block {
        display: grid;
        gap: 0.45rem;
        max-width: 70rem;
    }

    .movie-overview-summary-text {
        margin: 0;
        color: #e5e7eb;
        line-height: 1.7;
        font-size: 1.02rem;
        white-space: pre-wrap;
    }

    .movie-detail-tabs-shell {
        width: 100%;
    }

    .movie-detail-tabs {
        margin-top: 0.25rem;
    }

    .movie-detail-tabs .mud-tabs-toolbar {
        gap: 1rem;
    }

    .movie-detail-tabs .mud-tabs-tabbar {
        background: transparent !important;
        border: none;
        border-right: 1px solid rgba(51,65,85,0.4);
        border-radius: 0;
        padding: 0;
        padding-right: 0.5rem;
        min-width: 13rem;
        box-shadow: none !important;
    }

    .movie-detail-tabs .mud-tabs-tabbar-content,
    .movie-detail-tabs .mud-tabs-toolbar,
    .movie-detail-tabs .mud-tabs-tabbar-wrapper {
        background: transparent !important;
        box-shadow: none !important;
    }

    .movie-detail-tabs .mud-tab {
        justify-content: flex-start;
        text-align: left;
        border-radius: 8px;
        margin-bottom: 0.2rem;
        min-height: 2.35rem;
        padding: 0.55rem 0.8rem;
        color: #cbd5e1;
        border: 1px solid transparent;
        text-transform: none;
        letter-spacing: 0;
        font-weight: 600;
    }

    .movie-detail-tabs .mud-tab:hover {
        background: #1f2937;
        border-color: #334155;
    }

    .movie-detail-tabs .mud-tab.mud-tab-active {
        background: #1d4ed8;
        color: #ffffff;
        border-color: transparent;
    }

    .movie-detail-tabs .mud-tab-slider {
        display: none;
    }

    .movie-detail-tabs .mud-tabs-panels {
        padding: 0 0 0 1rem;
    }

    .movie-remediation-scroll-shell {
        margin-top: 1rem;
        display: grid;
        gap: 1rem;
        max-height: calc(100vh - 13rem);
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 0.35rem;
        scrollbar-gutter: stable;
        overscroll-behavior: contain;
    }

    .movie-remediation-card--focus {
        box-shadow: 0 0 0 1px rgba(59,130,246,0.35), 0 0 0 4px rgba(59,130,246,0.12);
        transition: box-shadow 0.2s ease;
    }

    .movie-remediation-status-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
    }

    .movie-remediation-progress-shell {
        display: grid;
        gap: 0.35rem;
        margin-top: 0.15rem;
    }

    .movie-remediation-progress-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: center;
    }

    .movie-remediation-progress-bar {
        width: 100%;
    }

    .movie-remediation-progress-text {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
    }

    .movie-remediation-progress-heartbeat {
        color: #94a3b8;
        font-size: 0.76rem;
    }

    .movie-remediation-status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        padding: 0.16rem 0.56rem;
        border-radius: 999px;
        font-size: 0.7rem;
        line-height: 1;
        font-weight: 700;
        border: 1px solid rgba(148,163,184,0.35);
        background: rgba(51,65,85,0.35);
        color: #e2e8f0;
    }

    .movie-remediation-status-pill--good {
        background: rgba(34,197,94,0.18);
        color: #bbf7d0;
        border-color: rgba(34,197,94,0.45);
    }

    .movie-remediation-status-pill--warn {
        background: rgba(245,158,11,0.18);
        color: #fde68a;
        border-color: rgba(245,158,11,0.45);
    }

    .movie-remediation-status-pill--danger {
        background: rgba(239,68,68,0.18);
        color: #fecaca;
        border-color: rgba(239,68,68,0.48);
    }

    .movie-remediation-status-pill--info {
        background: rgba(59,130,246,0.18);
        color: #bfdbfe;
        border-color: rgba(59,130,246,0.45);
    }

    .movie-remediation-status-pill--muted {
        background: rgba(100,116,139,0.18);
        color: #cbd5e1;
        border-color: rgba(100,116,139,0.4);
    }

    .movie-remediation-why-grid {

        grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
        gap: 0.9rem;
        align-items: start;
    }

    .movie-remediation-why-notes {
        border: 1px solid rgba(51,65,85,0.65);
        border-radius: 0.75rem;
        padding: 0.85rem;
        background: rgba(2,6,23,0.28);
        min-width: 0;
        display: grid;
        gap: 0.75rem;
        align-content: start;
    }

    .movie-remediation-why-compare {
        min-width: 0;
        display: grid;
        align-content: start;
    }

    .movie-issues-scroll-shell {
        margin-top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-height: calc(100vh - 13rem);
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 0.35rem;
        scrollbar-gutter: stable;
        overscroll-behavior: contain;
    }

    .movie-issues-panel-fill {
        flex: 1 1 auto;
        min-height: 0;
        align-content: start;
    }

    .movie-detail-top-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(20rem, 36rem);
        gap: 1rem;
        align-items: start;
    }

    .movie-detail-source-panel {
        width: 100%;
        justify-self: start;
    }

    .movie-issues-toggle {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        background: transparent;
        border: none;
        color: inherit;
        padding: 0;
        text-align: left;
        cursor: pointer;
    }

    .movie-issues-chevron {
        font-size: 1.05rem;
        color: #cbd5e1;
    }

    .movie-compatibility-table-wrap {
        overflow-x: auto;
        border: 1px solid rgba(51,65,85,0.8);
        border-radius: 0.8rem;
        background: rgba(15,23,42,0.42);
    }

    .movie-compatibility-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 34rem;
    }

    .movie-compatibility-table th,
    .movie-compatibility-table td {
        padding: 0.58rem 0.72rem;
        border-bottom: 1px solid rgba(51,65,85,0.7);
        text-align: left;
        vertical-align: top;
    }

    .movie-compatibility-table thead th {
        font-size: 0.7rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: #94a3b8;
        font-weight: 700;
        background: rgba(15,23,42,0.7);
        white-space: nowrap;
    }

    .movie-compatibility-table tbody th {
        color: #f8fafc;
        font-weight: 700;
        width: 20%;
    }

    .movie-compatibility-table tbody td {
        color: #e2e8f0;
    }

    .movie-compatibility-table tbody tr:last-child th,
    .movie-compatibility-table tbody tr:last-child td {
        border-bottom: none;
    }

    .movie-compatibility-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        padding: 0.18rem 0.56rem;
        border-radius: 999px;
        font-size: 0.72rem;
        line-height: 1;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .movie-compatibility-status--match {
        background: rgba(16, 185, 129, 0.14);
        color: #86efac;
        border-color: rgba(16, 185, 129, 0.35);
    }

    .movie-compatibility-status--allowed {
        background: rgba(59, 130, 246, 0.14);
        color: #93c5fd;
        border-color: rgba(59, 130, 246, 0.35);
    }

    .movie-compatibility-status--outside {
        background: rgba(245, 158, 11, 0.14);
        color: #fcd34d;
        border-color: rgba(245, 158, 11, 0.35);
    }

    .movie-compatibility-status--disc-image {
        background: rgba(168, 85, 247, 0.14);
