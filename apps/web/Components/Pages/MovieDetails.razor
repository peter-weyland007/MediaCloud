    private readonly List<LibraryItemSourceLinkDto> _sourceLinks = [];
    private readonly HashSet<string> _syncingServices = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<long> _resolvingIssueIds = [];
    private readonly Dictionary<string, DateTimeOffset?> _sourceSyncRanAtByService = new(StringComparer.OrdinalIgnoreCase);
    private IssueFormModel _issueForm = new();

    private static readonly IReadOnlyList<IssueTypeOption> IssueTypeOptions =
    [
        new("manual_issue", "General file issue"),
        new("playback_stall", "Playback stalls / buffers"),
        new("resume_starts_over", "Resume starts over"),
        new("seeking_issue", "Seeking / scrubbing issue"),
        new("subtitle_unusable", "Subtitle issue"),
        new("audio_wrong_during_playback", "Audio issue"),
