    private static string GetRemediationHistoryPillDefinition(string category, string? value)
    {
        var normalizedCategory = (category ?? string.Empty).Trim().ToLowerInvariant();
        var normalizedValue = (value ?? string.Empty).Trim();
        var key = normalizedValue.ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(normalizedValue) || normalizedValue == "—")
        {
            return normalizedCategory switch
            {
                "download type" => "MediaCloud does not have provider data showing whether this replacement came from Usenet or Torrent.",
                _ => $"No additional detail is available for {category.ToLowerInvariant()} yet."
            };
        }

        if (normalizedCategory == "integration step")
        {
            return key switch
            {
                "queued" => "MediaCloud asked the provider to run the replacement search, but there is no live grab or download evidence yet.",
                "searchqueued" => "The replacement search itself was queued with the provider.",
                "blacklistedandqueued" => "MediaCloud blacklisted the current release and queued a new replacement search.",
                "grabbed" => "The provider selected a replacement release and is waiting for download/import to continue.",
                "downloading" => "The provider is actively downloading the replacement file now.",
                "importing" => "The provider finished downloading and is importing the replacement into the library.",
                "imported" => "The provider says the replacement imported, and MediaCloud is waiting for refreshed local evidence.",
                "completed" => "The provider-side replacement step finished.",
                "noresults" => "The provider search ran but did not find a downloadable replacement.",
                "failed" => "The provider-side replacement step failed.",
                "blocked" => "MediaCloud intentionally did not send this forward because it needs review or is not allowed to auto-run.",
                "notstarted" => "This remediation path has not started yet.",
                "pending" => "MediaCloud is still waiting for enough evidence to advance this step.",
                "standby" => "Wait for the current remediation attempt to finish before repeating it.",
                _ => $"Integration step: {normalizedValue}."
            };
        }

        if (normalizedCategory == "status")
        {
            return key switch
            {
                "processing" => "MediaCloud is actively tracking this remediation and waiting for the provider or local evidence to advance.",
                "resolved" => "MediaCloud believes the issue is fixed.",
                "verificationfailed" => "A replacement happened, but the latest evidence still shows the issue.",
                "failed" => "The remediation request failed before MediaCloud could verify a fix.",
                "noreplacementfound" => "MediaCloud completed the search flow, but no replacement was found.",
                "blockedprofilereview" => "MediaCloud stopped here because the acquisition profile needs review first.",
                "blockedmanualreview" => "MediaCloud stopped here because this case needs manual review.",
                "importedreplacement" => "A replacement appears to be in place, but MediaCloud still wants fresher evidence.",
                _ => $"Status: {normalizedValue}."
            };
        }

        if (normalizedCategory == "verification")
        {
            return key switch
            {
                "verified" => "MediaCloud checked the latest evidence and believes the issue is fixed.",
                "waitingforevidence" => "The provider may be done, but MediaCloud is still waiting for refreshed file metadata or probe results.",
                "pending" => "Verification cannot finish yet because the replacement flow is still in progress.",
                "failed" => "Verification ran and still found a problem.",
                "nomatch" => "No replacement was found, so there is nothing new for MediaCloud to verify yet.",
                "notstarted" => "Verification has not started yet.",
                _ => $"Verification: {normalizedValue}."
            };
        }

        if (normalizedCategory == "provider state")
        {
            return key switch
            {
                "queued" => "The provider accepted the command but has not started running it yet.",
                "started" => "The provider started the command.",
                "running" => "The provider is actively running the command now.",
                "completed" => "The provider reports that the command finished.",
                "failed" => "The provider reports that the command failed.",
                "aborted" => "The provider reports that the command was aborted.",
                _ => $"Provider state: {normalizedValue}."
            };
        }

        if (normalizedCategory == "download type")
        {
            return key switch
            {
                "torrent" => "The provider reported this replacement is coming from a torrent source.",
                "usenet" => "The provider reported this replacement is coming from a Usenet source.",
                "unknown" => "The movie is in a download/import phase, but the provider did not tell MediaCloud whether it is Usenet or Torrent.",
                _ => $"Download type: {normalizedValue}."
            };
        }

        return $"{category}: {normalizedValue}.";
    }

    private static string GetRemediationHistoryDownloadTypePillClass(LibraryRemediationJobDto job)
    {
        if (!string.IsNullOrWhiteSpace(job.DownloadType))
        {
            return GetRemediationHistoryStatusPillClass(job.DownloadType);
        }

        return IsRemediationHistoryDownloadPhase(job.SearchStatus)
            ? "movie-remediation-status-pill--warn"
            : "movie-remediation-status-pill--muted";
    }

    private static bool IsRemediationHistoryDownloadPhase(string? searchStatus)
        => (searchStatus ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "grabbed" or "downloading" or "importing" or "imported" => true,
            _ => false
        };

    private IEnumerable<LibraryRemediationJobDto> GetRecentRemediationHistoryJobs(int count)
        => _compatibilityJobs.Take(Math.Max(count, 0));

    private async Task OpenFullRemediationHistoryAsync()
    {
        _activeMovieDetailTabIndex = FileRemediationTabIndex;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", @"(() => {
                const card = document.getElementById('remediation-history');
                if (!card) return;
                card.scrollIntoView({ behavior: 'smooth', block: 'start' });
                window.scrollBy({ top: -96, behavior: 'auto' });
                card.setAttribute('tabindex', '-1');
                card.focus({ preventScroll: true });
                card.classList.remove('movie-remediation-card--focus');
                void card.offsetWidth;
                card.classList.add('movie-remediation-card--focus');
                setTimeout(() => card.classList.remove('movie-remediation-card--focus'), 2400);
            })()");
        }
        catch
        {
            // Best-effort tab switch and scroll only.
        }
    }

    private async Task FocusProfileComparisonAsync()
    {
        _remediationV2ShowAllComparisons = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", @"(() => {
                const card = document.getElementById('remediation-v2-profile-comparison');
                if (!card) return;
                card.scrollIntoView({ behavior: 'smooth', block: 'start' });
                window.scrollBy({ top: -96, behavior: 'auto' });
                card.setAttribute('tabindex', '-1');
                card.focus({ preventScroll: true });
                card.classList.remove('movie-remediation-card--focus');
                void card.offsetWidth;
                card.classList.add('movie-remediation-card--focus');
                setTimeout(() => card.classList.remove('movie-remediation-card--focus'), 2400);
            })()");
        }
        catch
        {
            // Best-effort focus/highlight only.
        }
    }

