    private async Task SyncPreferredManualIssueTypeAsync(bool keepCurrentSelectionWhenPresent = true)
    {
        var preferred = DeterminePreferredManualIssueType();
        if (string.IsNullOrWhiteSpace(preferred))
        {
            await LoadSelectedManualIssueAsync();
            return;
        }

        var currentSelection = (_selectedManualIssueType ?? string.Empty).Trim();
        var currentExistsInHistory = _manualIssueHistory.Any(x => string.Equals(x.IssueType, currentSelection, StringComparison.OrdinalIgnoreCase));
        var currentOpenExists = _manualIssueHistory.Any(x => string.Equals(x.IssueType, currentSelection, StringComparison.OrdinalIgnoreCase)
            && string.Equals(x.Status, "Open", StringComparison.OrdinalIgnoreCase));

        if (keepCurrentSelectionWhenPresent && (currentOpenExists || currentExistsInHistory))
        {
            await LoadSelectedManualIssueAsync();
            return;
        }

        _selectedManualIssueType = preferred;
        await LoadSelectedManualIssueAsync();
    }

    private string DeterminePreferredManualIssueType()
    {
        var preferred = _manualIssueHistory
            .Where(x => ManualIssueOptions.Any(option => string.Equals(option.Key, x.IssueType, StringComparison.OrdinalIgnoreCase)))
            .OrderByDescending(x => string.Equals(x.Status, "Open", StringComparison.OrdinalIgnoreCase))
            .ThenByDescending(x => x.LastDetectedAtUtc)
            .Select(x => x.IssueType)
            .FirstOrDefault();

        return string.IsNullOrWhiteSpace(preferred)
            ? _selectedManualIssueType
            : preferred;
    }

