                    }
                </div>
                <div id="remediation-v2-profile-comparison" style="grid-column:2; grid-row:1; border:1px solid rgba(51,65,85,0.65); border-radius:0.75rem; padding:0.8rem; background:rgba(2,6,23,0.35); display:grid; gap:0.1rem; align-content:start; height:100%;">
                    <p class="card-label">PROFILE COMPARISON</p>
