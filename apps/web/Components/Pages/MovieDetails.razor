    private static string GetSmokeTestBasicTakeaway(MediaPlaybackSmokeTestResponse smokeTest)
    {
        if (string.Equals(smokeTest.VerdictSeverity, "danger", StringComparison.OrdinalIgnoreCase))
        {
            return "This file may still play on some clients, but it is outside your safer all-purpose target.";
        }

        if (string.Equals(smokeTest.VerdictSeverity, "warning", StringComparison.OrdinalIgnoreCase))
        {
            return "This file is close, but MediaCloud still sees enough mismatch to keep an eye on it.";
        }

        return "This file looks close to the active target profile.";
    }

    private static string GetSmokeTestNextStep(MediaPlaybackSmokeTestResponse smokeTest)
    {
        if (!smokeTest.SampleSucceeded && smokeTest.SampleAttempted)
        {
            return "Fix the test failure first so you know whether you are dealing with a real compatibility issue or just a broken sample path.";
        }

        if (string.Equals(smokeTest.VerdictSeverity, "danger", StringComparison.OrdinalIgnoreCase))
        {
            return "Keep it if your real client already behaves well, or plan a replacement/full transcode if you want broader device safety.";
        }

        if (string.Equals(smokeTest.VerdictSeverity, "warning", StringComparison.OrdinalIgnoreCase))
        {
            return "Monitor real playback on the target client before deciding whether remediation is worth it.";
        }

        return "No urgent action needed unless real playback issues show up.";
    }

