        {
            return;
        }

        _runningPlaybackSmokeTest = true;
        _playbackSmokeTestStatusMessage = string.Empty;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/playback-smoke-test");
            request.Content = JsonContent.Create(new MediaPlaybackSmokeTestRequest());
            using var response = await Http.SendAsync(request);
            var payload = await response.Content.ReadFromJsonAsync<MediaPlaybackSmokeTestResponse>();
            if (!response.IsSuccessStatusCode || payload is null)
