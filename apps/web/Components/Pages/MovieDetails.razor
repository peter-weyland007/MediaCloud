            "audio_out_of_sync" => new ManualIssueRemediationPlan("playback_failure", "Search Radarr for a replacement when the file plays but the audio timing is broken."),
            "wrong_version" => new ManualIssueRemediationPlan("wrong_version", "Search Radarr for the correct cut/version of this movie."),
            "quality_issue" => new ManualIssueRemediationPlan("quality_issue", "Search Radarr for a better-quality replacement."),
