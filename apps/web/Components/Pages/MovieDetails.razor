                                                <span class="card-note" style="color:#f8fafc; font-weight:700;">@GetRemediationV2PrimaryActionLabel()</span>
                                                <span class="card-note" style="color:#cbd5e1;">@GetRemediationV2PrimaryActionEffectText()</span>
