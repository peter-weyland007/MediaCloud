    private string GetRuntimeMatchLabel()
    {
        if (_item is null || !_item.RuntimeMinutes.HasValue || !_item.ActualRuntimeMinutes.HasValue)
        {
            return "Unknown";
        }

        if (_runtimeMismatchIssue is not null && string.Equals(_runtimeMismatchIssue.Status, "Open", StringComparison.OrdinalIgnoreCase))
        {
            return $"Mismatch ({_runtimeMismatchIssue.Severity})";
        }

        return "Match";
    }

    private string GetRuntimeMatchBadgeStyle()
    {
        const string baseStyle = "display:inline-block; padding:0.22rem 0.55rem; border-radius:999px; font-size:0.8rem; font-weight:700; letter-spacing:0.01em;";

        if (_item is null || !_item.RuntimeMinutes.HasValue || !_item.ActualRuntimeMinutes.HasValue)
        {
            return baseStyle + "background:rgba(148,163,184,0.18); color:#cbd5e1; border:1px solid rgba(148,163,184,0.35);";
        }

        if (_runtimeMismatchIssue is null || !string.Equals(_runtimeMismatchIssue.Status, "Open", StringComparison.OrdinalIgnoreCase))
        {
            return baseStyle + "background:rgba(16,185,129,0.18); color:#6ee7b7; border:1px solid rgba(16,185,129,0.45);";
        }

        var severity = (_runtimeMismatchIssue.Severity ?? string.Empty).Trim().ToLowerInvariant();
        return severity switch
        {
            "critical" => baseStyle + "background:rgba(239,68,68,0.22); color:#fecaca; border:1px solid rgba(239,68,68,0.65);",
            "high" => baseStyle + "background:rgba(249,115,22,0.22); color:#fed7aa; border:1px solid rgba(249,115,22,0.65);",
            _ => baseStyle + "background:rgba(234,179,8,0.22); color:#fde68a; border:1px solid rgba(234,179,8,0.65);"
        };
    }

    private string GetRuntimeMatchDetail()
    {
        if (_item is null)
        {
            return "Probe actual runtime to compare against reported runtime.";
        }

        if (!_item.RuntimeMinutes.HasValue || !_item.ActualRuntimeMinutes.HasValue)
        {
            if (!_item.LocalFileExists && !string.IsNullOrWhiteSpace(_item.PrimaryFilePath))
            {
                return "Actual runtime unavailable on this host because the mapped file path is not accessible locally.";
            }

            return "Probe actual runtime to compare against reported runtime.";
        }

        if (_runtimeMismatch is not null)
        {
            var thresholdText = _runtimeMismatch.ThresholdMinutes > 0
                ? $" · threshold {_runtimeMismatch.ThresholdMinutes:0.##}m"
                : string.Empty;
            return $"Δ {_runtimeMismatch.DiffMinutes:0.##}m ({_runtimeMismatch.DiffPercent:0.##} %){thresholdText}";
        }

        var diffMinutes = Math.Abs(_item.ActualRuntimeMinutes.Value - _item.RuntimeMinutes.Value);
        var diffPercent = (_item.RuntimeMinutes.Value <= 0)
            ? 0
            : (diffMinutes / _item.RuntimeMinutes.Value) * 100d;
        return $"Δ {diffMinutes:0.##}m ({diffPercent:0.##} %)";
    }

    private static RuntimeMismatchDetails? ParseRuntimeMismatchDetails(string? detailsJson)
    {
        if (string.IsNullOrWhiteSpace(detailsJson)) return null;

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(detailsJson);
            var root = doc.RootElement;
            var diffMinutes = root.TryGetProperty("diffMinutes", out var diffMinutesElement) ? diffMinutesElement.GetDouble() : 0;
            var diffPercent = root.TryGetProperty("diffPercent", out var diffPercentElement) ? diffPercentElement.GetDouble() : 0;
            var thresholdMinutes = root.TryGetProperty("thresholdMinutes", out var thresholdElement) ? thresholdElement.GetDouble() : 0;
            return new RuntimeMismatchDetails(diffMinutes, diffPercent, thresholdMinutes);
        }
        catch
        {
            return null;
        }
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private static string FormatRuntime(double? runtimeMinutes)
        => runtimeMinutes.HasValue && runtimeMinutes.Value > 0 ? $"{runtimeMinutes.Value:0.##} min" : "—";

    private const int MovieDescriptionPreviewLength = 360;

    private bool ShouldShowDescriptionToggle()
        => !string.IsNullOrWhiteSpace(_item?.Description) && _item.Description.Length > MovieDescriptionPreviewLength;

    private string GetMovieDescriptionText()
    {
        var description = (_item?.Description ?? string.Empty).Trim();
        if (_isMovieDescriptionExpanded || description.Length <= MovieDescriptionPreviewLength)
        {
            return description;
        }

        return description[..MovieDescriptionPreviewLength].TrimEnd() + "…";
    }

    private void ToggleMovieDescriptionExpanded()
        => _isMovieDescriptionExpanded = !_isMovieDescriptionExpanded;

    private static string GetDescriptionSourceLabel(string? serviceKey)
    {
        var key = (serviceKey ?? string.Empty).Trim();
        if (key.Equals("radarr", StringComparison.OrdinalIgnoreCase)) return "Radarr";
        if (key.Equals("plex", StringComparison.OrdinalIgnoreCase)) return "Plex";
        if (key.Equals("overseerr", StringComparison.OrdinalIgnoreCase)) return "Overseerr";
        if (key.Equals("sonarr", StringComparison.OrdinalIgnoreCase)) return "Sonarr";
        return string.IsNullOrWhiteSpace(key) ? "Unknown" : char.ToUpperInvariant(key[0]) + key[1..];
    }

    private string FormatActualRuntime(double? runtimeMinutes)
    {
        if (runtimeMinutes.HasValue && runtimeMinutes.Value > 0)
        {
            return $"{runtimeMinutes.Value:0.##} min";
        }

        return ShowActualRuntimeUnavailableNote()
            ? "Unavailable on this host"
            : "—";
    }

    private bool ShowActualRuntimeUnavailableNote()
        => _item is not null
           && !_item.LocalFileExists
           && !string.IsNullOrWhiteSpace(_item.PrimaryFilePath)
           && !_item.ActualRuntimeMinutes.HasValue;

    private string GetPlayabilityLabel()
        => string.IsNullOrWhiteSpace(_item?.PlayabilityScore) ? "Unknown" : _item!.PlayabilityScore;

    private string GetPlayabilitySummary()
    {
        if (_item is null || string.IsNullOrWhiteSpace(_item.PlayabilitySummary))
        {
            return "Run ffprobe against a locally visible file to score practical Plex compatibility.";
        }

        if (_item.PlayabilityCheckedAtUtc.HasValue)
        {
            return $"{_item.PlayabilitySummary} Checked {_item.PlayabilityCheckedAtUtc.Value.ToLocalTime():yyyy-MM-dd HH:mm}.";
        }

        return _item.PlayabilitySummary;
    }

    private string GetPlayabilityBadgeStyle()
    {
        const string baseStyle = "display:inline-block; padding:0.2rem 0.52rem; border-radius:999px; font-size:0.78rem; font-weight:700; letter-spacing:0.01em;";
        return (_item?.PlayabilityScore ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "excellent" => baseStyle + "background:rgba(16,185,129,0.18); color:#6ee7b7; border:1px solid rgba(16,185,129,0.45);",
            "good" => baseStyle + "background:rgba(59,130,246,0.18); color:#bfdbfe; border:1px solid rgba(59,130,246,0.45);",
            "transcode likely" => baseStyle + "background:rgba(234,179,8,0.22); color:#fde68a; border:1px solid rgba(234,179,8,0.65);",
            "problematic" => baseStyle + "background:rgba(239,68,68,0.22); color:#fecaca; border:1px solid rgba(239,68,68,0.65);",
            _ => baseStyle + "background:rgba(148,163,184,0.18); color:#cbd5e1; border:1px solid rgba(148,163,184,0.35);"
        };
    }

