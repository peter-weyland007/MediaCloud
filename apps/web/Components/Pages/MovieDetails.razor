    private async Task CreateIssueAsync()
    {
        if (_item is null)
        {
            return;
        }

        _savingIssue = true;
        _issuesStatusMessage = string.Empty;
        try
        {
            var summary = string.IsNullOrWhiteSpace(_issueForm.Summary)
                ? $"{GetIssueTypeLabel(_issueForm.IssueType)} reported for {_item.DisplayTitle}."
                : _issueForm.Summary.Trim();

            var requestBody = new CreateLibraryIssueRequest(
                _issueForm.IssueType,
                string.Empty,
                summary,
                string.Empty,
                string.Empty,
                _issueForm.Status,
                string.Empty,
                string.Empty,
                string.Empty,
                "manual");

            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/issues");
            request.Content = JsonContent.Create(requestBody);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _issuesStatusMessage = $"Failed to save issue (HTTP {(int)response.StatusCode}).";
                Snackbar.Add(_issuesStatusMessage, Severity.Error);
                return;
            }

            _issuesStatusMessage = "Issue saved.";
            Snackbar.Add(_issuesStatusMessage, Severity.Success);
