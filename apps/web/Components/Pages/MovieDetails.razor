            await LoadIssuesAsync();
        }
        catch
        {
            _issuesStatusMessage = "Failed to save issue.";
            Snackbar.Add(_issuesStatusMessage, Severity.Error);
        }
        finally
        {
            _savingIssue = false;
        }
