    private IEnumerable<string> GetSmokeTestPlainLanguageReasons(MediaPlaybackSmokeTestResponse smokeTest)
    {
        var translated = (smokeTest.Reasons ?? [])
            .Where(reason => !string.IsNullOrWhiteSpace(reason))
            .Select(TranslateSmokeTestReason)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(4)
            .ToList();

        if (translated.Count > 0)
        {
            return translated;
        }

        if (!string.IsNullOrWhiteSpace(smokeTest.WhySummary))
        {
            return [smokeTest.WhySummary];
        }

        return ["MediaCloud detected a mismatch between the current file and the preferred playback target."];
    }

    private static string TranslateSmokeTestReason(string reason)
    {
        var normalized = reason.Trim();
        if (normalized.Contains("MKV/Matroska", StringComparison.OrdinalIgnoreCase))
        {
            return "The file is packaged as MKV. Your preferred target leans toward MP4 because it usually works on more devices with less drama.";
        }

        if (normalized.Contains("HEVC", StringComparison.OrdinalIgnoreCase))
        {
            return "The video uses HEVC/x265. Your preferred target leans toward H.264 because it is the safer broad-compatibility codec.";
        }

        if (normalized.Contains("10-bit", StringComparison.OrdinalIgnoreCase))
        {
            return "The video is 10-bit, which is outside the safer target profile you selected.";
        }

        if (normalized.Contains("subtitle", StringComparison.OrdinalIgnoreCase))
        {
            return "Subtitle format may force extra conversion work on some clients.";
        }

        return normalized;
    }

