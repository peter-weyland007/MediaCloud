                                        <tr style="@(index < comparisonRows.Count - 1 ? "border-bottom:1px solid rgba(30,41,59,0.6);" : string.Empty)">
                                            <td style="padding:0.35rem 0.6rem 0.35rem 0; vertical-align:top; color:#e2e8f0; font-weight:600; line-height:1.35;">@row.Label</td>
