                            <p class="card-note">The latest actions MediaCloud has already taken for this movie.</p>
                            @if (HasActiveCompatibilityJob())
                            {
                                <p class="card-note">Compatibility remediation is active. MediaCloud will refresh this history automatically.</p>
                            }
                            @if (_remediationHistoryRefreshedAtUtc.HasValue)
                            {
                                <p class="card-note">Last refreshed: @FormatIssueTimestamp(_remediationHistoryRefreshedAtUtc.Value)</p>
                            }
                        </div>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   Style="min-width:auto; padding:0; text-transform:none; font-weight:600;"
                                   OnClick="RefreshRemediationHistoryAsync"
                                   Disabled="@_refreshingRemediationHistory">@(_refreshingRemediationHistory ? "Refreshing..." : "Refresh status")</MudButton>
                    </div>
                    @if (_compatibilityJobs.Count == 0)
                    {
                        <p class="card-note">No remediation actions have been recorded for this movie yet.</p>
                    }
                    else
                    {
                        @foreach (var job in GetRecentRemediationHistoryJobs(3))
                        {
                            <div style="border-top:1px solid rgba(51,65,85,0.45); padding-top:0.55rem; display:grid; gap:0.35rem;">
                                <p class="card-note"><strong>@DisplayValue(job.ServiceDisplayName)</strong> · @GetRemediationHistoryActionLabel(job)</p>
                                <div class="movie-remediation-status-row">
                                    <span class="card-note">Status:</span>
                                    <MudTooltip Arrow="true" Placement="Placement.Top" Text="@GetRemediationHistoryStatusDefinition(job)">
                                        <span class="movie-remediation-status-pill @GetRemediationHistoryStatusPillClass(job.Status)">@DisplayValue(job.Status)</span>
                                    </MudTooltip>
                                    <span class="card-note">Requested:</span>
                                    <span class="card-note">@FormatIssueTimestamp(job.RequestedAtUtc)</span>
                                </div>
                                <div class="movie-remediation-status-row">
                                    <span class="card-note">Integration step:</span>
                                    <MudTooltip Arrow="true" Placement="Placement.Top" Text="@GetRemediationHistoryIntegrationStepDefinition(job)">
                                        <span class="movie-remediation-status-pill @GetRemediationHistoryStatusPillClass(job.SearchStatus)">@DisplayValue(job.SearchStatus)</span>
                                    </MudTooltip>
                                    <span class="card-note">Verification:</span>
                                    <MudTooltip Arrow="true" Placement="Placement.Top" Text="@GetRemediationHistoryVerificationDefinition(job)">
                                        <span class="movie-remediation-status-pill @GetRemediationHistoryStatusPillClass(job.VerificationStatus)">@DisplayValue(job.VerificationStatus)</span>
                                    </MudTooltip>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(job.ProviderCommandStatus))
                                {
                                    <div class="movie-remediation-status-row">
                                        <span class="card-note">Provider state:</span>
                                        <MudTooltip Arrow="true" Placement="Placement.Top" Text="@GetRemediationHistoryProviderStateDefinition(job)">
                                            <span class="movie-remediation-status-pill @GetRemediationHistoryStatusPillClass(job.ProviderCommandStatus)">@DisplayValue(job.ProviderCommandStatus)</span>
                                        </MudTooltip>
                                    </div>
                                }
                                <div class="movie-remediation-status-row">
                                    <span class="card-note">Download type:</span>
                                    <MudTooltip Arrow="true" Placement="Placement.Top" Text="@GetRemediationHistoryDownloadTypeDefinition(job)">
                                        <span class="movie-remediation-status-pill @GetRemediationHistoryDownloadTypePillClass(job)">@GetRemediationHistoryDownloadTypeLabel(job)</span>
                                    </MudTooltip>
                                </div>
                                @if (ShouldShowCompatibilityProgress(job))
                                {
                                    <div class="movie-remediation-progress-shell" role="status" aria-live="polite">
                                        @if (IsCompatibilityProgressIndeterminate(job))
                                        {
                                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Class="movie-remediation-progress-bar" />
                                        }
                                        else
                                        {
                                            <MudProgressLinear Color="Color.Primary" Value="@GetCompatibilityProgressPercent(job).GetValueOrDefault()" Rounded="true" Class="movie-remediation-progress-bar" />
                                        }
                                        <div class="movie-remediation-progress-meta">
                                            <span class="movie-remediation-progress-text">@GetCompatibilityProgressLabel(job)</span>
                                            @if (!string.IsNullOrWhiteSpace(GetCompatibilityProgressHeartbeat(job)))
                                            {
                                                <span class="movie-remediation-progress-heartbeat">@GetCompatibilityProgressHeartbeat(job)</span>
                                            }
                                        </div>
                                    </div>
                                }
                                @if (!ShouldShowCompatibilityProgress(job) && !string.IsNullOrWhiteSpace(job.OutcomeSummary))
                                {
                                    <p class="card-note">Outcome: @DisplayValue(job.OutcomeSummary)</p>
                                }
                                else if (!string.IsNullOrWhiteSpace(job.ResultMessage))
                                {
                                    <p class="card-note">Result: @DisplayValue(job.ResultMessage)</p>
                                }
                            </div>
                        }
                    }
                </div>
            }


            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="card-note">@_statusMessage</p>
            }
        </div>
    </section>;

    private async Task LoadItemAsync(bool clearStatusMessage = true)
    {
        _loading = true;
        await RefreshRemediationAccessAsync();
        if (clearStatusMessage)
        {
            _statusMessage = string.Empty;
        }

        _item = null;
        _playbackSmokeTest = null;
        _playbackSmokeTestStatusMessage = string.Empty;
        _compatibilityQueueStatusMessage = string.Empty;
        _sourceStatuses.Clear();
        _sourceLinks.Clear();
        _compatibilityJobs.Clear();
        _remediationHistoryRefreshedAtUtc = null;

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            _item = await response.Content.ReadFromJsonAsync<MediaItemDetailDto>();
            if (_item is null)
            {
                return;
            }

            await LoadSourcePanelAsync();
            await LoadIssuesAsync();
            await LoadCompatibilityRecommendationAsync();
            if (_canManageRemediation)
            {
                await LoadCompatibilityJobsAsync();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadSourcePanelAsync()
    {
        using var statusRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/source-status");
        using var statusResponse = await Http.SendAsync(statusRequest);
        if (statusResponse.IsSuccessStatusCode)
        {
            var statuses = await statusResponse.Content.ReadFromJsonAsync<List<LibraryItemSourceStatusDto>>() ?? [];
            _sourceStatuses.Clear();
            _sourceStatuses.AddRange(statuses.OrderBy(x => x.DisplayName));
        }

        using var linksRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/sources");
        using var linksResponse = await Http.SendAsync(linksRequest);
        if (linksResponse.IsSuccessStatusCode)
        {
            var links = await linksResponse.Content.ReadFromJsonAsync<List<LibraryItemSourceLinkDto>>() ?? [];
            _sourceLinks.Clear();
            _sourceLinks.AddRange(links.OrderBy(x => x.ServiceKey).ThenBy(x => x.InstanceName));
        }
    }

    private async Task LoadIssuesAsync()
    {
        _issuesLoading = true;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/issues?take=100");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _issuesStatusMessage = $"Failed to load issue history (HTTP {(int)response.StatusCode}).";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<List<LibraryIssueDto>>() ?? [];
            _issues.Clear();
            _issues.AddRange(payload.OrderByDescending(x => x.LastDetectedAtUtc).ThenByDescending(x => x.Id));
        }
        catch
        {
            _issuesStatusMessage = "Failed to load issue history.";
        }
        finally
        {
            _issuesLoading = false;
        }
    }

    private async Task LoadCompatibilityRecommendationAsync()
    {
        _compatibilityLoading = true;
        _compatibilityStatusMessage = string.Empty;
        _compatibilityRecommendation = null;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/media-compatibility-recommendation");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _compatibilityStatusMessage = $"Failed to load preset comparison (HTTP {(int)response.StatusCode}).";
                return;
            }

            _compatibilityRecommendation = await response.Content.ReadFromJsonAsync<MediaCompatibilityRecommendationResponse>();
        }
        catch
        {
            _compatibilityStatusMessage = "Failed to load preset comparison.";
        }
        finally
        {
            _compatibilityLoading = false;
        }
    }

    private async Task LoadCompatibilityJobsAsync()
    {
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/remediation-jobs?take=20");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<List<LibraryRemediationJobDto>>() ?? [];
            _compatibilityJobs.Clear();
            _compatibilityJobs.AddRange(payload
                .OrderByDescending(x => x.RequestedAtUtc)
                .ThenByDescending(x => x.Id));
            _remediationHistoryRefreshedAtUtc = DateTimeOffset.Now;
            SyncCompatibilityJobPolling();
        }
        catch
        {
            _compatibilityJobs.Clear();
            StopCompatibilityJobPolling();
        }
    }

    private async Task RefreshRemediationHistoryAsync()
    {
        _refreshingRemediationHistory = true;
        try
        {
            await LoadCompatibilityJobsAsync();
            Snackbar.Add("Remediation history refreshed.", Severity.Info);
        }
        catch
        {
            Snackbar.Add("Failed to refresh remediation history.", Severity.Error);
        }
        finally
        {
            _refreshingRemediationHistory = false;
        }
    }

    private void SyncCompatibilityJobPolling()
    {
        if (HasActiveCompatibilityJob())
        {
            StartCompatibilityJobPolling();
            return;
        }

        StopCompatibilityJobPolling();
    }

    private void StartCompatibilityJobPolling()
    {
        if (_compatibilityJobPollingTask is { IsCompleted: false })
        {
            return;
        }

        StopCompatibilityJobPolling();
        _compatibilityJobPollingCts = new CancellationTokenSource();
        _compatibilityJobPollingTask = RunCompatibilityJobPollingAsync(_compatibilityJobPollingCts.Token);
    }

    private async Task RunCompatibilityJobPollingAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(4), cancellationToken);
                if (cancellationToken.IsCancellationRequested)
                {
                    break;
                }

                await InvokeAsync(async () =>
                {
                    if (_refreshingRemediationHistory)
                    {
                        return;
                    }

                    await LoadCompatibilityJobsAsync();
                    StateHasChanged();
                });

                if (!HasActiveCompatibilityJob())
                {
                    break;
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopCompatibilityJobPolling()
    {
        _compatibilityJobPollingCts?.Cancel();
        _compatibilityJobPollingCts?.Dispose();
        _compatibilityJobPollingCts = null;
        _compatibilityJobPollingTask = null;
    }

    public void Dispose()
        => StopCompatibilityJobPolling();

    private async Task QueueCompatibilityActionAsync()
    {
        if (_item is null || string.IsNullOrWhiteSpace(GetRecommendedCommandPreview()))
        {
            return;
        }

        _queueingCompatibilityAction = true;
        _compatibilityQueueStatusMessage = string.Empty;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/media-compatibility-remediation/queue");
            using var response = await Http.SendAsync(request);
            var payload = await response.Content.ReadFromJsonAsync<QueueMediaCompatibilityRemediationResponse>();
            if (!response.IsSuccessStatusCode || payload is null)
            {
                _compatibilityQueueStatusMessage = $"Failed to queue ffmpeg action (HTTP {(int)response.StatusCode}).";
                Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Error);
                return;
            }

            _compatibilityQueueStatusMessage = payload.Message;
            Snackbar.Add(payload.Message, payload.AlreadyQueued ? Severity.Info : Severity.Success);
            await LoadCompatibilityJobsAsync();
        }
        catch
        {
            _compatibilityQueueStatusMessage = "Failed to queue ffmpeg action.";
            Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Error);
        }
        finally
        {
            _queueingCompatibilityAction = false;
        }
    }

    private async Task RequestBetterFileAsync()
    {
        if (_item is null)
        {
            return;
        }

        if (!_canManageRemediation)
        {
            _compatibilityQueueStatusMessage = "Admin access is required to request a replacement file.";
            Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Warning);
            return;
        }

        _requestingBetterFile = true;
        _compatibilityQueueStatusMessage = string.Empty;
        try
        {
            var notes = $"Approved from Remediation v2 because file is outside the preferred playback profile. {GetRemediationV2WhySummary()}";
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/remediation/search-replacement");
            request.Content = JsonContent.Create(new SearchReplacementRequest("request_better_file", notes, "media_compatibility"));

            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _compatibilityQueueStatusMessage = string.IsNullOrWhiteSpace(error?.Error)
                    ? $"Failed to request a better file (HTTP {(int)response.StatusCode})."
                    : error.Error;
                Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LibraryItemRemediationResponse>();
            _compatibilityQueueStatusMessage = string.IsNullOrWhiteSpace(payload?.Message)
                ? "Replacement search approved. MediaCloud asked the source service for a better file."
                : payload.Message;
            Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Success);
            await LoadCompatibilityJobsAsync();
        }
        catch
        {
            _compatibilityQueueStatusMessage = "Failed to request a better file.";
            Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Error);
        }
        finally
        {
            _requestingBetterFile = false;
        }
    }

    private Task LeaveAsIsAsync()
    {
        _compatibilityQueueStatusMessage = IsLanguageIssueRequiringManualRemediation()
            ? "Left as-is for now. Possible client/default-track issue. MediaCloud did not queue a fix or request a replacement."
            : "Left as-is for now. MediaCloud did not queue a fix or request a replacement.";
        Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Info);
        return Task.CompletedTask;
    }

    private Task ConvertAnywayAsync()
    {
        _compatibilityQueueStatusMessage = IsLanguageIssueRequiringManualRemediation()
            ? "MediaCloud still cannot guarantee the correct spoken language here. Use the operator remediation panel only if you want to force a generic conversion anyway."
            : "Manual conversion review is still required here. Use the operator remediation panel if you want to force a one-off conversion.";
        Snackbar.Add(_compatibilityQueueStatusMessage, Severity.Warning);
        return Task.CompletedTask;
    }

    private async Task RefreshRemediationAccessAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _canManageRemediation = authState.User.Identity?.IsAuthenticated == true
                && authState.User.IsInRole("Admin");
        }
        catch
        {
            _canManageRemediation = false;
        }
    }

    private async Task ProbeRuntimeNowAsync()
    {
        if (_item is null)
        {
            return;
        }

        _probingRuntime = true;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/reprobe-runtime");
            using var response = await Http.SendAsync(request);
            var payload = await response.Content.ReadFromJsonAsync<LibraryItemRuntimeProbeResponse>();
            _statusMessage = response.IsSuccessStatusCode
                ? (string.IsNullOrWhiteSpace(payload?.Message) ? "Runtime analysis completed." : payload.Message)
                : $"Runtime analysis failed (HTTP {(int)response.StatusCode}).";

            if (response.IsSuccessStatusCode)
            {
                await LoadItemAsync(clearStatusMessage: false);
            }
        }
        catch
        {
            _statusMessage = "Runtime analysis failed.";
        }
        finally
        {
            _probingRuntime = false;
        }
    }

    private async Task ScanDetectMetricsAsync()
        => await ProbeRuntimeNowAsync();

    private async Task RunPlaybackSmokeTestAsync()
    {
