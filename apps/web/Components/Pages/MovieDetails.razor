    private string GetRemediationV2ProblemSummary()
    {
        if (_compatibilityRecommendation is null)
        {
            return "MediaCloud has not analyzed this file yet.";
        }

        var mismatch = GetCompatibilityMismatchRows().FirstOrDefault();
        if (mismatch is null)
        {
            return "MediaCloud did not find a major compatibility mismatch.";
        }

        return mismatch.Label switch
        {
            "Container" => "The file packaging does not match your preferred playback target.",
            "Video codec" => "The video format is outside your preferred playback target.",
            "Audio" => "The audio format is outside your preferred playback target.",
            "Subtitles" => "The subtitle setup is outside your preferred playback target.",
            _ => $"{mismatch.Label} is outside your preferred playback target."
        };
    }

    private IReadOnlyList<RemediationV2ChecklistStep> GetRemediationV2ActionSteps()
    {
        var hasRecommendation = _compatibilityRecommendation is not null;
        var hasQueuedJob = _compatibilityJobs.Any(x => string.Equals(x.Status, "Queued", StringComparison.OrdinalIgnoreCase));
        var hasRunningJob = _compatibilityJobs.Any(x => string.Equals(x.Status, "Running", StringComparison.OrdinalIgnoreCase));
        var hasAnyFixJob = hasQueuedJob || hasRunningJob || _compatibilityJobs.Any(x =>
            string.Equals(x.Status, "Completed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.Status, "Succeeded", StringComparison.OrdinalIgnoreCase));

        if (!hasRecommendation)
        {
            return
            [
                new("Analyze this file", false, true),
                new("Review the profile comparison", false, false)
            ];
        }

        if (GetRemediationV2ProfileComparisonRows().Count == 0)
        {
            return
            [
                new("Analyze this file", true, false),
                new("No action needed", false, true)
            ];
        }

        if (hasRunningJob)
        {
            return
            [
                new("Analyze this file", true, false),
                new("Queue a compatibility fix", true, false),
                new("Wait for the current fix to finish", false, true)
            ];
        }

        if (hasQueuedJob)
        {
            return
            [
                new("Analyze this file", true, false),
                new("Queue a compatibility fix", true, false),
                new("Wait for the queued fix to run", false, true)
            ];
        }

        if (IsLanguageIssueRequiringManualRemediation())
        {
            return
            [
                new("Analyze this file", true, false),
                new("Review the profile comparison", false, false),
                new("Choose which action to take", false, true)
            ];
        }

        if (_compatibilityRecommendation.SafeToQueue)
        {
            return
            [
                new("Analyze this file", true, false),
                new("Queue a compatibility fix", hasAnyFixJob, !hasAnyFixJob),
                new("Verify playback after the fix finishes", false, false)
            ];
        }

        return
        [
            new("Analyze this file", true, false),
            new("Review the profile comparison", false, false),
            new("Choose which action to take", false, true)
        ];
    }

    private string GetRemediationV2CurrentFileRiskLabel()
        => _compatibilityRecommendation?.CurrentFileRiskLabel is { Length: > 0 } label ? label : "Unknown";

    private string GetRemediationV2ConversionRiskLabel()
        => _compatibilityRecommendation?.ConversionRiskLabel is { Length: > 0 } label ? label : "Unknown";

    private string GetRemediationV2WhySummary()
    {
        if (_compatibilityRecommendation is null)
        {
            return "MediaCloud needs one scan before it can give a recommendation.";
        }

        if (_compatibilityJobs.Any(x => string.Equals(x.Status, "Running", StringComparison.OrdinalIgnoreCase)))
        {
            return "MediaCloud is already running a fix for this title.";
        }

        if (_compatibilityJobs.Any(x => string.Equals(x.Status, "Queued", StringComparison.OrdinalIgnoreCase)))
        {
            return "MediaCloud already has a fix queued for this title.";
        }

        if (!string.IsNullOrWhiteSpace(_compatibilityRecommendation.UserDecisionSummary))
        {
            return _compatibilityRecommendation.UserDecisionSummary;
        }

        if (IsLanguageIssueRequiringManualRemediation())
        {
            return "MediaCloud cannot safely auto-fix a wrong-language report yet. Decide how to handle the audio-language issue after you confirm whether the preferred track is missing, mis-tagged, or just not selected by default.";
        }

        if (!_compatibilityRecommendation.SafeToQueue)
        {
            return "This would need a full video conversion, so MediaCloud wants a human review before doing anything.";
        }

        return "This looks like a lower-risk compatibility fix that MediaCloud can queue without changing the original file automatically.";
    }

    private IReadOnlyList<LibraryIssueDto> GetOpenRemediationIssues()
        => _issues
            .Where(x => string.Equals(x.Status, "Open", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.ReportedAtUtc ?? x.LastDetectedAtUtc)
            .ThenByDescending(x => x.Id)
            .ToList();

    private string BuildRemediationIssueContextSummary(LibraryIssueDto issue)
    {
        var summary = string.IsNullOrWhiteSpace(issue.Summary)
            ? GetIssueTypeLabel(issue.IssueType)
            : issue.Summary.Trim();
        var notes = string.IsNullOrWhiteSpace(issue.IssueNotes)
            ? string.Empty
            : $" Notes: {issue.IssueNotes.Trim()}";
        var reportedAt = issue.ReportedAtUtc ?? issue.FirstDetectedAtUtc;
        return $"{summary}.{notes} Reported {FormatIssueTimestamp(reportedAt)}.";
    }

    private string BuildRemediationIssueFitSummary()
    {
        if (HasOpenIssueType("audio_wrong_during_playback") && (_item?.AudioLanguages?.Contains("eng", StringComparer.OrdinalIgnoreCase) ?? false))
        {
            return "MediaCloud already sees English audio metadata on this file, so the reported wrong-language behavior may be default-track selection, stream-order drift, or bad metadata. A compatibility rebuild only helps if it deliberately rewrites stream defaults/metadata; otherwise a replacement or metadata fix is safer.";
        }

        if (HasOpenIssueType("audio_wrong_during_playback"))
        {
            return "An audio-language report should bias remediation, but it should not auto-queue a conversion blindly. MediaCloud should verify whether the preferred language track is actually missing before treating conversion as the fix.";
        }

        if (HasOpenIssueType("subtitle_unusable"))
        {
            return "Subtitle reports should steer remediation toward subtitle replacement or subtitle-specific cleanup first, not assume a generic compatibility conversion solves it.";
        }

        if (HasOpenIssueType("device_specific_issue") || HasOpenIssueType("resume_starts_over") || HasOpenIssueType("seeking_issue"))
        {
            return "This looks partly client- or playback-behavior-specific, so MediaCloud should treat the report as evidence, not as proof that a file conversion is the right fix.";
        }

        return "Open reported issues should stay visible inside remediation so operators can judge whether the recommended file action actually addresses the complaint.";
    }

