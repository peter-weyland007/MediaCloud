        return IsRemediationHistoryDownloadPhase(job.SearchStatus)
            ? "Unknown"
            : "—";
    }

    private static string GetRemediationHistoryStatusDefinition(LibraryRemediationJobDto job)
        => GetRemediationHistoryPillDefinition("Status", job.Status);

    private static string GetRemediationHistoryIntegrationStepDefinition(LibraryRemediationJobDto job)
        => GetRemediationHistoryPillDefinition("Integration step", job.SearchStatus);

    private static string GetRemediationHistoryVerificationDefinition(LibraryRemediationJobDto job)
