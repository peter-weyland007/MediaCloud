    private static string GetCompatibilityStatusLabel(string? status)
        => (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "match" => "Recommended",
            "allowed" => "Acceptable",
            "outside profile" => "Caution",
            "disc image" => "Disc Image",
            _ => "Legacy"
        };

