@page "/media/movies/{Id:long}"
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthorizedApiRequestFactory RequestFactory
@using web.Components.Shared

<PageTitle>@(_item?.DisplayTitle is { Length: > 0 } title ? $"{title} · Movie Details" : "Movie Details")</PageTitle>

@if (_loading)
{
    <p class="card-note">Loading movie details…</p>
}
else if (_item is null)
{
    <h1>Movie not found</h1>
    <a href="/media/movies" style="color:#93c5fd; text-decoration:none;">← Back to Movies</a>
}
else
{
    <MediaDetailHeader BackHref="/media/movies"
                       BackLabel="Back to Movies"
                       Title="@_item.DisplayTitle"
                       Subtitle="@($"{_item.Year} · {_item.MediaType}")" />

    <section class="movie-detail-top-grid">
        <section class="card" style="margin-top:1rem;">
            <p class="card-label">OVERVIEW</p>
            @if (string.IsNullOrWhiteSpace(_item.Description))
            {
                <p class="card-note">No description is currently available for this movie.</p>
            }
            else
            {
                <p style="margin:0.35rem 0 0; line-height:1.55; color:#e2e8f0; white-space:pre-wrap;">@_item.Description</p>
            }
        </section>

        <section class="card movie-detail-source-panel" style="margin-top:1rem;">
            <div style="display:flex; justify-content:space-between; gap:0.75rem; align-items:start; flex-wrap:wrap;">
                <div>
                    <p class="card-label">SOURCE SERVICES</p>
                    <p class="card-note" style="margin:0.35rem 0 0;">Sync a specific source for this movie, then refresh the detail metrics immediately.</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(_sourcePanelStatusMessage))
                {
                    <span class="card-note">@_sourcePanelStatusMessage</span>
                }
            </div>

            @if (_sourceStatuses.Count == 0)
            {
                <p class="card-note" style="margin-top:0.75rem;">No source service status is available for this movie.</p>
            }
            else
            {
                <div style="display:grid; gap:0.75rem; margin-top:0.75rem;">
                    @foreach (var source in _sourceStatuses)
                    {
                        var sourceLinks = GetSourceLinks(source);
                        var hasRecordedSync = _sourceSyncRanAtByService.TryGetValue(source.ServiceKey, out var recordedSyncAtUtc);
                        var effectiveSyncedAtUtc = hasRecordedSync ? recordedSyncAtUtc : source.LastSyncedAtUtc;
                        <div style="width:100%; border:1px solid rgba(51,65,85,0.85); border-radius:0.75rem; padding:0.8rem; background:rgba(15,23,42,0.65); display:grid; gap:0.7rem;">
                            <div style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:0.75rem; align-items:start;">
                                <div style="display:grid; gap:0.35rem; min-width:0;">
                                    <div style="display:flex; gap:0.45rem; align-items:center; flex-wrap:wrap;">
                                        <strong>@BuildServiceHeader(source)</strong>
                                        <span style="@GetSourceLinkBadgeStyle(source)">@BuildSourceBadgeLabel(source)</span>
                                    </div>
                                    <span class="card-note">Matched item: @BuildPrimaryMatchedItemSummary(sourceLinks, source.ServiceKey)</span>
                                </div>

                                <div style="display:flex; flex-direction:column; gap:0.2rem; align-items:flex-end; align-self:start; min-width:0;">
                                    <MudButton Class="media-btn media-btn--primary"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick='() => SyncSourceAsync(source)'
                                               Disabled='@(!source.CanSync || _syncingServices.Contains(source.ServiceKey))'>@(_syncingServices.Contains(source.ServiceKey) ? "Syncing..." : "SYNC")</MudButton>
                                    <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Last synced: @(effectiveSyncedAtUtc.HasValue ? effectiveSyncedAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") : "—")</span>
                                </div>
                            </div>

                            <div style="display:grid; gap:0.3rem;">
                                @if (sourceLinks.Count > 0)
                                {
                                    @foreach (var link in sourceLinks)
                                    {
                                        if (!ReferenceEquals(link, sourceLinks[0]))
                                        {
                                            <span class="card-note">Matched item: @BuildMatchedItemSummary(link)</span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span class="card-note">@BuildExternalIdLabel(source.ServiceKey): —</span>
                                }
                            </div>

                        </div>
                    }
                </div>
            }
        </section>
    </section>

    <MediaItemDetailBody Item="_item"
                         OverviewEmptyText="No description is currently available for this movie."
                         AnalyzeButtonLabel="Analyze file"
                         IsAnalyzing="_probingRuntime"
                         ShowOverviewSection="false"
                         ShowSourceServicesSummary="false"
                         OnAnalyze="@ProbeRuntimeNowAsync" />

    <BazarrSubtitlePanel LibraryItemId="@_item.Id" />

    <section class="card" style="margin-top:1rem;">
        <button type="button"
                class="movie-issues-toggle"
                @onclick="ToggleCompatibilityPanel"
                aria-expanded="@_compatibilityExpanded"
                aria-controls="movie-compatibility-panel">
            <span>
                <span class="card-label" style="display:block;">PROFILE MATCH MATRIX</span>
                <span class="card-note">Target vs file table for playback fit.</span>
                @if (_compatibilityRecommendation is not null)
                {
                    <span class="card-note" style="display:block; margin-top:0.2rem;">Preset: @_compatibilityRecommendation.ActivePresetName</span>
                }
            </span>
            <span class="movie-issues-chevron">@(_compatibilityExpanded ? "▾" : "▸")</span>
        </button>

        @if (_compatibilityExpanded)
        {
            <div id="movie-compatibility-panel" style="margin-top:1rem; display:grid; gap:0.85rem;">
                @if (_compatibilityLoading)
                {
                    <p class="card-note">Loading preset comparison…</p>
                }
                else if (!string.IsNullOrWhiteSpace(_compatibilityStatusMessage))
                {
                    <p class="card-note">@_compatibilityStatusMessage</p>
                }
                else if (_compatibilityRecommendation is null || _compatibilityRecommendation.ComparisonRows.Count == 0)
                {
                    <p class="card-note">No preset comparison is available until MediaCloud has analyzed this file.</p>
                }
                else
                {
                    <div class="movie-compatibility-table-wrap">
                        <table class="movie-compatibility-table">
                            <thead>
                                <tr>
                                    <th scope="col">Trait</th>
                                    <th scope="col">Target</th>
                                    <th scope="col">File</th>
                                    <th scope="col">Fit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _compatibilityRecommendation.ComparisonRows)
                                {
                                    <tr>
                                        <th scope="row">@row.Label</th>
                                        <td>@row.SelectedProfileValue</td>
                                        <td>@row.InspectedValue</td>
                                        <td>
                                            <span class="movie-compatibility-status @GetCompatibilityStatusClass(row.Status)">@GetCompatibilityStatusLabel(row.Status)</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </section>

    <section class="card" style="margin-top:1rem;">
        <button type="button"
                class="movie-issues-toggle"
                @onclick="ToggleIssuesPanel"
                aria-expanded="@_issuesExpanded"
                aria-controls="movie-issues-panel">
            <span>
                <span class="card-label" style="display:block;">MEDIA FILE ISSUES</span>
                <span class="card-note">Open: @OpenIssueCount · Resolved: @ResolvedIssueCount</span>
            </span>
            <span class="movie-issues-chevron">@(_issuesExpanded ? "▾" : "▸")</span>
        </button>

        @if (_issuesExpanded)
        {
            <div id="movie-issues-panel" style="margin-top:1rem; display:grid; gap:1rem;">
                <div style="display:grid; gap:0.75rem; padding-top:0.15rem; border-top:1px solid rgba(51,65,85,0.65);">
                    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.75rem;">
                        <div class="form-group" style="margin:0;">
                            <label for="movie-issue-type">Issue type</label>
                            <InputSelect id="movie-issue-type" class="input" @bind-Value="_issueForm.IssueType">
                                @foreach (var option in IssueTypeOptions)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label for="movie-issue-status">Status</label>
                            <InputSelect id="movie-issue-status" class="input" @bind-Value="_issueForm.Status">
                                <option value="Open">Open</option>
                                <option value="Resolved">Resolved</option>
                            </InputSelect>
                        </div>
                        <div class="form-group" style="margin:0; display:flex; flex-direction:column; justify-content:flex-end;">
                            <label>Severity</label>
                            <span class="card-note">Auto-set from issue type after save.</span>
                        </div>
                    </div>

                    <div class="form-group" style="margin:0;">
                        <label for="movie-issue-summary">Summary</label>
                        <InputText id="movie-issue-summary" class="input" @bind-Value="_issueForm.Summary" />
                    </div>

                    <div style="display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; align-items:start;">
                        <div>
                            @if (!string.IsNullOrWhiteSpace(_issuesStatusMessage))
                            {
                                <p class="card-note" style="margin:0;">@_issuesStatusMessage</p>
                            }
                        </div>
                        <MudButton Class="media-btn media-btn--primary"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="CreateIssueAsync"
                                   Disabled="@_savingIssue">@(_savingIssue ? "Saving..." : "Save issue")</MudButton>
                    </div>
                </div>

                <div style="display:grid; gap:0.75rem;">
                    @if (_issuesLoading)
                    {
                        <p class="card-note">Loading issue history…</p>
                    }
                    else if (_issues.Count == 0)
                    {
                        <p class="card-note">No issues have been recorded for this media file yet.</p>
                    }
                    else
                    {
                        @foreach (var issue in _issues)
                        {
                            <div style="border:1px solid rgba(51,65,85,0.85); border-radius:0.75rem; padding:0.8rem; background:rgba(15,23,42,0.65); display:grid; gap:0.5rem;">
                                <div style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:0.75rem; align-items:start;">
                                    <div style="display:grid; gap:0.35rem; min-width:0;">
                                        <div style="display:flex; gap:0.45rem; align-items:center; flex-wrap:wrap;">
                                            <strong>@GetIssueTypeLabel(issue.IssueType)</strong>
                                            <span style="@GetIssueStatusBadgeStyle(issue.Status)">@issue.Status</span>
                                            <span style="@GetIssueSeverityBadgeStyle(issue.Severity)">@issue.Severity</span>
                                        </div>
                                        <span>@issue.Summary</span>
                                        @if (!string.IsNullOrWhiteSpace(issue.IssueNotes))
                                        {
                                            <span class="card-note">@issue.IssueNotes</span>
                                        }
                                    </div>

                                    <div style="display:flex; flex-direction:column; gap:0.2rem; align-items:flex-end; min-width:0;">
                                        @if (string.Equals(issue.Status, "Open", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <MudButton Class="media-btn media-btn--primary"
                                                       Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       OnClick='() => ResolveIssueAsync(issue)'
                                                       Disabled="@_resolvingIssueIds.Contains(issue.Id)">@(_resolvingIssueIds.Contains(issue.Id) ? "Resolving..." : "Resolve")</MudButton>
                                        }
                                        <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Reported: @FormatIssueTimestamp(issue.ReportedAtUtc ?? issue.FirstDetectedAtUtc)</span>
                                        <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Updated: @FormatIssueTimestamp(issue.LastDetectedAtUtc)</span>
                                        @if (issue.ResolvedAtUtc.HasValue)
                                        {
                                            <span class="card-note" style="display:block; margin:0; text-align:right; white-space:nowrap; font-size:0.72rem;">Resolved: @FormatIssueTimestamp(issue.ResolvedAtUtc.Value)</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </section>
}

<style>
    .movie-detail-top-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(20rem, 36rem);
        gap: 1rem;
        align-items: start;
    }

    .movie-detail-source-panel {
        width: 100%;
        justify-self: start;
    }

    .movie-issues-toggle {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        background: transparent;
        border: none;
        color: inherit;
        padding: 0;
        text-align: left;
        cursor: pointer;
    }

    .movie-issues-chevron {
        font-size: 1.05rem;
        color: #cbd5e1;
    }

    .movie-compatibility-table-wrap {
        overflow-x: auto;
        border: 1px solid rgba(51,65,85,0.8);
        border-radius: 0.8rem;
        background: rgba(15,23,42,0.42);
    }

    .movie-compatibility-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 34rem;
    }

    .movie-compatibility-table th,
    .movie-compatibility-table td {
        padding: 0.58rem 0.72rem;
        border-bottom: 1px solid rgba(51,65,85,0.7);
        text-align: left;
        vertical-align: top;
    }

    .movie-compatibility-table thead th {
        font-size: 0.7rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: #94a3b8;
        font-weight: 700;
        background: rgba(15,23,42,0.7);
        white-space: nowrap;
    }

    .movie-compatibility-table tbody th {
        color: #f8fafc;
        font-weight: 700;
        width: 20%;
    }

    .movie-compatibility-table tbody td {
        color: #e2e8f0;
    }

    .movie-compatibility-table tbody tr:last-child th,
    .movie-compatibility-table tbody tr:last-child td {
        border-bottom: none;
    }

    .movie-compatibility-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        padding: 0.18rem 0.56rem;
        border-radius: 999px;
        font-size: 0.72rem;
        line-height: 1;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .movie-compatibility-status--match {
        background: rgba(16, 185, 129, 0.14);
        color: #86efac;
        border-color: rgba(16, 185, 129, 0.35);
    }

    .movie-compatibility-status--allowed {
        background: rgba(59, 130, 246, 0.14);
        color: #93c5fd;
        border-color: rgba(59, 130, 246, 0.35);
    }

    .movie-compatibility-status--outside {
        background: rgba(245, 158, 11, 0.14);
        color: #fcd34d;
        border-color: rgba(245, 158, 11, 0.35);
    }

    .movie-compatibility-status--disc-image {
        background: rgba(168, 85, 247, 0.14);
        color: #d8b4fe;
        border-color: rgba(168, 85, 247, 0.35);
    }

    .movie-compatibility-status--unknown {
        background: rgba(148, 163, 184, 0.14);
        color: #cbd5e1;
        border-color: rgba(148, 163, 184, 0.3);
    }

    @@media (max-width: 920px) {
        .movie-detail-top-grid {
            grid-template-columns: 1fr;
        }

        .movie-detail-source-panel {
            width: 100%;
        }

        .movie-compatibility-table {
            min-width: 0;
        }
    }
</style>

@code {
    [Parameter] public long Id { get; set; }

    private bool _loading = true;
    private bool _probingRuntime;
    private bool _issuesExpanded;
    private bool _issuesLoading;
    private bool _savingIssue;
    private bool _compatibilityLoading;
    private bool _compatibilityExpanded;
    private string _statusMessage = string.Empty;
    private string _sourcePanelStatusMessage = string.Empty;
    private string _issuesStatusMessage = string.Empty;
    private string _compatibilityStatusMessage = string.Empty;
    private MediaItemDetailDto? _item;
    private MediaCompatibilityRecommendationResponse? _compatibilityRecommendation;
    private readonly List<LibraryIssueDto> _issues = [];
    private readonly List<LibraryItemSourceStatusDto> _sourceStatuses = [];
    private readonly List<LibraryItemSourceLinkDto> _sourceLinks = [];
    private readonly HashSet<string> _syncingServices = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<long> _resolvingIssueIds = [];
    private readonly Dictionary<string, DateTimeOffset?> _sourceSyncRanAtByService = new(StringComparer.OrdinalIgnoreCase);
    private IssueFormModel _issueForm = new();

    private static readonly IReadOnlyList<IssueTypeOption> IssueTypeOptions =
    [
        new("manual_issue", "General file issue"),
        new("playback_stall", "Playback stalls / buffers"),
        new("resume_starts_over", "Resume starts over"),
        new("seeking_issue", "Seeking / scrubbing issue"),
        new("subtitle_unusable", "Subtitle issue"),
        new("audio_wrong_during_playback", "Audio issue"),
        new("device_specific_issue", "Device-specific issue")
    ];

    private int OpenIssueCount => _issues.Count(x => string.Equals(x.Status, "Open", StringComparison.OrdinalIgnoreCase));
    private int ResolvedIssueCount => _issues.Count(x => string.Equals(x.Status, "Resolved", StringComparison.OrdinalIgnoreCase));

    protected override Task OnParametersSetAsync()
        => LoadItemAsync();

    private async Task LoadItemAsync(bool clearStatusMessage = true)
    {
        _loading = true;
        if (clearStatusMessage)
        {
            _statusMessage = string.Empty;
            _sourcePanelStatusMessage = string.Empty;
        }

        _item = null;
        _sourceStatuses.Clear();
        _sourceLinks.Clear();

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            _item = await response.Content.ReadFromJsonAsync<MediaItemDetailDto>();
            if (_item is null)
            {
                return;
            }

            await LoadSourcePanelAsync();
            await LoadIssuesAsync();
            await LoadCompatibilityRecommendationAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadSourcePanelAsync()
    {
        using var statusRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/source-status");
        using var statusResponse = await Http.SendAsync(statusRequest);
        if (statusResponse.IsSuccessStatusCode)
        {
            var statuses = await statusResponse.Content.ReadFromJsonAsync<List<LibraryItemSourceStatusDto>>() ?? [];
            _sourceStatuses.Clear();
            _sourceStatuses.AddRange(statuses.OrderBy(x => x.DisplayName));
        }

        using var linksRequest = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/sources");
        using var linksResponse = await Http.SendAsync(linksRequest);
        if (linksResponse.IsSuccessStatusCode)
        {
            var links = await linksResponse.Content.ReadFromJsonAsync<List<LibraryItemSourceLinkDto>>() ?? [];
            _sourceLinks.Clear();
            _sourceLinks.AddRange(links.OrderBy(x => x.ServiceKey).ThenBy(x => x.InstanceName));
        }
    }

    private async Task LoadIssuesAsync()
    {
        _issuesLoading = true;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/issues?take=100");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _issuesStatusMessage = $"Failed to load issue history (HTTP {(int)response.StatusCode}).";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<List<LibraryIssueDto>>() ?? [];
            _issues.Clear();
            _issues.AddRange(payload.OrderByDescending(x => x.LastDetectedAtUtc).ThenByDescending(x => x.Id));
        }
        catch
        {
            _issuesStatusMessage = "Failed to load issue history.";
        }
        finally
        {
            _issuesLoading = false;
        }
    }

    private async Task LoadCompatibilityRecommendationAsync()
    {
        _compatibilityLoading = true;
        _compatibilityStatusMessage = string.Empty;
        _compatibilityRecommendation = null;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Get, $"/api/library/items/{Id}/media-compatibility-recommendation");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _compatibilityStatusMessage = $"Failed to load preset comparison (HTTP {(int)response.StatusCode}).";
                return;
            }

            _compatibilityRecommendation = await response.Content.ReadFromJsonAsync<MediaCompatibilityRecommendationResponse>();
        }
        catch
        {
            _compatibilityStatusMessage = "Failed to load preset comparison.";
        }
        finally
        {
            _compatibilityLoading = false;
        }
    }

    private async Task ProbeRuntimeNowAsync()
    {
        if (_item is null)
        {
            return;
        }

        _probingRuntime = true;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/reprobe-runtime");
            using var response = await Http.SendAsync(request);
            var payload = await response.Content.ReadFromJsonAsync<LibraryItemRuntimeProbeResponse>();
            _statusMessage = response.IsSuccessStatusCode
                ? (string.IsNullOrWhiteSpace(payload?.Message) ? "Runtime analysis completed." : payload.Message)
                : $"Runtime analysis failed (HTTP {(int)response.StatusCode}).";

            if (response.IsSuccessStatusCode)
            {
                await LoadItemAsync(clearStatusMessage: false);
            }
        }
        catch
        {
            _statusMessage = "Runtime analysis failed.";
        }
        finally
        {
            _probingRuntime = false;
        }
    }

    private void ToggleIssuesPanel()
        => _issuesExpanded = !_issuesExpanded;

    private async Task CreateIssueAsync()
    {
        if (_item is null)
        {
            return;
        }

        _savingIssue = true;
        _issuesStatusMessage = string.Empty;
        try
        {
            var summary = string.IsNullOrWhiteSpace(_issueForm.Summary)
                ? $"{GetIssueTypeLabel(_issueForm.IssueType)} reported for {_item.DisplayTitle}."
                : _issueForm.Summary.Trim();

            var requestBody = new CreateLibraryIssueRequest(
                _issueForm.IssueType,
                string.Empty,
                summary,
                string.Empty,
                string.Empty,
                _issueForm.Status,
                string.Empty,
                string.Empty,
                string.Empty,
                "manual");

            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/issues");
            request.Content = JsonContent.Create(requestBody);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _issuesStatusMessage = $"Failed to save issue (HTTP {(int)response.StatusCode}).";
                Snackbar.Add(_issuesStatusMessage, Severity.Error);
                return;
            }

            _issuesStatusMessage = "Issue saved.";
            Snackbar.Add(_issuesStatusMessage, Severity.Success);
            _issueForm = new();
            await LoadIssuesAsync();
        }
        catch
        {
            _issuesStatusMessage = "Failed to save issue.";
            Snackbar.Add(_issuesStatusMessage, Severity.Error);
        }
        finally
        {
            _savingIssue = false;
        }
    }

    private async Task ResolveIssueAsync(LibraryIssueDto issue)
    {
        _resolvingIssueIds.Add(issue.Id);
        _issuesStatusMessage = string.Empty;
        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/issues/{issue.Id}/resolve");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _issuesStatusMessage = $"Failed to resolve issue (HTTP {(int)response.StatusCode}).";
                Snackbar.Add(_issuesStatusMessage, Severity.Error);
                return;
            }

            _issuesStatusMessage = "Issue resolved.";
            Snackbar.Add(_issuesStatusMessage, Severity.Success);
            await LoadIssuesAsync();
        }
        catch
        {
            _issuesStatusMessage = "Failed to resolve issue.";
            Snackbar.Add(_issuesStatusMessage, Severity.Error);
        }
        finally
        {
            _resolvingIssueIds.Remove(issue.Id);
        }
    }

    private async Task SyncSourceAsync(LibraryItemSourceStatusDto source)
    {
        if (_item is null || !source.CanSync || string.IsNullOrWhiteSpace(source.ServiceKey))
        {
            return;
        }

        _syncingServices.Add(source.ServiceKey);
        _sourcePanelStatusMessage = $"Syncing {_item.DisplayTitle} from {source.DisplayName}...";

        try
        {
            using var request = await RequestFactory.CreateAsync(HttpMethod.Post, $"/api/library/items/{_item.Id}/sources/{source.ServiceKey}/sync");
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _sourcePanelStatusMessage = $"{source.DisplayName} sync failed (HTTP {(int)response.StatusCode}).";
                Snackbar.Add(_sourcePanelStatusMessage, Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LibraryItemSourceSyncResponse>();
            _sourceSyncRanAtByService[source.ServiceKey] = payload?.SyncedAtUtc;
            _sourcePanelStatusMessage = payload?.Message ?? $"{source.DisplayName} sync finished.";
            Snackbar.Add(_sourcePanelStatusMessage, payload?.Success == true ? Severity.Success : Severity.Warning);
            await LoadItemAsync(clearStatusMessage: false);
        }
        catch
        {
            _sourcePanelStatusMessage = $"{source.DisplayName} sync failed.";
            Snackbar.Add(_sourcePanelStatusMessage, Severity.Error);
        }
        finally
        {
            _syncingServices.Remove(source.ServiceKey);
        }
    }

    private List<LibraryItemSourceLinkDto> GetSourceLinks(LibraryItemSourceStatusDto source)
        => _sourceLinks
            .Where(x => string.Equals(x.ServiceKey, source.ServiceKey, StringComparison.OrdinalIgnoreCase)
                && (source.IntegrationId is null || x.IntegrationId == source.IntegrationId.Value))
            .ToList();

    private static string BuildMatchedItemLabel(LibraryItemSourceLinkDto source)
    {
        var title = string.IsNullOrWhiteSpace(source.SourceTitle) ? source.SourceSortTitle : source.SourceTitle;
        return string.IsNullOrWhiteSpace(title) ? "Unknown" : title;
    }

    private static string BuildMatchedItemSummary(LibraryItemSourceLinkDto source)
    {
        var title = BuildMatchedItemLabel(source);
        var externalId = BuildExternalIdValue(source);
        return externalId == "—"
            ? title
            : $"{title} ({externalId})";
    }

    private static string BuildPrimaryMatchedItemSummary(List<LibraryItemSourceLinkDto> sourceLinks, string? serviceKey)
        => sourceLinks.Count > 0
            ? BuildMatchedItemSummary(sourceLinks[0])
            : $"Unknown ({BuildExternalIdLabel(serviceKey)}: —)";

    private static string BuildServiceHeader(LibraryItemSourceStatusDto source)
    {
        var displayName = source.DisplayName?.Trim() ?? string.Empty;
        var instanceName = source.InstanceName?.Trim() ?? string.Empty;
        return string.IsNullOrWhiteSpace(instanceName) || string.Equals(displayName, instanceName, StringComparison.OrdinalIgnoreCase)
            ? displayName
            : $"{displayName} ({instanceName})";
    }

    private static string BuildExternalIdLabel(string? serviceKey)
        => (serviceKey ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "plex" => "Plex ID",
            "radarr" => "Radarr ID",
            "overseerr" => "Request ID",
            _ => "External ID"
        };

    private static string BuildExternalIdValue(LibraryItemSourceLinkDto source)
        => string.IsNullOrWhiteSpace(source.ExternalId) ? "—" : source.ExternalId;

    private static string BuildSourceBadgeLabel(LibraryItemSourceStatusDto source)
    {
        if (!source.HasSourceLink)
        {
            return "Missing link";
        }

        return HasSourceMismatch(source)
            ? "Mismatch"
            : "Matched";
    }

    private static bool HasSourceMismatch(LibraryItemSourceStatusDto source)
        => source.HasSourceLink
            && (string.Equals(source.ServiceKey, "radarr", StringComparison.OrdinalIgnoreCase)
                || string.Equals(source.ServiceKey, "overseerr", StringComparison.OrdinalIgnoreCase))
            && source.MonitoringSynced == false;

    private static string GetSourceLinkBadgeStyle(LibraryItemSourceStatusDto source)
    {
        const string baseStyle = "display:inline-flex; align-items:center; justify-content:center; white-space:nowrap; flex:0 0 auto; padding:0.16rem 0.56rem; border-radius:999px; font-size:0.7rem; line-height:1; font-weight:700; letter-spacing:0.03em; text-transform:uppercase;";
        if (!source.HasSourceLink)
        {
            return baseStyle + "background:rgba(245,158,11,0.16); color:#fde68a; border:1px solid rgba(245,158,11,0.42);";
        }

        return HasSourceMismatch(source)
            ? baseStyle + "background:rgba(239,68,68,0.18); color:#fecaca; border:1px solid rgba(239,68,68,0.48);"
            : baseStyle + "background:rgba(34,197,94,0.18); color:#bbf7d0; border:1px solid rgba(34,197,94,0.45);";
    }

    private static string GetCompatibilityStatusClass(string? status)
        => (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "match" => "movie-compatibility-status--match",
            "allowed" => "movie-compatibility-status--allowed",
            "outside profile" => "movie-compatibility-status--outside",
            "disc image" => "movie-compatibility-status--disc-image",
            _ => "movie-compatibility-status--unknown"
