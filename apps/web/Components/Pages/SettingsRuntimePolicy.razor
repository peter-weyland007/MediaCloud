@page "/settings/runtime-policy"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar

<PageTitle>Runtime Policy</PageTitle>

<p class="subtitle"><a href="/settings">Settings</a> / Runtime Policy</p>
<h1>Runtime Policy</h1>
<p class="subtitle">Set tolerance and severity thresholds for reported vs actual runtime differences.</p>

<div class="card" style="max-width:900px;">
    @if (_loading)
    {
        <p class="card-note">Loading runtime policy…</p>
    }
    else
    {
        <div class="form-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:0.8rem;">
            <div class="form-group">
                <label>Tolerance floor (minutes)</label>
                <InputNumber class="input" @bind-Value="_model.ToleranceMinutesFloor" />
                <p class="card-note" style="margin-top:0.35rem;">Minimum absolute difference allowed before mismatch.</p>
            </div>

            <div class="form-group">
                <label>Tolerance percent (%)</label>
                <InputNumber class="input" @bind-Value="_model.TolerancePercent" />
                <p class="card-note" style="margin-top:0.35rem;">Percent of reported runtime used as relative tolerance.</p>
            </div>

            <div class="form-group">
                <label>Warning percent (%)</label>
                <InputNumber class="input" @bind-Value="_model.WarningPercent" />
            </div>

            <div class="form-group">
                <label>High minutes (minutes)</label>
                <InputNumber class="input" @bind-Value="_model.HighMinutes" />
            </div>

            <div class="form-group">
                <label>Critical percent (%)</label>
                <InputNumber class="input" @bind-Value="_model.CriticalPercent" />
            </div>

            <div class="form-group">
                <label>Critical minutes (minutes)</label>
                <InputNumber class="input" @bind-Value="_model.CriticalMinutes" />
            </div>
        </div>

        <div style="display:flex; gap:0.55rem; margin-top:0.85rem; flex-wrap:wrap;">
            <button class="button-primary" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Saving..." : "Save runtime policy")</button>
            <button class="button-secondary" @onclick="ResetDefaultsAsync" disabled="@_resetting">@(_resetting ? "Resetting..." : "Reset to defaults")</button>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _resetting;
    private RuntimePolicySettingsModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/runtime-policy");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _model = RuntimePolicySettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load runtime policy.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/runtime-policy")
            {
                Content = JsonContent.Create(new UpdateRuntimePolicySettingsRequest(
                    _model.ToleranceMinutesFloor,
                    _model.TolerancePercent,
                    _model.WarningPercent,
                    _model.HighMinutes,
                    _model.CriticalPercent,
                    _model.CriticalMinutes))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null) _model = RuntimePolicySettingsModel.FromResponse(payload);
            Snackbar.Add("Runtime policy saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save runtime policy.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ResetDefaultsAsync()
    {
        _resetting = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/settings/runtime-policy/reset");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to reset runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null) _model = RuntimePolicySettingsModel.FromResponse(payload);
            Snackbar.Add("Runtime policy reset to defaults.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to reset runtime policy.", Severity.Error);
        }
        finally
        {
            _resetting = false;
        }
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private sealed class RuntimePolicySettingsModel
    {
        public double ToleranceMinutesFloor { get; set; } = 3;
        public double TolerancePercent { get; set; } = 5;
        public double WarningPercent { get; set; } = 10;
        public double HighMinutes { get; set; } = 12;
        public double CriticalPercent { get; set; } = 20;
        public double CriticalMinutes { get; set; } = 25;

        public static RuntimePolicySettingsModel FromResponse(RuntimePolicySettingsResponse value) => new()
        {
            ToleranceMinutesFloor = value.ToleranceMinutesFloor,
            TolerancePercent = value.TolerancePercent,
            WarningPercent = value.WarningPercent,
            HighMinutes = value.HighMinutes,
            CriticalPercent = value.CriticalPercent,
            CriticalMinutes = value.CriticalMinutes
        };
    }

    private record UpdateRuntimePolicySettingsRequest(
        double ToleranceMinutesFloor,
        double TolerancePercent,
        double WarningPercent,
        double HighMinutes,
        double CriticalPercent,
        double CriticalMinutes);

    private record RuntimePolicySettingsResponse(
        double ToleranceMinutesFloor,
        double TolerancePercent,
        double WarningPercent,
        double HighMinutes,
        double CriticalPercent,
        double CriticalMinutes);

    private record ErrorResponse(string Error);
}
