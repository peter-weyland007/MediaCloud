    private sealed class MediaProfileSettingsModel
    {
        public string PreferredContainer { get; set; } = "mp4";
        public string PreferredVideoCodec { get; set; } = "h264";
        public string MaxPreferredResolution { get; set; } = "1080p";
        public bool AllowHevc { get; set; }
        public bool Allow10BitVideo { get; set; }
        public string PreferredAudioCodec { get; set; } = "aac";
        public bool AllowImageBasedSubtitles { get; set; }
        public bool PreferTextSubtitlesOnly { get; set; } = true;
        public int MaxPreferredBitrateMbps { get; set; } = 20;
        public string ActivePresetKey { get; set; } = string.Empty;
        public string ActivePresetName { get; set; } = string.Empty;

        public static MediaProfileSettingsModel FromResponse(MediaProfileSettingsResponse value) => new()
        {
            PreferredContainer = value.PreferredContainer,
            PreferredVideoCodec = value.PreferredVideoCodec,
            MaxPreferredResolution = value.MaxPreferredResolution,
            AllowHevc = value.AllowHevc,
            Allow10BitVideo = value.Allow10BitVideo,
            PreferredAudioCodec = value.PreferredAudioCodec,
            AllowImageBasedSubtitles = value.AllowImageBasedSubtitles,
            PreferTextSubtitlesOnly = value.PreferTextSubtitlesOnly,
            MaxPreferredBitrateMbps = value.MaxPreferredBitrateMbps,
            ActivePresetKey = value.ActivePresetKey,
            ActivePresetName = value.ActivePresetName
        };

        public static MediaProfileSettingsModel BroadPlexCompatibility() => new()
        {
            PreferredContainer = "mp4",
            PreferredVideoCodec = "h264",
            MaxPreferredResolution = "1080p",
            AllowHevc = false,
            Allow10BitVideo = false,
            PreferredAudioCodec = "aac",
            AllowImageBasedSubtitles = false,
            PreferTextSubtitlesOnly = true,
            MaxPreferredBitrateMbps = 20,
            ActivePresetKey = "broad-plex-compatibility",
            ActivePresetName = "Stable / Broad Compatibility"
        };

        public static MediaProfileSettingsModel ModernQualityEfficiency() => new()
        {
            PreferredContainer = "mkv",
            PreferredVideoCodec = "hevc",
            MaxPreferredResolution = "4k",
            AllowHevc = true,
            Allow10BitVideo = true,
            PreferredAudioCodec = "eac3",
            AllowImageBasedSubtitles = true,
            PreferTextSubtitlesOnly = false,
            MaxPreferredBitrateMbps = 40,
            ActivePresetKey = "modern-quality-efficiency",
            ActivePresetName = "Modern / Quality Efficiency"
        };

        public MediaProfileSettingsModel Clone() => new()
        {
            PreferredContainer = PreferredContainer,
            PreferredVideoCodec = PreferredVideoCodec,
            MaxPreferredResolution = MaxPreferredResolution,
            AllowHevc = AllowHevc,
            Allow10BitVideo = Allow10BitVideo,
            PreferredAudioCodec = PreferredAudioCodec,
            AllowImageBasedSubtitles = AllowImageBasedSubtitles,
            PreferTextSubtitlesOnly = PreferTextSubtitlesOnly,
            MaxPreferredBitrateMbps = MaxPreferredBitrateMbps,
            ActivePresetKey = ActivePresetKey,
            ActivePresetName = ActivePresetName
        };

        public bool Matches(MediaProfileSettingsModel other)
            => string.Equals(PreferredContainer, other.PreferredContainer, StringComparison.OrdinalIgnoreCase)
                && string.Equals(PreferredVideoCodec, other.PreferredVideoCodec, StringComparison.OrdinalIgnoreCase)
                && string.Equals(MaxPreferredResolution, other.MaxPreferredResolution, StringComparison.OrdinalIgnoreCase)
                && AllowHevc == other.AllowHevc
                && Allow10BitVideo == other.Allow10BitVideo
                && string.Equals(PreferredAudioCodec, other.PreferredAudioCodec, StringComparison.OrdinalIgnoreCase)
                && AllowImageBasedSubtitles == other.AllowImageBasedSubtitles
                && PreferTextSubtitlesOnly == other.PreferTextSubtitlesOnly
                && MaxPreferredBitrateMbps == other.MaxPreferredBitrateMbps;

        public string BuildSummary()
            => $"{PreferredContainer.ToUpperInvariant()} · {PreferredVideoCodec.ToUpperInvariant()} preferred · {PreferredAudioCodec.ToUpperInvariant()} audio · max {MaxPreferredResolution.ToUpperInvariant()} · HEVC {(AllowHevc ? "allowed" : "off")} · 10-bit {(Allow10BitVideo ? "allowed" : "off")} · {(PreferTextSubtitlesOnly ? "text subtitles preferred" : AllowImageBasedSubtitles ? "image subtitles allowed" : "image subtitles discouraged")}";
    }

