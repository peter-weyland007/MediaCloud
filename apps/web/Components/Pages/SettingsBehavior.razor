@page "/settings/app-behavior"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar

<PageTitle>App Behavior Settings</PageTitle>

<h1>App Behavior</h1>
<p class="subtitle">Global runtime policy, integration pull behavior, monitoring & request sync, and TV display defaults.</p>

<div class="settings-stack">
    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">RUNTIME POLICY</p>
                <h2>Mismatch tolerances</h2>
                <p class="card-note">Set tolerance and severity thresholds for reported vs actual runtime differences.</p>
            </div>
            <a class="button-secondary settings-link-button" href="/settings/runtime-policy">Open standalone page</a>
        </div>

        @if (_loadingRuntimePolicy)
        {
            <p class="card-note">Loading runtime policy…</p>
        }
        else
        {
            <div class="settings-two-col-grid">
                <div class="form-group">
                    <label>Tolerance floor (minutes)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.ToleranceMinutesFloor" />
                    <p class="card-note settings-note-tight">Minimum absolute difference allowed before mismatch.</p>
                </div>

                <div class="form-group">
                    <label>Tolerance percent (%)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.TolerancePercent" />
                    <p class="card-note settings-note-tight">Percent of reported runtime used as relative tolerance.</p>
                </div>

                <div class="form-group">
                    <label>Warning percent (%)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.WarningPercent" />
                </div>

                <div class="form-group">
                    <label>High minutes (minutes)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.HighMinutes" />
                </div>

                <div class="form-group">
                    <label>Critical percent (%)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.CriticalPercent" />
                </div>

                <div class="form-group">
                    <label>Critical minutes (minutes)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.CriticalMinutes" />
                </div>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveRuntimePolicyAsync" disabled="@_savingRuntimePolicy">@(_savingRuntimePolicy ? "Saving..." : "Save runtime policy")</button>
                <button class="button-secondary" @onclick="ResetRuntimePolicyDefaultsAsync" disabled="@_resettingRuntimePolicy">@(_resettingRuntimePolicy ? "Resetting..." : "Reset to defaults")</button>
            </div>
        }
    </div>

    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">MONITORING & REQUEST SYNC</p>
                <h2>Global monitoring ownership + request sync</h2>
                <p class="card-note">Configure app-wide monitoring behavior: Radarr and Sonarr are the actual monitor-state targets, while Overseerr contributes request and availability intent signals.</p>
            </div>
            <a class="button-secondary settings-link-button" href="/settings/monitoring">Open standalone page</a>
        </div>

        @if (_loadingMonitoring)
        {
            <p class="card-note">Loading monitoring settings…</p>
        }
        else
        {
            <div class="settings-toggle-stack">
                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_monitoring.ManagedByMediaCloud" />
                    <span>
                        <strong>Monitor in MediaCloud</strong><br />
                        <span class="card-note">Use MediaCloud as the monitor-state source of truth for movie and series library items. When off, MediaCloud stops driving monitor-state changes into Radarr and Sonarr.</span>
                    </span>
                </label>

                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_monitoring.AutoSyncEnabled" disabled="@(!_monitoring.ManagedByMediaCloud)" />
                    <span>
                        <strong>Auto sync</strong><br />
                        <span class="card-note">When enabled, MediaCloud automatically pushes monitor-state changes to Radarr and Sonarr. Overseerr is still consulted for request and media-intent context, but it is not the primary monitor-state owner.</span>
                    </span>
                </label>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveMonitoringAsync" disabled="@_savingMonitoring">@(_savingMonitoring ? "Saving..." : "Save monitoring settings")</button>
            </div>
        }
    </div>

    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">INTEGRATION PULLS</p>
                <h2>Automatic vs manual integration refresh</h2>
                <p class="card-note">Choose whether MediaCloud should periodically pull fresh data from enabled integrations or wait for manual sync actions only.</p>
            </div>
        </div>

        @if (_loadingIntegrationPulls)
        {
            <p class="card-note">Loading integration pull settings…</p>
        }
        else
        {
            <div class="settings-toggle-stack">
                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_integrationPulls.AutoPullEnabled" />
                    <span>
                        <strong>Automatically pull data from integrations</strong><br />
                        <span class="card-note">When enabled, MediaCloud periodically syncs enabled integrations in the background. When disabled, integration data only changes when an admin manually runs sync actions.</span>
                    </span>
                </label>

                <div class="form-group">
                    <label>Automatic pull interval (minutes)</label>
                    <InputNumber class="input" @bind-Value="_integrationPulls.IntervalMinutes" disabled="@(!_integrationPulls.AutoPullEnabled)" />
                    <p class="card-note settings-note-tight">Valid range: 5 to 1440 minutes. Current mode: @(_integrationPulls.AutoPullEnabled ? "Automatic background pulls" : "Manual-only pulls")</p>
                    <p class="card-note settings-note-micro">Last automatic pull: @FormatBehaviorDate(_integrationPulls.LastAutoPullAtUtc)</p>
                </div>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveIntegrationPullsAsync" disabled="@_savingIntegrationPulls">@(_savingIntegrationPulls ? "Saving..." : "Save integration pull settings")</button>
            </div>
        }
    </div>

    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">PREFERRED MEDIA PROFILE</p>
                <h2>Compatibility target for playback remediation</h2>
                <p class="card-note">Define the house-standard container, codec, subtitle, and bitrate target MediaCloud should use when judging whether a movie needs a compatibility-focused ffmpeg pass.</p>
            </div>
        </div>

        @if (_loadingMediaProfile)
        {
            <p class="card-note">Loading media profile settings…</p>
        }
        else
        {
            <div class="settings-two-col-grid">
                <div class="form-group">
                    <label>Preset</label>
                    <InputSelect class="input" @bind-Value="_selectedMediaProfilePreset">
                        @foreach (var preset in _mediaProfilePresetOptions)
                        {
                            <option value="@preset.Key">@preset.Label</option>
                        }
                    </InputSelect>
                    <p class="card-note settings-note-tight">Use one of the built-in compatibility targets or switch to one of your saved named presets.</p>
                </div>

                <div class="form-group settings-align-end">
                    <button class="button-secondary" @onclick="ApplySelectedMediaProfilePreset" type="button">Apply preset</button>
                </div>

                <div class="form-group">
                    <label>Preferred container</label>
                    <InputSelect class="input" @bind-Value="_mediaProfile.PreferredContainer">
                        <option value="mp4">MP4</option>
                        <option value="mkv">MKV</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Preferred video codec</label>
                    <InputSelect class="input" @bind-Value="_mediaProfile.PreferredVideoCodec">
                        <option value="h264">H.264</option>
                        <option value="hevc">HEVC</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Max preferred resolution</label>
                    <InputSelect class="input" @bind-Value="_mediaProfile.MaxPreferredResolution">
                        <option value="1080p">1080p</option>
                        <option value="4k">4K</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Preferred audio codec</label>
                    <InputSelect class="input" @bind-Value="_mediaProfile.PreferredAudioCodec">
                        <option value="aac">AAC</option>
                        <option value="ac3">AC3</option>
                        <option value="eac3">EAC3</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Maximum preferred bitrate (Mbps)</label>
                    <InputNumber class="input" @bind-Value="_mediaProfile.MaxPreferredBitrateMbps" />
                </div>
            </div>

            <div class="settings-toggle-stack settings-section-gap-top">
                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_mediaProfile.AllowHevc" />
                    <span>
                        <strong>Allow HEVC</strong><br />
                        <span class="card-note">When off, MediaCloud treats HEVC/H.265 as a manual-review target instead of a safe compatibility remux candidate.</span>
                    </span>
                </label>

                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_mediaProfile.Allow10BitVideo" />
                    <span>
                        <strong>Allow 10-bit video</strong><br />
                        <span class="card-note">When off, 10-bit sources are treated as manual-review items because they usually require a full video transcode.</span>
                    </span>
                </label>

                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_mediaProfile.AllowImageBasedSubtitles" />
                    <span>
                        <strong>Allow image-based subtitles</strong><br />
                        <span class="card-note">Controls whether PGS/VobSub-style subtitles are acceptable in the preferred profile.</span>
                    </span>
                </label>

                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_mediaProfile.PreferTextSubtitlesOnly" />
                    <span>
                        <strong>Prefer text subtitles only</strong><br />
                        <span class="card-note">When enabled, MediaCloud avoids auto-queueing safe ffmpeg previews for files that still depend on image-based subtitle tracks.</span>
                    </span>
                </label>
            </div>

            <p class="card-note settings-summary-note">Current target: @_mediaProfile.BuildSummary()</p>

            <div class="settings-two-col-grid settings-summary-note">
                <div class="form-group">
                    <label>Save as named preset</label>
                    <InputText class="input" @bind-Value="_newMediaProfilePresetName" placeholder="Living Room 4K" />
                    <p class="card-note settings-note-tight">Store the current settings under a reusable custom preset name.</p>
                </div>

                <div class="form-group settings-align-end">
                    <button class="button-secondary" type="button" @onclick="SaveMediaProfilePresetAsync" disabled="@_savingMediaProfilePreset">@(_savingMediaProfilePreset ? "Saving preset..." : "Save as named preset")</button>
                </div>
            </div>

            <div class="settings-presets-stack">
                <p class="card-label settings-zero-margin">Saved presets</p>
                <p class="card-note settings-zero-margin">Each saved custom preset has actions on the right: <strong>Rename</strong> or <strong>Delete</strong>.</p>
                @foreach (var preset in _mediaProfilePresetOptions.Where(x => !x.IsBuiltIn && x.Key != "custom-unsaved"))
                {
                    <div class="settings-preset-card">
                        <div class="settings-preset-header">
                            <div>
                                <strong>@preset.Name</strong>
                                <div class="card-note">Custom preset actions</div>
                            </div>
                            <div class="settings-button-row-tight">
                                <button class="button-secondary" type="button" @onclick="() => RenameMediaProfilePresetAsync(preset.Key)">Rename</button>
                                <button class="button-secondary" type="button" @onclick="() => DeleteMediaProfilePresetAsync(preset.Key)">Delete</button>
                            </div>
                        </div>
                        <div class="form-group settings-zero-margin">
                            <label>Preset name</label>
                            <InputText class="input" Value="@preset.Name" ValueChanged="@(value => UpdatePresetDraftName(preset.Key, value))" />
                        </div>
                    </div>
                }
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveMediaProfileAsync" disabled="@_savingMediaProfile">@(_savingMediaProfile ? "Saving..." : "Save media profile")</button>
            </div>
        }
    </div>

    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">TV DISPLAY</p>
                <h2>Series season display defaults</h2>
                <p class="card-note">Configure global TV-series detail defaults like hiding Specials by default.</p>
            </div>
            <a class="button-secondary settings-link-button" href="/settings/tv-display">Open standalone page</a>
        </div>

        @if (_loadingTvDisplay)
        {
            <p class="card-note">Loading TV display settings…</p>
        }
        else
        {
            <div class="settings-toggle-stack">
                <label class="settings-toggle-row">
                    <input type="checkbox" @bind="_tvDisplay.HideSpecialsByDefault" />
                    <span>
                        <strong>Hide Specials by default</strong><br />
                        <span class="card-note">When enabled, series detail pages hide season 0 / Specials unless the viewer turns them back on for that page.</span>
                    </span>
                </label>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveTvDisplayAsync" disabled="@_savingTvDisplay">@(_savingTvDisplay ? "Saving..." : "Save TV display settings")</button>
            </div>
        }
    </div>
</div>

<style>
    .settings-stack {
        display: grid;
        gap: 1rem;
    }

    .settings-two-col-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
    }

    .settings-section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.85rem;
        flex-wrap: wrap;
    }

    .settings-actions {
        display: flex;
        gap: 0.55rem;
        margin-top: 0.95rem;
        flex-wrap: wrap;
    }

    .settings-link-button {
        display: inline-block;
        text-decoration: none;
    }

    .settings-toggle-stack {
        display: grid;
        gap: 0.9rem;
    }

    .settings-toggle-row {
        display: flex;
        gap: 0.6rem;
        align-items: flex-start;
    }

    .settings-note-tight {
        margin-top: 0.35rem;
    }

    .settings-note-micro {
        margin-top: 0.2rem;
    }

    .settings-align-end {
        display: flex;
        align-items: end;
    }

    .settings-section-gap-top,
    .settings-summary-note,
    .settings-presets-stack {
        margin-top: 0.85rem;
    }

    .settings-presets-stack {
        display: grid;
        gap: 0.75rem;
    }

    .settings-zero-margin {
        margin: 0;
    }

    .settings-preset-card {
        border: 1px solid rgba(51,65,85,0.85);
        border-radius: 0.8rem;
        padding: 0.9rem;
        background: rgba(15,23,42,0.5);
        display: grid;
        gap: 0.6rem;
    }

    .settings-preset-header {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .settings-button-row-tight {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 1100px) {
        .settings-two-col-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool _loadingRuntimePolicy = true;
    private bool _savingRuntimePolicy;
    private bool _resettingRuntimePolicy;
    private bool _loadingMonitoring = true;
    private bool _savingMonitoring;
    private bool _loadingIntegrationPulls = true;
    private bool _savingIntegrationPulls;
    private bool _loadingTvDisplay = true;
    private bool _savingTvDisplay;
    private bool _loadingMediaProfile = true;
    private bool _savingMediaProfile;
    private bool _savingMediaProfilePreset;

    private RuntimePolicySettingsModel _runtimePolicy = new();
    private MonitoringSettingsModel _monitoring = new();
    private IntegrationPullSettingsModel _integrationPulls = new();
    private TvDisplaySettingsModel _tvDisplay = new();
    private MediaProfileSettingsModel _mediaProfile = new();
    private string _selectedMediaProfilePreset = "custom-unsaved";
    private string _newMediaProfilePresetName = string.Empty;
    private Dictionary<string, string> _mediaProfilePresetDraftNames = new(StringComparer.OrdinalIgnoreCase);
    private List<MediaProfilePresetOption> _mediaProfilePresetOptions = BuildDefaultMediaProfilePresetOptions();

    protected override async Task OnInitializedAsync()
    {
        await LoadRuntimePolicyAsync();
        await LoadMonitoringAsync();
        await LoadIntegrationPullsAsync();
        await LoadMediaProfileAsync();
        await LoadTvDisplayAsync();
    }

    private async Task LoadRuntimePolicyAsync()
    {
        _loadingRuntimePolicy = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/runtime-policy");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _runtimePolicy = RuntimePolicySettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load runtime policy.", Severity.Error);
        }
        finally
        {
            _loadingRuntimePolicy = false;
        }
    }

    private async Task SaveRuntimePolicyAsync()
    {
        _savingRuntimePolicy = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/runtime-policy")
            {
                Content = JsonContent.Create(new UpdateRuntimePolicySettingsRequest(
                    _runtimePolicy.ToleranceMinutesFloor,
                    _runtimePolicy.TolerancePercent,
                    _runtimePolicy.WarningPercent,
                    _runtimePolicy.HighMinutes,
                    _runtimePolicy.CriticalPercent,
                    _runtimePolicy.CriticalMinutes))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _runtimePolicy = RuntimePolicySettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Runtime policy saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save runtime policy.", Severity.Error);
        }
        finally
        {
            _savingRuntimePolicy = false;
        }
    }

    private async Task ResetRuntimePolicyDefaultsAsync()
    {
        _resettingRuntimePolicy = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/settings/runtime-policy/reset");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to reset runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _runtimePolicy = RuntimePolicySettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Runtime policy reset to defaults.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to reset runtime policy.", Severity.Error);
        }
        finally
        {
            _resettingRuntimePolicy = false;
        }
    }

    private async Task LoadMonitoringAsync()
    {
        _loadingMonitoring = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/monitoring");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load monitoring settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MonitoringSettingsResponse>();
            if (payload is not null)
            {
                _monitoring = MonitoringSettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load monitoring settings.", Severity.Error);
        }
        finally
        {
            _loadingMonitoring = false;
        }
    }

    private async Task SaveMonitoringAsync()
    {
        _savingMonitoring = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/monitoring")
            {
                Content = JsonContent.Create(new UpdateMonitoringSettingsRequest(_monitoring.ManagedByMediaCloud, _monitoring.AutoSyncEnabled))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save monitoring settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MonitoringSettingsResponse>();
            if (payload is not null)
            {
                _monitoring = MonitoringSettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Monitoring settings saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save monitoring settings.", Severity.Error);
        }
        finally
        {
            _savingMonitoring = false;
        }
    }

    private async Task LoadIntegrationPullsAsync()
    {
        _loadingIntegrationPulls = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/integration-pulls");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load integration pull settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<IntegrationPullSettingsResponse>();
            if (payload is not null)
            {
                _integrationPulls = IntegrationPullSettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load integration pull settings.", Severity.Error);
        }
        finally
        {
            _loadingIntegrationPulls = false;
        }
    }

    private async Task SaveIntegrationPullsAsync()
    {
        _savingIntegrationPulls = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/integration-pulls")
            {
                Content = JsonContent.Create(new UpdateIntegrationPullSettingsRequest(_integrationPulls.AutoPullEnabled, _integrationPulls.IntervalMinutes))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save integration pull settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<IntegrationPullSettingsResponse>();
            if (payload is not null)
            {
                _integrationPulls = IntegrationPullSettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Integration pull settings saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save integration pull settings.", Severity.Error);
        }
        finally
        {
            _savingIntegrationPulls = false;
        }
    }

    private async Task LoadMediaProfileAsync()
    {
        _loadingMediaProfile = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/media-profile");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load media profile settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MediaProfileSettingsResponse>();
            if (payload is not null)
            {
                _mediaProfile = MediaProfileSettingsModel.FromResponse(payload);
                await LoadMediaProfilePresetOptionsAsync();
                _selectedMediaProfilePreset = ResolveMediaProfilePreset(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load media profile settings.", Severity.Error);
        }
        finally
        {
            _loadingMediaProfile = false;
        }
    }

    private async Task LoadMediaProfilePresetOptionsAsync()
    {
        using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/media-profile/presets");
        await AttachBearerAsync(request);
        using var response = await Http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            _mediaProfilePresetOptions = BuildDefaultMediaProfilePresetOptions();
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<List<MediaProfilePresetDto>>() ?? [];
        var options = BuildDefaultMediaProfilePresetOptions();
        foreach (var preset in payload.Where(x => !x.IsBuiltIn))
        {
            options.Add(new MediaProfilePresetOption(preset.Key, preset.Name, preset.Name, preset.IsBuiltIn, MediaProfileSettingsModel.FromResponse(preset.Settings)));
        }

        _mediaProfilePresetOptions = options;
        _mediaProfilePresetDraftNames = options
            .Where(x => !x.IsBuiltIn && x.Key != "custom-unsaved")
            .ToDictionary(x => x.Key, x => x.Name, StringComparer.OrdinalIgnoreCase);
    }

    private async Task SaveMediaProfileAsync()
    {
        _savingMediaProfile = true;
        try
        {
            var selectedPreset = GetSelectedMediaProfilePreset();
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/media-profile")
            {
                Content = JsonContent.Create(new UpdateMediaProfileSettingsRequest(
                    _mediaProfile.PreferredContainer,
                    _mediaProfile.PreferredVideoCodec,
                    _mediaProfile.MaxPreferredResolution,
                    _mediaProfile.AllowHevc,
                    _mediaProfile.Allow10BitVideo,
                    _mediaProfile.PreferredAudioCodec,
                    _mediaProfile.AllowImageBasedSubtitles,
                    _mediaProfile.PreferTextSubtitlesOnly,
                    _mediaProfile.MaxPreferredBitrateMbps,
                    selectedPreset?.Key ?? string.Empty,
                    selectedPreset?.Name ?? string.Empty))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save media profile settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MediaProfileSettingsResponse>();
            if (payload is not null)
            {
                _mediaProfile = MediaProfileSettingsModel.FromResponse(payload);
                await LoadMediaProfilePresetOptionsAsync();
                _selectedMediaProfilePreset = ResolveMediaProfilePreset(payload);
            }

            Snackbar.Add("Media profile settings saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save media profile settings.", Severity.Error);
        }
        finally
        {
            _savingMediaProfile = false;
        }
    }

    private async Task SaveMediaProfilePresetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newMediaProfilePresetName))
        {
            Snackbar.Add("Enter a preset name first.", Severity.Warning);
            return;
        }

        if (_mediaProfilePresetOptions.Any(x => !x.IsBuiltIn && !string.Equals(x.Key, _selectedMediaProfilePreset, StringComparison.OrdinalIgnoreCase) && string.Equals(x.Name, _newMediaProfilePresetName.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add("A custom media profile preset with that name already exists.", Severity.Warning);
            return;
        }

        _savingMediaProfilePreset = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/settings/media-profile/presets")
            {
                Content = JsonContent.Create(new SaveMediaProfilePresetRequest(
                    _newMediaProfilePresetName.Trim(),
                    new UpdateMediaProfileSettingsRequest(
                        _mediaProfile.PreferredContainer,
                        _mediaProfile.PreferredVideoCodec,
                        _mediaProfile.MaxPreferredResolution,
                        _mediaProfile.AllowHevc,
                        _mediaProfile.Allow10BitVideo,
                        _mediaProfile.PreferredAudioCodec,
                        _mediaProfile.AllowImageBasedSubtitles,
                        _mediaProfile.PreferTextSubtitlesOnly,
                        _mediaProfile.MaxPreferredBitrateMbps,
                        string.Empty,
                        string.Empty)))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save media profile preset ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MediaProfilePresetDto>();
            await LoadMediaProfilePresetOptionsAsync();
            if (payload is not null)
            {
                _selectedMediaProfilePreset = payload.Key;
            }
            _newMediaProfilePresetName = string.Empty;
            Snackbar.Add("Media profile preset saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save media profile preset.", Severity.Error);
        }
        finally
        {
            _savingMediaProfilePreset = false;
        }
    }

    private async Task RenameMediaProfilePresetAsync(string presetKey)
    {
        if (!_mediaProfilePresetDraftNames.TryGetValue(presetKey, out var name) || string.IsNullOrWhiteSpace(name))
        {
            Snackbar.Add("Enter a preset name first.", Severity.Warning);
            return;
        }

        if (_mediaProfilePresetOptions.Any(x => !x.IsBuiltIn && !string.Equals(x.Key, presetKey, StringComparison.OrdinalIgnoreCase) && string.Equals(x.Name, name.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add("A custom media profile preset with that name already exists.", Severity.Warning);
            return;
        }

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, $"/api/settings/media-profile/presets/{Uri.EscapeDataString(presetKey)}")
            {
                Content = JsonContent.Create(new RenameMediaProfilePresetRequest(name.Trim()))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to rename media profile preset ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MediaProfilePresetDto>();
            await LoadMediaProfilePresetOptionsAsync();
            if (payload is not null && string.Equals(_selectedMediaProfilePreset, presetKey, StringComparison.OrdinalIgnoreCase))
            {
                _selectedMediaProfilePreset = payload.Key;
                _mediaProfile.ActivePresetName = payload.Name;
            }

            Snackbar.Add("Media profile preset renamed.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to rename media profile preset.", Severity.Error);
        }
    }

    private async Task DeleteMediaProfilePresetAsync(string presetKey)
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/settings/media-profile/presets/{Uri.EscapeDataString(presetKey)}");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to delete media profile preset ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            await LoadMediaProfilePresetOptionsAsync();
            if (string.Equals(_selectedMediaProfilePreset, presetKey, StringComparison.OrdinalIgnoreCase))
            {
                _selectedMediaProfilePreset = "custom-unsaved";
                _mediaProfile.ActivePresetKey = string.Empty;
                _mediaProfile.ActivePresetName = string.Empty;
            }

            Snackbar.Add("Media profile preset deleted.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to delete media profile preset.", Severity.Error);
        }
    }

    private void UpdatePresetDraftName(string presetKey, string? value)
        => _mediaProfilePresetDraftNames[presetKey] = value ?? string.Empty;

    private void ApplySelectedMediaProfilePreset()
    {
        var selected = GetSelectedMediaProfilePreset();
        if (selected?.Settings is not null)
        {
            _mediaProfile = selected.Settings.Clone();
            _mediaProfile.ActivePresetKey = selected.Key;
            _mediaProfile.ActivePresetName = selected.Name;
        }
    }

    private MediaProfilePresetOption? GetSelectedMediaProfilePreset()
        => _mediaProfilePresetOptions.FirstOrDefault(x => string.Equals(x.Key, _selectedMediaProfilePreset, StringComparison.OrdinalIgnoreCase));

    private string ResolveMediaProfilePreset(MediaProfileSettingsResponse payload)
    {
        if (!string.IsNullOrWhiteSpace(payload.ActivePresetKey) && _mediaProfilePresetOptions.Any(x => string.Equals(x.Key, payload.ActivePresetKey, StringComparison.OrdinalIgnoreCase)))
        {
            return payload.ActivePresetKey;
        }

        if (_mediaProfile.Matches(MediaProfileSettingsModel.BroadPlexCompatibility())) return "broad-plex-compatibility";
        if (_mediaProfile.Matches(MediaProfileSettingsModel.ModernQualityEfficiency())) return "modern-quality-efficiency";
        return "custom-unsaved";
    }

