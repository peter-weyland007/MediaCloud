@page "/settings/app-behavior"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar

<PageTitle>App Behavior Settings</PageTitle>

<h1>App Behavior</h1>
<p class="subtitle">Global runtime policy, monitoring & request sync, and TV display defaults.</p>

<div class="settings-stack">
    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">RUNTIME POLICY</p>
                <h2>Mismatch tolerances</h2>
                <p class="card-note">Set tolerance and severity thresholds for reported vs actual runtime differences.</p>
            </div>
            <a class="button-secondary" href="/settings/runtime-policy" style="display:inline-block; text-decoration:none;">Open standalone page</a>
        </div>

        @if (_loadingRuntimePolicy)
        {
            <p class="card-note">Loading runtime policy…</p>
        }
        else
        {
            <div class="settings-two-col-grid">
                <div class="form-group">
                    <label>Tolerance floor (minutes)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.ToleranceMinutesFloor" />
                    <p class="card-note" style="margin-top:0.35rem;">Minimum absolute difference allowed before mismatch.</p>
                </div>

                <div class="form-group">
                    <label>Tolerance percent (%)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.TolerancePercent" />
                    <p class="card-note" style="margin-top:0.35rem;">Percent of reported runtime used as relative tolerance.</p>
                </div>

                <div class="form-group">
                    <label>Warning percent (%)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.WarningPercent" />
                </div>

                <div class="form-group">
                    <label>High minutes (minutes)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.HighMinutes" />
                </div>

                <div class="form-group">
                    <label>Critical percent (%)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.CriticalPercent" />
                </div>

                <div class="form-group">
                    <label>Critical minutes (minutes)</label>
                    <InputNumber class="input" @bind-Value="_runtimePolicy.CriticalMinutes" />
                </div>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveRuntimePolicyAsync" disabled="@_savingRuntimePolicy">@(_savingRuntimePolicy ? "Saving..." : "Save runtime policy")</button>
                <button class="button-secondary" @onclick="ResetRuntimePolicyDefaultsAsync" disabled="@_resettingRuntimePolicy">@(_resettingRuntimePolicy ? "Resetting..." : "Reset to defaults")</button>
            </div>
        }
    </div>

    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">MONITORING & REQUEST SYNC</p>
                <h2>Global monitoring ownership + request sync</h2>
                <p class="card-note">Configure app-wide monitoring behavior: Radarr and Sonarr are the actual monitor-state targets, while Overseerr contributes request and availability intent signals.</p>
            </div>
            <a class="button-secondary" href="/settings/monitoring" style="display:inline-block; text-decoration:none;">Open standalone page</a>
        </div>

        @if (_loadingMonitoring)
        {
            <p class="card-note">Loading monitoring settings…</p>
        }
        else
        {
            <div style="display:grid; gap:0.9rem;">
                <label style="display:flex; gap:0.6rem; align-items:flex-start;">
                    <input type="checkbox" @bind="_monitoring.ManagedByMediaCloud" />
                    <span>
                        <strong>Monitor in MediaCloud</strong><br />
                        <span class="card-note">Use MediaCloud as the monitor-state source of truth for movie and series library items. When off, MediaCloud stops driving monitor-state changes into Radarr and Sonarr.</span>
                    </span>
                </label>

                <label style="display:flex; gap:0.6rem; align-items:flex-start;">
                    <input type="checkbox" @bind="_monitoring.AutoSyncEnabled" disabled="@(!_monitoring.ManagedByMediaCloud)" />
                    <span>
                        <strong>Auto sync</strong><br />
                        <span class="card-note">When enabled, MediaCloud automatically pushes monitor-state changes to Radarr and Sonarr. Overseerr is still consulted for request and media-intent context, but it is not the primary monitor-state owner.</span>
                    </span>
                </label>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveMonitoringAsync" disabled="@_savingMonitoring">@(_savingMonitoring ? "Saving..." : "Save monitoring settings")</button>
            </div>
        }
    </div>

    <div class="card">
        <div class="settings-section-header">
            <div>
                <p class="card-label">TV DISPLAY</p>
                <h2>Series season display defaults</h2>
                <p class="card-note">Configure global TV-series detail defaults like hiding Specials by default.</p>
            </div>
            <a class="button-secondary" href="/settings/tv-display" style="display:inline-block; text-decoration:none;">Open standalone page</a>
        </div>

        @if (_loadingTvDisplay)
        {
            <p class="card-note">Loading TV display settings…</p>
        }
        else
        {
            <div style="display:grid; gap:0.9rem;">
                <label style="display:flex; gap:0.6rem; align-items:flex-start;">
                    <input type="checkbox" @bind="_tvDisplay.HideSpecialsByDefault" />
                    <span>
                        <strong>Hide Specials by default</strong><br />
                        <span class="card-note">When enabled, series detail pages hide season 0 / Specials unless the viewer turns them back on for that page.</span>
                    </span>
                </label>
            </div>

            <div class="settings-actions">
                <button class="button-primary" @onclick="SaveTvDisplayAsync" disabled="@_savingTvDisplay">@(_savingTvDisplay ? "Saving..." : "Save TV display settings")</button>
            </div>
        }
    </div>
</div>

<style>
    .settings-stack {
        display: grid;
        gap: 1rem;
    }

    .settings-two-col-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
    }

    .settings-section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.85rem;
        flex-wrap: wrap;
    }

    .settings-actions {
        display: flex;
        gap: 0.55rem;
        margin-top: 0.95rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 1100px) {
        .settings-two-col-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool _loadingRuntimePolicy = true;
    private bool _savingRuntimePolicy;
    private bool _resettingRuntimePolicy;
    private bool _loadingMonitoring = true;
    private bool _savingMonitoring;
    private bool _loadingTvDisplay = true;
    private bool _savingTvDisplay;

    private RuntimePolicySettingsModel _runtimePolicy = new();
    private MonitoringSettingsModel _monitoring = new();
    private TvDisplaySettingsModel _tvDisplay = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRuntimePolicyAsync();
        await LoadMonitoringAsync();
        await LoadTvDisplayAsync();
    }

    private async Task LoadRuntimePolicyAsync()
    {
        _loadingRuntimePolicy = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/runtime-policy");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _runtimePolicy = RuntimePolicySettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load runtime policy.", Severity.Error);
        }
        finally
        {
            _loadingRuntimePolicy = false;
        }
    }

    private async Task SaveRuntimePolicyAsync()
    {
        _savingRuntimePolicy = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/runtime-policy")
            {
                Content = JsonContent.Create(new UpdateRuntimePolicySettingsRequest(
                    _runtimePolicy.ToleranceMinutesFloor,
                    _runtimePolicy.TolerancePercent,
                    _runtimePolicy.WarningPercent,
                    _runtimePolicy.HighMinutes,
                    _runtimePolicy.CriticalPercent,
                    _runtimePolicy.CriticalMinutes))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _runtimePolicy = RuntimePolicySettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Runtime policy saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save runtime policy.", Severity.Error);
        }
        finally
        {
            _savingRuntimePolicy = false;
        }
    }

    private async Task ResetRuntimePolicyDefaultsAsync()
    {
        _resettingRuntimePolicy = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/settings/runtime-policy/reset");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to reset runtime policy ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<RuntimePolicySettingsResponse>();
            if (payload is not null)
            {
                _runtimePolicy = RuntimePolicySettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Runtime policy reset to defaults.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to reset runtime policy.", Severity.Error);
        }
        finally
        {
            _resettingRuntimePolicy = false;
        }
    }

    private async Task LoadMonitoringAsync()
    {
        _loadingMonitoring = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/monitoring");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load monitoring settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MonitoringSettingsResponse>();
            if (payload is not null)
            {
                _monitoring = MonitoringSettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load monitoring settings.", Severity.Error);
        }
        finally
        {
            _loadingMonitoring = false;
        }
    }

    private async Task SaveMonitoringAsync()
    {
        _savingMonitoring = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/monitoring")
            {
                Content = JsonContent.Create(new UpdateMonitoringSettingsRequest(_monitoring.ManagedByMediaCloud, _monitoring.AutoSyncEnabled))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save monitoring settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<MonitoringSettingsResponse>();
            if (payload is not null)
            {
                _monitoring = MonitoringSettingsModel.FromResponse(payload);
            }

            Snackbar.Add("Monitoring settings saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save monitoring settings.", Severity.Error);
        }
        finally
        {
            _savingMonitoring = false;
        }
    }

    private async Task LoadTvDisplayAsync()
    {
        _loadingTvDisplay = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/settings/tv-display");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load TV display settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<TvDisplaySettingsResponse>();
            if (payload is not null)
            {
                _tvDisplay = TvDisplaySettingsModel.FromResponse(payload);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load TV display settings.", Severity.Error);
        }
        finally
        {
            _loadingTvDisplay = false;
        }
    }

    private async Task SaveTvDisplayAsync()
    {
        _savingTvDisplay = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Put, "/api/settings/tv-display")
            {
                Content = JsonContent.Create(new UpdateTvDisplaySettingsRequest(_tvDisplay.HideSpecialsByDefault))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                Snackbar.Add(error?.Error ?? $"Failed to save TV display settings ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<TvDisplaySettingsResponse>();
            if (payload is not null)
            {
                _tvDisplay = TvDisplaySettingsModel.FromResponse(payload);
            }

            Snackbar.Add("TV display settings saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to save TV display settings.", Severity.Error);
        }
        finally
        {
            _savingTvDisplay = false;
        }
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private sealed class RuntimePolicySettingsModel
    {
        public double ToleranceMinutesFloor { get; set; } = 3;
        public double TolerancePercent { get; set; } = 5;
        public double WarningPercent { get; set; } = 10;
        public double HighMinutes { get; set; } = 12;
        public double CriticalPercent { get; set; } = 20;
        public double CriticalMinutes { get; set; } = 25;

        public static RuntimePolicySettingsModel FromResponse(RuntimePolicySettingsResponse value) => new()
        {
            ToleranceMinutesFloor = value.ToleranceMinutesFloor,
            TolerancePercent = value.TolerancePercent,
            WarningPercent = value.WarningPercent,
            HighMinutes = value.HighMinutes,
            CriticalPercent = value.CriticalPercent,
            CriticalMinutes = value.CriticalMinutes
        };
    }

    private sealed class MonitoringSettingsModel
    {
        public bool ManagedByMediaCloud { get; set; } = true;
        public bool AutoSyncEnabled { get; set; }

        public static MonitoringSettingsModel FromResponse(MonitoringSettingsResponse value) => new()
        {
            ManagedByMediaCloud = value.ManagedByMediaCloud,
            AutoSyncEnabled = value.AutoSyncEnabled
        };
    }

    private sealed class TvDisplaySettingsModel
    {
        public bool HideSpecialsByDefault { get; set; }

        public static TvDisplaySettingsModel FromResponse(TvDisplaySettingsResponse value) => new()
        {
            HideSpecialsByDefault = value.HideSpecialsByDefault
        };
    }

    private record UpdateRuntimePolicySettingsRequest(double ToleranceMinutesFloor, double TolerancePercent, double WarningPercent, double HighMinutes, double CriticalPercent, double CriticalMinutes);
    private record RuntimePolicySettingsResponse(double ToleranceMinutesFloor, double TolerancePercent, double WarningPercent, double HighMinutes, double CriticalPercent, double CriticalMinutes);
    private record UpdateMonitoringSettingsRequest(bool ManagedByMediaCloud, bool AutoSyncEnabled);
    private record MonitoringSettingsResponse(bool ManagedByMediaCloud, bool AutoSyncEnabled);
    private record UpdateTvDisplaySettingsRequest(bool HideSpecialsByDefault);
    private record TvDisplaySettingsResponse(bool HideSpecialsByDefault);
    private record ErrorResponse(string Error);
}
