@page "/integrations/{ServiceKey}"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@TitleText</PageTitle>

<p class="subtitle"><a href="/integrations">Integrations</a> / @ServiceDisplayName</p>
<h1>@ServiceDisplayName</h1>
<p class="subtitle">Service instances, operational status, and actions for @ServiceDisplayName.</p>

<div class="card" style="margin-bottom:1rem; display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;">
    <div>
        <p class="card-label">SERVICE CONTROL PLANE</p>
        <p class="card-note" style="margin-top:0.35rem;">Back to integrations for the broader control plane and connection management.</p>
    </div>
    <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
        <MudButton Href="/integrations" Color="Color.Secondary">Back to integrations</MudButton>
    </MudButtonGroup>
</div>

@if (_loading)
{
    <div class="card">
        <p class="card-note">Loading service instances…</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="card">
        <p class="error-text">@_loadError</p>
    </div>
}
else if (_instances.Count == 0)
{
    <div class="card">
        <p class="card-label">SERVICE INSTANCES</p>
        <p class="card-note" style="margin-top:0.35rem;">No configured instances were found for @ServiceDisplayName.</p>
    </div>
}
else
{
    <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
        <button type="button"
                class="integration-detail-panel-toggle"
                @onclick='() => TogglePanel("summary")'
                aria-expanded="@IsPanelExpanded("summary")"
                aria-controls="integration-detail-panel-summary">
            <span>
                <span class="card-label" style="display:block;">SUMMARY</span>
                <span class="card-note" style="display:block; margin-top:0.35rem;">Overall service health and instance totals for @ServiceDisplayName.</span>
            </span>
            <span class="integration-detail-panel-chevron">@PanelChevron("summary")</span>
        </button>

        @if (IsPanelExpanded("summary"))
        {
            <div id="integration-detail-panel-summary" class="integration-detail-panel-body" style="display:flex; gap:0.55rem; flex-wrap:wrap;">
                <span class="integration-service-metric-chip">@_instances.Count instance(s)</span>
                <span class="integration-service-metric-chip">Healthy: @_instances.Count(x => string.Equals(GetHealthLabel(x), "Healthy", StringComparison.OrdinalIgnoreCase))</span>
                <span class="integration-service-metric-chip">Operational: @_instances.Count(x => string.Equals(GetHealthLabel(x), "Operational", StringComparison.OrdinalIgnoreCase))</span>
                <span class="integration-service-metric-chip">Attention needed: @_instances.Count(x => string.Equals(GetHealthLabel(x), "Attention needed", StringComparison.OrdinalIgnoreCase))</span>
            </div>
        }
    </section>

    @if (IsRadarrPage)
    {
        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <button type="button"
                    class="integration-detail-panel-toggle"
                    @onclick='() => TogglePanel("radarr-control")'
                    aria-expanded="@IsPanelExpanded("radarr-control")"
                    aria-controls="integration-detail-panel-radarr-control">
                <span>
                    <span class="card-label" style="display:block;">RADARR CONTROL</span>
                    <span class="card-note" style="display:block; margin-top:0.35rem;">First-pass Radarr control plane for catalog sync, monitoring ownership, roots, and reconciliation.</span>
                </span>
                <span class="integration-detail-panel-chevron">@PanelChevron("radarr-control")</span>
            </button>

            @if (IsPanelExpanded("radarr-control"))
            {
                <div id="integration-detail-panel-radarr-control" class="integration-detail-panel-body" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                    <div>
                        <p class="card-label">CATALOG SYNC</p>
                        <p class="card-note" style="margin-top:0.35rem;">Last success: @FormatTimestamp(_instances.Select(x => x.LastSuccessfulAtUtc).Where(x => x.HasValue).OrderByDescending(x => x).FirstOrDefault())</p>
                        <p class="card-note" style="margin-top:0.25rem;">Last attempt: @FormatTimestamp(_instances.Select(x => x.LastAttemptedAtUtc).Where(x => x.HasValue).OrderByDescending(x => x).FirstOrDefault())</p>
                        <p class="card-note" style="margin-top:0.25rem;">Sync-backed movie catalog ingestion is active for Radarr.</p>
                    </div>
                    <div>
                        <p class="card-label">MONITORING OWNERSHIP</p>
                        <p class="card-note" style="margin-top:0.35rem;">MediaCloud owns monitoring: @FormatBool(_monitoringSettings?.ManagedByMediaCloud)</p>
                        <p class="card-note" style="margin-top:0.25rem;">Auto sync enabled: @FormatBool(_monitoringSettings?.AutoSyncEnabled)</p>
                        <p class="card-note" style="margin-top:0.25rem;">Settings live on the app-wide monitoring policy, but this is the effective Radarr state.</p>
                    </div>
                    <div>
                        <p class="card-label">DRIFT & RECONCILIATION</p>
                        @if (_radarrDriftPreviewLoading)
                        {
                            <p class="card-note" style="margin-top:0.35rem;">Loading drift preview…</p>
                        }
                        else
                        {
                            <p class="card-note" style="margin-top:0.35rem;">Plex movies scanned: @(_radarrDriftPreview?.TotalPlexMovies ?? 0)</p>
                            <p class="card-note" style="margin-top:0.25rem;">Missing from Radarr: @(_radarrDriftPreview?.MissingRadarrCount ?? 0)</p>
                            <p class="card-note" style="margin-top:0.25rem;">Missing in both Radarr + Overseerr: @(_radarrDriftPreview?.MissingBothCount ?? 0)</p>
                        }
                    </div>

                    <div style="grid-column:1 / -1; display:grid; gap:0.75rem;">
                        <div style="display:flex; justify-content:space-between; align-items:center; gap:0.75rem; flex-wrap:wrap;">
                            <div>
                                <p class="card-label">SEARCH & RETRY</p>
                                <p class="card-note" style="margin-top:0.35rem;">Retry search in Radarr for linked titles or add missing titles to Radarr from the drift preview.</p>
                            </div>
                            <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_selectedRadarrSearchRetryLibraryItemIds.Count == 0 || _radarrSyncingLibraryItemIds.Count > 0)" OnClick="BulkSyncSelectedLibraryItemsToRadarrAsync">
                                    @(_radarrSyncingLibraryItemIds.Count > 0 ? "Adding..." : "Bulk Add to Radarr")
                                </MudButton>
                                <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_selectedRadarrSearchRetryLibraryItemIds.Count == 0 || _radarrSearchingLibraryItemIds.Count > 0)" OnClick="BulkRunRadarrSearchReplacementAsync">
                                    @(_radarrSearchingLibraryItemIds.Count > 0 ? "Retrying..." : "Bulk Retry search")
                                </MudButton>
                                <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@_radarrDriftPreviewLoading" OnClick="RefreshRadarrDriftPreviewAsync">
                                    @(_radarrDriftPreviewLoading ? "Refreshing..." : "Refresh drift preview")
                                </MudButton>
                            </MudButtonGroup>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_radarrSearchRetryStatus))
                        {
                            <p class="card-note">@_radarrSearchRetryStatus</p>
                        }

                        @if (VisibleRadarrSearchRetryRows.Count == 0)
                        {
                            <p class="card-note">No Radarr search/retry candidates are available from the current drift preview.</p>
                        }
                        else
                        {
                            <table style="width:100%; border-collapse:collapse; font-size:0.84rem;">
                                <thead>
                                    <tr style="text-align:left; border-bottom:1px solid rgba(148,163,184,0.25);">
                                        <th style="padding:0.3rem 0.4rem; width:80px;">
                                            <label style="display:flex; gap:0.35rem; align-items:center;">
                                                <input type="checkbox" checked="@AreAllVisibleRadarrSearchRetryRowsSelected" @onchange="ToggleSelectAllRadarrSearchRetryRows" />
                                                All
                                            </label>
                                        </th>
                                        <th style="padding:0.3rem 0.4rem;">Title</th>
                                        <th style="padding:0.3rem 0.4rem;">Year</th>
                                        <th style="padding:0.3rem 0.4rem;">Radarr state</th>
                                        <th style="padding:0.3rem 0.4rem;">TMDB</th>
                                        <th style="padding:0.3rem 0.4rem;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in VisibleRadarrSearchRetryRows)
                                    {
                                        <tr style="border-bottom:1px solid rgba(148,163,184,0.12);">
                                            <td style="padding:0.3rem 0.4rem;">
                                                <input type="checkbox" checked="@_selectedRadarrSearchRetryLibraryItemIds.Contains(row.LibraryItemId)" disabled="@(!CanBulkOperateOnRadarrSearchRetryRow(row))" @onchange="args => ToggleRadarrSearchRetryRowSelection(row.LibraryItemId, args.Value)" />
                                            </td>
                                            <td style="padding:0.3rem 0.4rem;">
                                                <div>@row.Title</div>
                                                <div class="card-note">Sources: @row.SourceServicesCsv</div>
                                            </td>
                                            <td style="padding:0.3rem 0.4rem;">@(row.Year?.ToString() ?? "—")</td>
                                            <td style="padding:0.3rem 0.4rem;">@(row.MissingRadarr ? "Missing from Radarr" : "Linked in Radarr")</td>
                                            <td style="padding:0.3rem 0.4rem;">@(row.TmdbId?.ToString() ?? "—")</td>
                                            <td style="padding:0.3rem 0.4rem;">
                                                <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                                    <MudButton Class="integration-action-button integration-action-button-sync"
                                                               ButtonType="ButtonType.Button"
                                                               Disabled="@(!row.MissingRadarr || !row.CanBackfill || _radarrSyncingLibraryItemIds.Contains(row.LibraryItemId))"
                                                               OnClick="@(() => SyncLibraryItemToRadarrAsync(row))">
                                                        @(_radarrSyncingLibraryItemIds.Contains(row.LibraryItemId) ? "Adding..." : "Add to Radarr")
                                                    </MudButton>
                                                    <MudButton Class="integration-action-button integration-action-button-secondary"
                                                               ButtonType="ButtonType.Button"
                                                               Disabled="@(row.MissingRadarr || _radarrSearchingLibraryItemIds.Contains(row.LibraryItemId))"
                                                               OnClick="@(() => RunRadarrSearchReplacementAsync(row))">
                                                        @(_radarrSearchingLibraryItemIds.Contains(row.LibraryItemId) ? "Retrying..." : "Retry search in Radarr")
                                                    </MudButton>
                                                </MudButtonGroup>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
        </section>

        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <button type="button"
                    class="integration-detail-panel-toggle"
                    @onclick='() => TogglePanel("radarr-quality-profiles")'
                    aria-expanded="@IsPanelExpanded("radarr-quality-profiles")"
                    aria-controls="integration-detail-panel-radarr-quality-profiles">
                <span>
                    <span class="card-label" style="display:block;">QUALITY PROFILES</span>
                    <span class="card-note" style="display:block; margin-top:0.35rem;">Choose the preferred quality profile MediaCloud should use for Radarr-driven adds and future remediation flows.</span>
                </span>
                <span class="integration-detail-panel-chevron">@PanelChevron("radarr-quality-profiles")</span>
            </button>

            @if (IsPanelExpanded("radarr-quality-profiles"))
            {
                <div id="integration-detail-panel-radarr-quality-profiles" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">
                    @if (_radarrQualityProfilesLoading && _radarrQualityProfiles is null)
                    {
                        <p class="card-note">Loading quality profiles…</p>
                    }
                    else if (_radarrQualityProfiles is null)
                    {
                        <p class="card-note">@(string.IsNullOrWhiteSpace(_radarrQualityProfilesError) ? "Radarr quality profiles are not available yet." : _radarrQualityProfilesError)</p>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_radarrQualityProfilesError))
                        {
                            <p class="card-note" style="color:#fca5a5;">@_radarrQualityProfilesError</p>
                        }

                        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                            <div>
                                <p class="card-label">AVAILABLE PROFILES</p>
                                <p class="card-note" style="margin-top:0.35rem;">@_radarrQualityProfiles.Profiles.Count profile(s) returned by Radarr.</p>
                            </div>
                            <div>
                                <p class="card-label">PREFERRED QUALITY PROFILE</p>
                                <p class="card-note" style="margin-top:0.35rem;">@(_radarrQualityProfiles.PreferredProfileName is { Length: > 0 } preferred ? preferred : "No MediaCloud default selected yet.")</p>
                            </div>
                            <div>
                                <p class="card-label">OBSERVED ON SYNCED ITEMS</p>
                                @if (_radarrQualityProfiles.ObservedLibraryQualityProfiles.Count == 0)
                                {
                                    <p class="card-note" style="margin-top:0.35rem;">No synced Radarr profile names have been observed yet.</p>
                                }
                                else
                                {
                                    <p class="card-note" style="margin-top:0.35rem;">@string.Join(", ", _radarrQualityProfiles.ObservedLibraryQualityProfiles)</p>
                                }
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="radarr-preferred-quality-profile">Preferred quality profile</label>
                            <InputSelect id="radarr-preferred-quality-profile" class="input" @bind-Value="_radarrQualityProfiles.PreferredProfileId">
                                @foreach (var profile in _radarrQualityProfiles.Profiles)
                                {
                                    <option value="@profile.Id">@profile.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrQualityProfilesSaving || _radarrQualityProfilesSyncing || _instances.FirstOrDefault() is null || _radarrQualityProfiles.Profiles.Count == 0)" OnClick="SaveRadarrQualityProfileAsync">
                                @(_radarrQualityProfilesSaving ? "Saving..." : "Save quality profile")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrQualityProfilesSaving || _radarrQualityProfilesSyncing || _instances.FirstOrDefault() is null || _radarrQualityProfiles.Profiles.Count == 0)" OnClick="SyncRadarrMediaCloudProfileAsync">
                                @(_radarrQualityProfilesSyncing ? "Syncing..." : "Sync MediaCloud Profile")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_radarrQualityProfilesLoading || _radarrQualityProfilesSyncing || _instances.FirstOrDefault() is null)" OnClick="ReloadRadarrQualityProfilesAsync">
                                @(_radarrQualityProfilesLoading ? "Refreshing..." : "Reload from Radarr")
                            </MudButton>
                        </MudButtonGroup>
                    }
                </div>
            }
        </section>

        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <button type="button"
                    class="integration-detail-panel-toggle"
                    @onclick='() => TogglePanel("radarr-default-add-policy")'
                    aria-expanded="@IsPanelExpanded("radarr-default-add-policy")"
                    aria-controls="integration-detail-panel-radarr-default-add-policy">
                <span>
                    <span class="card-label" style="display:block;">DEFAULT ADD POLICY</span>
                    <span class="card-note" style="display:block; margin-top:0.35rem;">Control the root folder, quality profile, minimum availability, and monitored default MediaCloud should use when adding movies to Radarr.</span>
                </span>
                <span class="integration-detail-panel-chevron">@PanelChevron("radarr-default-add-policy")</span>
            </button>

            @if (IsPanelExpanded("radarr-default-add-policy"))
            {
                <div id="integration-detail-panel-radarr-default-add-policy" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">
                    @if (_radarrDefaultAddPolicyLoading && _radarrDefaultAddPolicy is null)
                    {
                        <p class="card-note">Loading default add policy…</p>
                    }
                    else if (_radarrDefaultAddPolicy is null)
                    {
                        <p class="card-note">@(string.IsNullOrWhiteSpace(_radarrDefaultAddPolicyError) ? "Radarr default add policy is not available yet." : _radarrDefaultAddPolicyError)</p>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_radarrDefaultAddPolicyError))
                        {
                            <p class="card-note" style="color:#fca5a5;">@_radarrDefaultAddPolicyError</p>
                        }

                        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                            <div>
                                <p class="card-label">ROOT FOLDER</p>
                                <p class="card-note" style="margin-top:0.35rem;">@(_radarrDefaultAddPolicy.RootFolderPath is { Length: > 0 } root ? root : "No default root folder selected.")</p>
                            </div>
                            <div>
                                <p class="card-label">QUALITY PROFILE</p>
                                <p class="card-note" style="margin-top:0.35rem;">@(_radarrDefaultAddPolicy.QualityProfileName is { Length: > 0 } profile ? profile : "No default quality profile selected.")</p>
                            </div>
                            <div>
                                <p class="card-label">MINIMUM AVAILABILITY</p>
                                <p class="card-note" style="margin-top:0.35rem;">@_radarrDefaultAddPolicy.MinimumAvailability</p>
                            </div>
                            <div>
                                <p class="card-label">MONITOR BY DEFAULT</p>
                                <p class="card-note" style="margin-top:0.35rem;">@FormatBool(_radarrDefaultAddPolicy.Monitored)</p>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="radarr-default-root-folder">Default root folder</label>
                            <InputSelect id="radarr-default-root-folder" class="input" @bind-Value="_radarrDefaultAddPolicy.RootFolderPath">
                                @foreach (var root in _radarrDefaultAddPolicy.AvailableRootFolders)
                                {
                                    <option value="@root">@root</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label for="radarr-default-quality-profile">Preferred quality profile</label>
                            <InputSelect id="radarr-default-quality-profile" class="input" @bind-Value="_radarrDefaultAddPolicy.QualityProfileId">
                                @foreach (var profile in _radarrDefaultAddPolicy.AvailableQualityProfiles)
                                {
                                    <option value="@profile.Id">@profile.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label for="radarr-minimum-availability">Minimum availability</label>
                            <InputSelect id="radarr-minimum-availability" class="input" @bind-Value="_radarrDefaultAddPolicy.MinimumAvailability">
                                @foreach (var option in _radarrDefaultAddPolicy.MinimumAvailabilityOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </InputSelect>
                        </div>

                        <label style="display:flex; gap:0.45rem; align-items:center;">
                            <input type="checkbox" @bind="_radarrDefaultAddPolicy.Monitored" />
                            <span>Monitor by default</span>
                        </label>

                        <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrDefaultAddPolicySaving || _instances.FirstOrDefault() is null || _radarrDefaultAddPolicy.AvailableRootFolders.Count == 0 || _radarrDefaultAddPolicy.AvailableQualityProfiles.Count == 0)" OnClick="SaveRadarrDefaultAddPolicyAsync">
                                @(_radarrDefaultAddPolicySaving ? "Saving..." : "Save add policy")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_radarrDefaultAddPolicyLoading || _instances.FirstOrDefault() is null)" OnClick="ReloadRadarrDefaultAddPolicyAsync">
                                @(_radarrDefaultAddPolicyLoading ? "Refreshing..." : "Reload from Radarr")
                            </MudButton>
                        </MudButtonGroup>
                    }
                </div>
            }
        </section>

        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <button type="button"
                    class="integration-detail-panel-toggle"
                    @onclick='() => TogglePanel("radarr-tags")'
                    aria-expanded="@IsPanelExpanded("radarr-tags")"
                    aria-controls="integration-detail-panel-radarr-tags">
                <span>
                    <span class="card-label" style="display:block;">TAGS</span>
                    <span class="card-note" style="display:block; margin-top:0.35rem;">Apply tags when adding movies to Radarr so MediaCloud can stamp consistent acquisition policy onto new adds.</span>
                </span>
                <span class="integration-detail-panel-chevron">@PanelChevron("radarr-tags")</span>
            </button>

            @if (IsPanelExpanded("radarr-tags"))
            {
                <div id="integration-detail-panel-radarr-tags" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">
                    @if (_radarrTagsLoading && _radarrTags is null)
                    {
                        <p class="card-note">Loading tags…</p>
                    }
                    else if (_radarrTags is null)
                    {
                        <p class="card-note">@(string.IsNullOrWhiteSpace(_radarrTagsError) ? "Radarr tags are not available yet." : _radarrTagsError)</p>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_radarrTagsError))
                        {
                            <p class="card-note" style="color:#fca5a5;">@_radarrTagsError</p>
                        }

                        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                            <div>
                                <p class="card-label">AVAILABLE TAGS</p>
                                <p class="card-note" style="margin-top:0.35rem;">@_radarrTags.Tags.Count tag(s) returned by Radarr.</p>
                            </div>
                            <div>
                                <p class="card-label">DEFAULT TAGS</p>
                                <p class="card-note" style="margin-top:0.35rem;">@(_radarrTags.SelectedTagLabels.Count == 0 ? "No default tags selected." : string.Join(", ", _radarrTags.SelectedTagLabels))</p>
                            </div>
                        </div>

                        <div style="display:grid; gap:0.6rem;">
                            @foreach (var tag in _radarrTags.Tags)
                            {
                                <label style="display:flex; gap:0.45rem; align-items:center;">
                                    <input type="checkbox" checked="@_radarrTags.SelectedTagIds.Contains(tag.Id)" @onchange="args => ToggleRadarrTagSelection(tag.Id, args.Value)" />
                                    <span>@tag.Label</span>
                                </label>
                            }
                        </div>

                        <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrTagsSaving || _instances.FirstOrDefault() is null)" OnClick="SaveRadarrTagsAsync">
                                @(_radarrTagsSaving ? "Saving..." : "Save tags")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_radarrTagsLoading || _instances.FirstOrDefault() is null)" OnClick="ReloadRadarrTagsAsync">
                                @(_radarrTagsLoading ? "Refreshing..." : "Reload from Radarr")
                            </MudButton>
                        </MudButtonGroup>
                    }
                </div>
            }
        </section>

        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <div class="integration-detail-panel-header">
                <button type="button"
                        class="integration-detail-panel-toggle"
                        @onclick='() => TogglePanel("radarr-naming")'
                        aria-expanded="@IsPanelExpanded("radarr-naming")"
                        aria-controls="integration-detail-panel-radarr-naming">
                    <span>
                        <span class="card-label" style="display:block;">NAMING CONVENTION</span>
                        <span class="card-note" style="display:block; margin-top:0.35rem;">Adjust Radarr file and folder naming without leaving MediaCloud.</span>
                    </span>
                </button>
                <span class="integration-detail-panel-actions">
                    <button type="button"
                            class="integration-detail-panel-icon-button"
                            title="File name tokens reference"
                            aria-label="Open file name tokens reference"
                            @onclick="OpenRadarrNamingHelp">
                        <span class="integration-detail-panel-icon-glyph" aria-hidden="true">i</span>
                    </button>
                    <span class="integration-detail-panel-chevron">@PanelChevron("radarr-naming")</span>
                </span>
            </div>

            @if (IsPanelExpanded("radarr-naming"))
            {
                <div id="integration-detail-panel-radarr-naming" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">

                    @if (_radarrNamingLoading && _radarrNaming is null)
                    {
                        <p class="card-note">Loading naming settings…</p>
                    }
                    else if (_radarrNaming is null)
                    {
                        <p class="card-note">@(string.IsNullOrWhiteSpace(_radarrNamingError) ? "Radarr naming settings are not available yet." : _radarrNamingError)</p>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_radarrNamingError))
                        {
                            <p class="card-note" style="color:#fca5a5;">@_radarrNamingError</p>
                        }

                        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                            <label style="display:flex; gap:0.45rem; align-items:center;">
                                <input type="checkbox" @bind="_radarrNaming.RenameMovies" />
                                <span>Rename movie files</span>
                            </label>
                            <label style="display:flex; gap:0.45rem; align-items:center;">
                                <input type="checkbox" @bind="_radarrNaming.ReplaceIllegalCharacters" />
                                <span>Replace illegal characters</span>
                            </label>
                            <div>
                                <label for="radarr-colon-format">Colon replacement format</label>
                                <InputText id="radarr-colon-format" class="input" @bind-Value="_radarrNaming.ColonReplacementFormat" />
                            </div>
                        </div>

                        <div style="display:grid; gap:0.75rem;">
                            <div>
                                <label for="radarr-standard-format">Standard file format</label>
                                <textarea id="radarr-standard-format" class="input" rows="2" @bind="_radarrNaming.StandardMovieFormat"></textarea>
                            </div>
                            <div>
                                <label for="radarr-folder-format">Movie folder format</label>
                                <textarea id="radarr-folder-format" class="input" rows="2" @bind="_radarrNaming.MovieFolderFormat"></textarea>
                            </div>
                        </div>

                        <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrNamingSaving || _instances.FirstOrDefault() is null)" OnClick="SaveRadarrNamingAsync">
                                @(_radarrNamingSaving ? "Saving..." : "Save naming")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_radarrNamingLoading || _instances.FirstOrDefault() is null)" OnClick="ReloadRadarrNamingAsync">
                                @(_radarrNamingLoading ? "Refreshing..." : "Reload from Radarr")
                            </MudButton>
                        </MudButtonGroup>
                    }
                </div>
            }
        </section>

        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <button type="button"
                    class="integration-detail-panel-toggle"
                    @onclick='() => TogglePanel("radarr-paths")'
                    aria-expanded="@IsPanelExpanded("radarr-paths")"
                    aria-controls="integration-detail-panel-radarr-paths">
                <span>
                    <span class="card-label" style="display:block;">ROOT FOLDERS & MAPPINGS</span>
                    <span class="card-note" style="display:block; margin-top:0.35rem;">Remote roots, local path mapping, and path test results.</span>
                </span>
                <span class="integration-detail-panel-chevron">@PanelChevron("radarr-paths")</span>
            </button>

            @if (IsPanelExpanded("radarr-paths"))
            {
                <div id="integration-detail-panel-radarr-paths" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">
                    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:0.85rem;">
                        <div>
                            <p class="card-label">DISCOVERED ROOT FOLDERS</p>
                            @if (_radarrRemoteRoots?.Paths is { Count: > 0 } remoteRoots)
                            {
                                <ul style="margin:0.5rem 0 0 1rem; padding:0; display:grid; gap:0.35rem;">
                                    @foreach (var root in remoteRoots)
                                    {
                                        <li class="card-note">@root</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="card-note" style="margin-top:0.35rem;">@(_radarrRemoteRoots?.Message ?? "No Radarr root folders discovered yet.")</p>
                            }
                        </div>
                        <div>
                            <p class="card-label">ACTIVE PATH MAPPING</p>
                            @if (_radarrPathMapping is not null)
                            {
                                <p class="card-note" style="margin-top:0.35rem;">Remote: @_radarrPathMapping.RemoteRootPath</p>
                                <p class="card-note" style="margin-top:0.25rem;">Local: @_radarrPathMapping.LocalRootPath</p>
                                <p class="card-note" style="margin-top:0.25rem;">Updated: @FormatTimestamp(_radarrPathMapping.UpdatedAtUtc)</p>
                                <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                    <MudButton Class="integration-action-button" ButtonType="ButtonType.Button" OnClick="OpenEditPathMappingDialogAsync">Edit mapping</MudButton>
                                    <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_testingMappingId == _radarrPathMapping.Id)" OnClick="@(() => TestPathMappingAsync(_radarrPathMapping))">
                                        @(_testingMappingId == _radarrPathMapping.Id ? "Testing mapping..." : "Test mapping")
                                    </MudButton>
                                    <MudButton Class="integration-action-button" ButtonType="ButtonType.Button" Color="Color.Error" OnClick="DeletePathMappingAsync">Delete mapping</MudButton>
                                </MudButtonGroup>
                            }
                            else
                            {
                                <p class="card-note" style="margin-top:0.35rem;">No Radarr path mapping is configured yet.</p>
                                <MudButton Class="integration-action-button" ButtonType="ButtonType.Button" OnClick="OpenCreatePathMappingDialogAsync" style="width:max-content;">Add mapping</MudButton>
                            }
                        </div>
                    </div>

                    @if (_radarrPathMappingTest is not null)
                    {
                        <div style="border-top:1px solid rgba(51,65,85,0.65); padding-top:0.75rem; display:grid; gap:0.35rem;">
                            <p class="card-label">MAPPING TEST RESULT</p>
                            <p class="card-note">Status: @(_radarrPathMappingTest.Success ? "Healthy" : "Needs attention")</p>
                            <p class="card-note">Message: @_radarrPathMappingTest.Message</p>
                            <p class="card-note">Local root exists: @FormatBool(_radarrPathMappingTest.LocalPathExists)</p>
                            <p class="card-note">Remote root matches Radarr: @FormatBool(_radarrPathMappingTest.RemotePathMatchesIntegration)</p>
                            <p class="card-note">Resolved sample file exists: @FormatBool(_radarrPathMappingTest.ResolvedLocalFileExists)</p>
                        </div>
                    }
                </div>
            }
        </section>
    }

    @if (IsSonarrPage)
    {
        <section class="card" style="margin-bottom:1rem; display:grid; gap:0.85rem;">
            <button type="button"
                    class="integration-detail-panel-toggle"
                    @onclick='() => TogglePanel("sonarr-quality-profiles")'
                    aria-expanded="@IsPanelExpanded("sonarr-quality-profiles")"
                    aria-controls="integration-detail-panel-sonarr-quality-profiles">
                <span>
                    <span class="card-label" style="display:block;">QUALITY PROFILES</span>
                    <span class="card-note" style="display:block; margin-top:0.35rem;">Choose the preferred quality profile MediaCloud should use for Sonarr-driven adds, then sync the remote MediaCloud Profile when needed.</span>
                </span>
                <span class="integration-detail-panel-chevron">@PanelChevron("sonarr-quality-profiles")</span>
            </button>

            @if (IsPanelExpanded("sonarr-quality-profiles"))
            {
                <div id="integration-detail-panel-sonarr-quality-profiles" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">
                    @if (_radarrQualityProfilesLoading && _radarrQualityProfiles is null)
                    {
                        <p class="card-note">Loading quality profiles…</p>
                    }
                    else if (_radarrQualityProfiles is null)
                    {
                        <p class="card-note">@(string.IsNullOrWhiteSpace(_radarrQualityProfilesError) ? "Sonarr quality profiles are not available yet." : _radarrQualityProfilesError)</p>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_radarrQualityProfilesError))
                        {
                            <p class="card-note" style="color:#fca5a5;">@_radarrQualityProfilesError</p>
                        }

                        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.85rem;">
                            <div>
                                <p class="card-label">AVAILABLE PROFILES</p>
                                <p class="card-note" style="margin-top:0.35rem;">@_radarrQualityProfiles.Profiles.Count profile(s) returned by Sonarr.</p>
                            </div>
                            <div>
                                <p class="card-label">PREFERRED QUALITY PROFILE</p>
                                <p class="card-note" style="margin-top:0.35rem;">@(_radarrQualityProfiles.PreferredProfileName is { Length: > 0 } preferred ? preferred : "No MediaCloud default selected yet.")</p>
                            </div>
                            <div>
                                <p class="card-label">OBSERVED ON SYNCED ITEMS</p>
                                @if (_radarrQualityProfiles.ObservedLibraryQualityProfiles.Count == 0)
                                {
                                    <p class="card-note" style="margin-top:0.35rem;">No synced Sonarr profile names have been observed yet.</p>
                                }
                                else
                                {
                                    <p class="card-note" style="margin-top:0.35rem;">@string.Join(", ", _radarrQualityProfiles.ObservedLibraryQualityProfiles)</p>
                                }
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="sonarr-preferred-quality-profile">Preferred quality profile</label>
                            <InputSelect id="sonarr-preferred-quality-profile" class="input" @bind-Value="_radarrQualityProfiles.PreferredProfileId">
                                @foreach (var profile in _radarrQualityProfiles.Profiles)
                                {
                                    <option value="@profile.Id">@profile.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrQualityProfilesSaving || _radarrQualityProfilesSyncing || _instances.FirstOrDefault() is null || _radarrQualityProfiles.Profiles.Count == 0)" OnClick="SaveSonarrQualityProfileAsync">
                                @(_radarrQualityProfilesSaving ? "Saving..." : "Save quality profile")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_radarrQualityProfilesSaving || _radarrQualityProfilesSyncing || _instances.FirstOrDefault() is null || _radarrQualityProfiles.Profiles.Count == 0)" OnClick="SyncSonarrMediaCloudProfileAsync">
                                @(_radarrQualityProfilesSyncing ? "Syncing..." : "Sync MediaCloud Profile")
                            </MudButton>
                            <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_radarrQualityProfilesLoading || _radarrQualityProfilesSyncing || _instances.FirstOrDefault() is null)" OnClick="ReloadSonarrQualityProfilesAsync">
                                @(_radarrQualityProfilesLoading ? "Refreshing..." : "Reload from Sonarr")
                            </MudButton>
                        </MudButtonGroup>
                    }
                </div>
            }
        </section>
    }

    <section class="card" style="display:grid; gap:0.85rem;">
        <button type="button"
                class="integration-detail-panel-toggle"
                @onclick='() => TogglePanel("instances")'
                aria-expanded="@IsPanelExpanded("instances")"
                aria-controls="integration-detail-panel-instances">
            <span>
                <span class="card-label" style="display:block;">SERVICE INSTANCES</span>
                <span class="card-note" style="display:block; margin-top:0.35rem;">Instance-level health, version status, and connection actions.</span>
            </span>
            <span class="integration-detail-panel-chevron">@PanelChevron("instances")</span>
        </button>

        @if (IsPanelExpanded("instances"))
        {
            <div id="integration-detail-panel-instances" class="integration-detail-panel-body" style="display:grid; gap:0.85rem;">
                @foreach (var item in _instances)
                {
                    <div class="integration-instance-card">
                        <div class="integration-instance-heading">
                            <div class="integration-instance-title-block">
                                <strong>@item.InstanceName</strong>
                                <a href="@item.BaseUrl" target="_blank" rel="noopener noreferrer" class="integration-instance-link">@item.BaseUrl</a>
                                <span class="card-note">Auth: @item.AuthType · Enabled: @(item.Enabled ? "Yes" : "No") · Mode: @(item.SupportsSync ? "Sync-backed" : "Ops-only") · Updated: @FormatTimestamp(item.UpdatedAtUtc)</span>
                            </div>
                            <span class="integration-instance-health" style="@BuildHealthPillStyle(item)">@GetHealthLabel(item)</span>
                        </div>

                        <div class="integration-instance-detail-grid">
                            <div>
                                <p class="card-label">VERSION</p>
                                <div class="integration-instance-version-row">
                                    <span>@DisplayVersionComparison(item.CurrentVersion, item.LatestReleaseVersion)</span>
                                    <span style="@BuildVersionStatusPillStyle(item.CurrentVersion, item.LatestReleaseVersion)">@GetVersionStatusLabel(item.CurrentVersion, item.LatestReleaseVersion)</span>
                                </div>
                            </div>
                            <div>
                                <p class="card-label">HEALTH</p>
                                <p style="margin:0.35rem 0 0;">Last success: @FormatTimestamp(item.LastSuccessfulAtUtc)</p>
                                <p class="card-note" style="margin-top:0.25rem;">Last attempt: @FormatTimestamp(item.LastAttemptedAtUtc)</p>
                                @if (!string.IsNullOrWhiteSpace(item.LastError))
                                {
                                    <p class="card-note" style="margin-top:0.25rem;">Error: @item.LastError</p>
                                }
                            </div>
                        </div>

                        @if (string.Equals(item.ServiceKey, "prowlarr", StringComparison.OrdinalIgnoreCase) && item.ProwlarrSummary is not null)
                        {
                            <div class="integration-prowlarr-summary-grid">
                                <div>
                                    <p class="card-label">CONFIGURED INDEXERS</p>
                                    <p style="margin:0.35rem 0 0;">@item.ProwlarrSummary.ConfiguredIndexers</p>
                                </div>
                                <div>
                                    <p class="card-label">UNAVAILABLE INDEXERS</p>
                                    <p style="margin:0.35rem 0 0;">@item.ProwlarrSummary.UnavailableIndexers</p>
                                </div>
                                <div>
                                    <p class="card-label">APPLICATION LINKS</p>
                                    <p style="margin:0.35rem 0 0;">@item.ProwlarrSummary.ApplicationLinks</p>
                                </div>
                                <div>
                                    <p class="card-label">HEALTH ISSUES</p>
                                    <p style="margin:0.35rem 0 0;">@item.ProwlarrSummary.HealthIssues</p>
                                    <p class="card-note" style="margin-top:0.25rem;">Warnings: @item.ProwlarrSummary.WarningHealthIssues · Errors: @item.ProwlarrSummary.ErrorHealthIssues</p>
                                </div>
                            </div>
                        }

                        <div class="integration-instance-actions">
                            <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                @if (item.SupportsSync)
                                {
                                    <MudButton Class="integration-action-button integration-action-button-sync" ButtonType="ButtonType.Button" Disabled="@(_syncingId == item.Id)" OnClick="@(() => SyncIntegrationAsync(item))">
                                        @(_syncingId == item.Id ? "Syncing..." : "Sync")
                                    </MudButton>
                                }
                                <MudButton Class="integration-action-button integration-action-button-secondary" ButtonType="ButtonType.Button" Disabled="@(_testingId == item.Id)" OnClick="@(() => TestIntegrationAsync(item))">
                                    @(_testingId == item.Id ? "Testing..." : "Test")
                                </MudButton>
                                <MudButton Class="integration-action-button" Href="/integrations" Color="Color.Secondary">Manage connections</MudButton>
                            </MudButtonGroup>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
}


<MudDialog Class="integration-dialog integration-path-mapping-dialog" @bind-Visible="_pathMappingDialogVisible" Options="_pathMappingDialogOptions">
    <TitleContent>
        @(_editingPathMappingId is null ? "Add mapping" : "Edit mapping")
    </TitleContent>
    <DialogContent>
        <div style="display:grid; gap:0.85rem; max-height:min(70vh, 760px); overflow-y:auto; padding-right:0.25rem;">
            <p class="card-note">Manage this integration's remote-to-local folder mapping directly from the integration page.</p>

            <div class="form-group">
                <label>Remote Root Path</label>
                @if (_radarrRemoteRoots?.Paths is { Count: > 0 } remoteRootOptions)
                {
                    <select class="input" value="@(_useCustomPathMappingRemoteRoot ? CustomRemoteRootChoice : _pathMappingForm.RemoteRootPath)" @onchange="OnPathMappingRemoteRootChoiceChanged">
                        @foreach (var root in remoteRootOptions)
                        {
                            <option value="@root">@root</option>
                        }
                        <option value="@CustomRemoteRootChoice">Custom...</option>
                    </select>
                    @if (_useCustomPathMappingRemoteRoot)
                    {
                        <InputText class="input" style="margin-top:0.45rem;" @bind-Value="_pathMappingForm.RemoteRootPath" placeholder="Enter custom remote root" />
                    }
                }
                else
                {
                    <InputText class="input" @bind-Value="_pathMappingForm.RemoteRootPath" placeholder="/movies" />
                }
            </div>

            <div class="form-group">
                <label>Local Root Path</label>
                <InputText class="input" @bind-Value="_pathMappingForm.LocalRootPath" placeholder="/Volumes/Media/Movies" />
            </div>

            <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                <MudButton ButtonType="ButtonType.Button" Disabled="@_pathMappingSaving" OnClick="SavePathMappingAsync">@(_pathMappingSaving ? "Saving..." : "Save mapping")</MudButton>
                <MudButton ButtonType="ButtonType.Button" Color="Color.Secondary" OnClick="ClosePathMappingDialog">Cancel</MudButton>
            </MudButtonGroup>
        </div>
    </DialogContent>
</MudDialog>

<MudDialog Class="integration-dialog radarr-naming-help-dialog" @bind-Visible="_radarrNamingHelpVisible" Options="_radarrNamingHelpDialogOptions">
    <TitleContent>
        Movie naming tokens
    </TitleContent>
    <DialogContent>
        <div class="radarr-naming-help-shell">
            <p class="card-note">Replicated from Radarr's movie naming help so you can format names in MediaCloud without leaving the page.</p>

            <section class="radarr-naming-help-section">
                <p class="card-label">MOVIE NAMING</p>
                <ul>
                    <li><code>{Movie Title}</code> → The Movie's Title!</li>
                    <li><code>{Movie Title:DE}</code> → Titel des Films</li>
                    <li><code>{Movie CleanTitle}</code> → The Movies Title!</li>
                    <li><code>{Movie TitleThe}</code> → Movie's Title!, The</li>
                    <li><code>{Movie OriginalTitle}</code> → Τίτλος ταινίας</li>
                    <li><code>{Movie CleanOriginalTitle}</code> → Τίτλος ταινίας</li>
                    <li><code>{Movie TitleFirstCharacter}</code> → S</li>
                    <li><code>{Movie Collection}</code> → The Movie Collection</li>
                    <li><code>{Movie Certification}</code> → R</li>
                    <li><code>{Release Year}</code> → 2009</li>
                </ul>
                <p class="card-note">CleanTitle replaces ampersands with “and”, strips slashes, and removes punctuation that is unsafe or noisy in file names.</p>
            </section>

            <section class="radarr-naming-help-section">
                <p class="card-label">MOVIE IDS</p>
                <ul>
                    <li><code>{ImdbId}</code> → tt12345</li>
                    <li><code>{Tmdbid}</code> → 123456</li>
                    <li><code>{imdb-{ImdbId}}</code> conditionally hides when the IMDb value is blank.</li>
                </ul>
            </section>

            <section class="radarr-naming-help-section">
                <p class="card-label">QUALITY</p>
                <ul>
                    <li><code>{Quality Full}</code> → HDTV 720p Proper</li>
                    <li><code>{Quality Title}</code> → HDTV 720p</li>
                </ul>
            </section>

            <section class="radarr-naming-help-section">
                <p class="card-label">MEDIA INFO</p>
                <ul>
                    <li><code>{MediaInfo Simple}</code> → x264 DTS</li>
                    <li><code>{MediaInfo Full}</code> → x264 DTS [EN+DE]</li>
                    <li><code>{MediaInfo AudioCodec}</code> → DTS</li>
                    <li><code>{MediaInfo AudioChannels}</code> → 5.1</li>
                    <li><code>{MediaInfo AudioLanguages}</code> → [EN+DE]</li>
                    <li><code>{MediaInfo SubtitleLanguages}</code> → [EN]</li>
                    <li><code>{MediaInfo VideoCodec}</code> → x264</li>
                    <li><code>{MediaInfo VideoBitDepth}</code> → 8</li>
                    <li><code>{MediaInfo VideoDynamicRange}</code> → HDR</li>
                    <li><code>{MediaInfo VideoDynamicRangeType}</code> → DV HDR10</li>
                </ul>
                <p class="card-note">Language filters like <code>:EN+DE</code> are supported for MediaInfo Full, AudioLanguages, and SubtitleLanguages. Use <code>-DE</code> to exclude a language.</p>
            </section>

            <section class="radarr-naming-help-section">
                <p class="card-label">RELEASE / EDITION / CUSTOM</p>
                <ul>
                    <li><code>{Release Group}</code> → Rls Grp</li>
                    <li><code>{Edition Tags}</code> → IMAX</li>
                    <li><code>{edition-{Edition Tags}}</code> conditionally hides when edition tags are blank.</li>
                    <li><code>{Custom Formats}</code> → Surround Sound x264</li>
                </ul>
            </section>

            <section class="radarr-naming-help-section">
                <p class="card-label">ORIGINAL</p>
                <ul>
                    <li><code>{Original Title}</code> → Movie.Title.HDTV.x264-EVOLVE</li>
                    <li><code>{Original Filename}</code> → Movie.title.hdtv.x264-EVOLVE</li>
                </ul>
                <p class="card-note">Radarr recommends Original Title over Original Filename because the literal filename may be obfuscated.</p>
            </section>

            <section class="radarr-naming-help-section">
                <p class="card-label">MOVIE FOLDER FORMAT</p>
                <p class="card-note">Folder naming uses the same movie identity tokens plus the core IDs:</p>
                <ul>
                    <li><code>{Movie Title}</code>, <code>{Movie Title:DE}</code>, <code>{Movie CleanTitle}</code></li>
                    <li><code>{Movie TitleThe}</code>, <code>{Movie OriginalTitle}</code>, <code>{Movie TitleFirstCharacter}</code></li>
                    <li><code>{Movie Collection}</code>, <code>{Movie Certification}</code>, <code>{Release Year}</code></li>
                    <li><code>{ImdbId}</code>, <code>{Tmdbid}</code></li>
                </ul>
            </section>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" Color="Color.Secondary" OnClick="CloseRadarrNamingHelp">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .integration-detail-panel-toggle {
        width: 100%;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.85rem;
        padding: 0;
        border: 0;
        background: transparent;
        color: inherit;
        text-align: left;
        cursor: pointer;
    }

    .integration-detail-panel-toggle:hover .integration-detail-panel-chevron,
    .integration-detail-panel-toggle:focus-visible .integration-detail-panel-chevron {
        color: #e2e8f0;
    }

