    private async Task BulkSyncSelectedLibraryItemsToRadarrAsync()
    {
        var rows = VisibleRadarrSearchRetryRows
            .Where(x => _selectedRadarrSearchRetryLibraryItemIds.Contains(x.LibraryItemId) && x.MissingRadarr && x.CanBackfill)
            .ToList();
        if (rows.Count == 0)
        {
            _radarrSearchRetryStatus = "No selected rows are eligible to add to Radarr.";
            Snackbar.Add(_radarrSearchRetryStatus, Severity.Warning);
            return;
        }

        foreach (var row in rows)
        {
            await SyncLibraryItemToRadarrAsync(row);
        }

        _radarrSearchRetryStatus = $"Processed bulk add for {rows.Count} Radarr candidate(s).";
        Snackbar.Add(_radarrSearchRetryStatus, Severity.Success);
    }

    private async Task BulkRunRadarrSearchReplacementAsync()
    {
        var rows = VisibleRadarrSearchRetryRows
            .Where(x => _selectedRadarrSearchRetryLibraryItemIds.Contains(x.LibraryItemId) && !x.MissingRadarr)
            .ToList();
        if (rows.Count == 0)
        {
            _radarrSearchRetryStatus = "No selected rows are eligible for Radarr retry search.";
            Snackbar.Add(_radarrSearchRetryStatus, Severity.Warning);
            return;
        }

        foreach (var row in rows)
        {
            await RunRadarrSearchReplacementAsync(row);
        }

        _radarrSearchRetryStatus = $"Queued bulk retry search for {rows.Count} Radarr item(s).";
        Snackbar.Add(_radarrSearchRetryStatus, Severity.Success);
    }

