    {
        _loading = true;
        _loadError = string.Empty;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/integrations");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _loadError = $"Failed to load integrations ({(int)response.StatusCode}).";
                return;
            }

            var items = await response.Content.ReadFromJsonAsync<List<IntegrationInstanceResponse>>() ?? [];
            _instances.Clear();
            _instances.AddRange(items.Where(x => string.Equals(x.ServiceKey, NormalizedServiceKey, StringComparison.OrdinalIgnoreCase)));
        }
        catch
        {
            _loadError = "Failed to load integrations.";
        }
        finally
        {
            _loading = false;
