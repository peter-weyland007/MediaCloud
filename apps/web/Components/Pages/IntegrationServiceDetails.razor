    private void ToggleSelectAllRadarrSearchRetryRows(ChangeEventArgs args)
    {
        var isChecked = args.Value switch
        {
            bool value => value,
            string value when bool.TryParse(value, out var parsed) => parsed,
            _ => false
        };

        foreach (var row in VisibleRadarrSearchRetryRows.Where(CanBulkOperateOnRadarrSearchRetryRow))
