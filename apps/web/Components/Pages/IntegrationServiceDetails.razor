    private async Task SyncLibraryItemToRadarrAsync(PlexBackfillCandidateDto row)
    {
        _radarrSyncingLibraryItemIds.Add(row.LibraryItemId);
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post,
                LibraryItemRadarrSourceSyncEndpointTemplate.Replace("{libraryItemId}", row.LibraryItemId.ToString()));
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _radarrSearchRetryStatus = $"Add to Radarr failed for {row.Title} ({(int)response.StatusCode}).";
                Snackbar.Add(_radarrSearchRetryStatus, Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LibraryItemSourceSyncResponse>();
            _radarrSearchRetryStatus = payload?.Message ?? $"Radarr sync completed for {row.Title}.";
            Snackbar.Add(_radarrSearchRetryStatus, payload?.Success == true ? Severity.Success : Severity.Warning);
            await LoadRadarrDriftPreviewAsync();
        }
        catch
        {
            _radarrSearchRetryStatus = $"Add to Radarr failed for {row.Title}.";
            Snackbar.Add(_radarrSearchRetryStatus, Severity.Error);
        }
        finally
        {
            _radarrSyncingLibraryItemIds.Remove(row.LibraryItemId);
        }
    }

    private async Task RunRadarrSearchReplacementAsync(PlexBackfillCandidateDto row)
    {
        _radarrSearchingLibraryItemIds.Add(row.LibraryItemId);
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post,
                LibraryItemSearchReplacementEndpointTemplate.Replace("{libraryItemId}", row.LibraryItemId.ToString()))
            {
                Content = JsonContent.Create(new SearchReplacementRequest("manual_operator_retry", "Triggered from the Radarr integration detail page.", "manual_retry"))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _radarrSearchRetryStatus = $"Retry search failed for {row.Title} ({(int)response.StatusCode}).";
                Snackbar.Add(_radarrSearchRetryStatus, Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LibraryItemRemediationResponse>();
            _radarrSearchRetryStatus = payload?.Message ?? $"Queued Radarr search for {row.Title}.";
            Snackbar.Add(_radarrSearchRetryStatus, payload?.Success == true ? Severity.Success : Severity.Warning);
        }
        catch
        {
            _radarrSearchRetryStatus = $"Retry search failed for {row.Title}.";
            Snackbar.Add(_radarrSearchRetryStatus, Severity.Error);
        }
        finally
        {
            _radarrSearchingLibraryItemIds.Remove(row.LibraryItemId);
        }
    }

