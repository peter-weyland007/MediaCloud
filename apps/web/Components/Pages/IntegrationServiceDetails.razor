        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .integration-detail-panel-header .integration-detail-panel-toggle {
        flex: 1 1 auto;
        justify-content: flex-start;
    }

    .integration-detail-panel-actions {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-left: auto;
    }

