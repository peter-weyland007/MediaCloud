@page "/settings/libraries"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar
@using System.IO

<PageTitle>Library Paths</PageTitle>

<h1>Library Paths</h1>
<p class="subtitle"><a href="/settings">Settings</a> / Library Paths</p>
<p class="subtitle">Manage physical library path mappings separately from integrations.</p>

<div class="card" style="max-width:900px; margin-bottom:1rem;">
    <h2 style="margin-top:0;">Add mapping</h2>
    <div class="form-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        <div class="form-group" style="grid-column:1 / -1;">
            <label>Integration</label>
            <select class="input" value="@_form.IntegrationId" @onchange="OnIntegrationChangedAsync">
                <option value="0">Select integration…</option>
                @foreach (var i in _integrations)
                {
                    <option value="@i.Id">@i.DisplayName / @i.InstanceName (@i.ServiceKey)</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Remote Root Path</label>
            @if (_remoteRootSuggestions.Count > 0)
            {
                <select class="input" value="@(UseCustomRemoteRoot ? CustomRemoteChoice : _form.RemoteRootPath)" @onchange="OnRemoteRootChoiceChanged">
                    @foreach (var path in _remoteRootSuggestions)
                    {
                        <option value="@path">@path</option>
                    }
                    <option value="@CustomRemoteChoice">Custom...</option>
                </select>
                @if (UseCustomRemoteRoot)
                {
                    <InputText class="input" style="margin-top:0.45rem;" @bind-Value="_form.RemoteRootPath" placeholder="Enter custom remote root" />
                }
            }
            else
            {
                <InputText class="input" @bind-Value="_form.RemoteRootPath" />
            }

            @if (_loadingRemoteRoots)
            {
                <p class="card-note" style="margin-top:0.35rem;">Loading remote roots from integration…</p>
            }
            else if (!string.IsNullOrWhiteSpace(_remoteRootMessage))
            {
                <p class="card-note" style="margin-top:0.35rem;">@_remoteRootMessage</p>
            }
            else
            {
                <p class="card-note" style="margin-top:0.35rem;">Example: /movies</p>
            }
        </div>
        <div class="form-group">
            <label>Local Root Path</label>
            <div style="display:flex; gap:0.45rem; align-items:center;">
                <InputText class="input" style="flex:1;" @bind-Value="_form.LocalRootPath" />
                <button type="button" class="button-secondary" @onclick="OpenLocalBrowserAsync" disabled="@_loadingLocalDirectories">Browse</button>
            </div>
            <p class="card-note" style="margin-top:0.35rem;">Example: /Volumes/Media/Movies</p>
        </div>
    </div>

    @if (_showLocalBrowser)
    {
        <div class="card" style="margin-top:0.85rem; background:#0b1220; border:1px solid #1e293b;">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:0.5rem;">
                <p class="card-label" style="margin:0;">LOCAL FOLDER BROWSER</p>
                <button type="button" class="button-secondary" @onclick="CloseLocalBrowser">Close</button>
            </div>
            <p style="margin:0.5rem 0; font-family:monospace;">@_localBrowsePath</p>
            <div style="display:flex; gap:0.45rem; margin-bottom:0.65rem;">
                <button type="button" class="button-secondary" @onclick="NavigateLocalParentAsync" disabled="@string.IsNullOrWhiteSpace(_localBrowseParent)">Up</button>
                <button type="button" class="button-primary" @onclick="UseCurrentLocalDirectory">Use this folder</button>
            </div>
            @if (_loadingLocalDirectories)
            {
                <p class="card-note">Loading folders…</p>
            }
            else if (!string.IsNullOrWhiteSpace(_localBrowseError))
            {
                <p class="error-text">@_localBrowseError</p>
            }
            else if (_localBrowseDirectories.Count == 0)
            {
                <p class="card-note">No subfolders in this location.</p>
            }
            else
            {
                <div style="max-height:220px; overflow:auto; display:grid; gap:0.35rem;">
                    @foreach (var dir in _localBrowseDirectories)
                    {
                        <button type="button" class="button-secondary" style="text-align:left;" @onclick="() => NavigateLocalDirectoryAsync(dir)">@dir</button>
                    }
                </div>
            }
        </div>
    }

    <div style="display:flex; gap:0.5rem; margin-top:0.85rem;">
        <button class="button-primary" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Saving..." : (_editingId is null ? "Add mapping" : "Save mapping"))</button>
        <button class="button-secondary" @onclick="ResetForm">Clear</button>
    </div>
</div>

<div class="card" style="max-width:1100px;">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:0.6rem; flex-wrap:wrap;">
        <h2 style="margin:0;">Current mappings</h2>
        <button class="button-secondary" @onclick="ReprobeMissingRuntimesAsync" disabled="@_reprobingMissingRuntimes">@(_reprobingMissingRuntimes ? "Reprobing..." : "Reprobe missing runtimes")</button>
    </div>
    @if (!string.IsNullOrWhiteSpace(_mappingTestSummary))
    {
        <div style="margin-top:0.4rem; padding:0.65rem 0.8rem; border-radius:0.5rem; border:1px solid @(_mappingTestSuccess ? "#14532d" : "#7f1d1d"); background:@(_mappingTestSuccess ? "#052e16" : "#450a0a");">
            <p class="@(_mappingTestSuccess ? "success-text" : "error-text")" style="margin:0; font-weight:600;">@_mappingTestSummary</p>
            @if (_mappingTestDeepAttempted)
            {
                <div style="margin-top:0.5rem; display:grid; gap:0.35rem; font-size:0.92rem;">
                    <div><strong>Sample source:</strong> <code style="word-break:break-all;">@_mappingTestSourcePath</code></div>
                    <div><strong>Resolved local:</strong> <code style="word-break:break-all;">@_mappingTestResolvedPath</code></div>
                    <div><strong>Resolved file exists:</strong> @(_mappingTestResolvedExists ? "yes" : "no")</div>
                </div>
            }
        </div>
    }
    @if (_loading)
    {
        <p class="card-note">Loading mappings…</p>
    }
    else if (_mappings.Count == 0)
    {
        <p class="card-note">No mappings configured yet.</p>
    }
    else
    {
        <table class="data-table" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr>
                    <th style="text-align:left;">Integration</th>
                    <th style="text-align:left;">Remote Root</th>
                    <th style="text-align:left;">Local Root</th>
                    <th style="text-align:left;">Updated</th>
                    <th style="text-align:left;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in _mappings)
                {
                    <tr>
                        <td>@m.DisplayName / @m.InstanceName (@m.ServiceKey)</td>
                        <td>@m.RemoteRootPath</td>
                        <td>@m.LocalRootPath</td>
                        <td>@m.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td style="display:flex; gap:0.4rem; flex-wrap:wrap;">
                            <button class="button-secondary" @onclick="async () => await TestMappingAsync(m)">Test</button>
                            <button class="button-secondary" @onclick="async () => await LoadForEditAsync(m)">Edit</button>
                            <button class="button-danger" @onclick="() => DeleteAsync(m)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private const string CustomRemoteChoice = "__custom__";

    private bool _loading = true;
    private bool _saving;
    private bool _reprobingMissingRuntimes;
    private bool _loadingRemoteRoots;
    private bool _showLocalBrowser;
    private bool _loadingLocalDirectories;
    private bool UseCustomRemoteRoot = true;
    private string _remoteRootMessage = string.Empty;
    private string _mappingTestSummary = string.Empty;
    private bool _mappingTestSuccess;
    private bool _mappingTestDeepAttempted;
    private bool _mappingTestResolvedExists;
    private string _mappingTestSourcePath = string.Empty;
    private string _mappingTestResolvedPath = string.Empty;
    private string _localBrowsePath = string.Empty;
    private string _localBrowseParent = string.Empty;
    private string _localBrowseError = string.Empty;
    private long? _editingId;
    private readonly MappingForm _form = new();
    private readonly List<IntegrationInstanceResponse> _integrations = [];
    private readonly List<LibraryPathMappingResponse> _mappings = [];
    private readonly List<string> _remoteRootSuggestions = [];
    private readonly List<string> _localBrowseDirectories = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            await LoadIntegrationsAsync();
            await LoadMappingsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadIntegrationsAsync()
    {
        using var request = new HttpRequestMessage(HttpMethod.Get, "/api/integrations");
        await AttachBearerAsync(request);
        using var response = await Http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add("Failed to load integrations.", Severity.Error);
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<List<IntegrationInstanceResponse>>() ?? [];
        _integrations.Clear();
        _integrations.AddRange(payload);
    }

    private async Task LoadMappingsAsync()
    {
        using var request = new HttpRequestMessage(HttpMethod.Get, "/api/library-path-mappings");
        await AttachBearerAsync(request);
        using var response = await Http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add("Failed to load library path mappings.", Severity.Error);
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<List<LibraryPathMappingResponse>>() ?? [];
        _mappings.Clear();
        _mappings.AddRange(payload.OrderBy(x => x.ServiceKey).ThenBy(x => x.InstanceName));
    }

    private async Task LoadForEditAsync(LibraryPathMappingResponse mapping)
    {
        _editingId = mapping.Id;
        _form.IntegrationId = mapping.IntegrationId;
        _form.RemoteRootPath = mapping.RemoteRootPath;
        _form.LocalRootPath = mapping.LocalRootPath;
        await LoadRemoteRootsAsync(mapping.IntegrationId, keepExistingValue: true);
    }

    private async Task OnIntegrationChangedAsync(ChangeEventArgs args)
    {
        if (!long.TryParse(args.Value?.ToString(), out var integrationId))
        {
            integrationId = 0;
        }

        _form.IntegrationId = integrationId;
        _editingId = null;
        await LoadRemoteRootsAsync(integrationId, keepExistingValue: false);
    }

    private async Task LoadRemoteRootsAsync(long integrationId, bool keepExistingValue)
    {
        _remoteRootSuggestions.Clear();
        _remoteRootMessage = string.Empty;
        UseCustomRemoteRoot = true;

        if (integrationId <= 0)
        {
            if (!keepExistingValue)
            {
                _form.RemoteRootPath = string.Empty;
            }
            return;
        }

        _loadingRemoteRoots = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/integrations/{integrationId}/remote-roots");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _remoteRootMessage = $"Unable to load remote roots ({(int)response.StatusCode}).";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<IntegrationRemoteRootsResponse>();
            var roots = payload?.Paths?.Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x.Trim()).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? [];
            _remoteRootSuggestions.AddRange(roots);
            _remoteRootMessage = payload?.Message ?? string.Empty;

            if (_remoteRootSuggestions.Count == 0)
            {
                if (!keepExistingValue)
                {
                    _form.RemoteRootPath = string.Empty;
                }
                UseCustomRemoteRoot = true;
                return;
            }

            if (keepExistingValue && _remoteRootSuggestions.Any(x => string.Equals(x, _form.RemoteRootPath, StringComparison.OrdinalIgnoreCase)))
            {
                UseCustomRemoteRoot = false;
                return;
            }

            if (!keepExistingValue)
            {
                _form.RemoteRootPath = _remoteRootSuggestions[0];
                UseCustomRemoteRoot = false;
                return;
            }

            UseCustomRemoteRoot = true;
        }
        catch
        {
            _remoteRootMessage = "Failed to load remote roots from selected integration.";
        }
        finally
        {
            _loadingRemoteRoots = false;
        }
    }

    private void OnRemoteRootChoiceChanged(ChangeEventArgs args)
    {
        var selected = args.Value?.ToString() ?? string.Empty;
        if (string.Equals(selected, CustomRemoteChoice, StringComparison.Ordinal))
        {
            UseCustomRemoteRoot = true;
            return;
        }

        UseCustomRemoteRoot = false;
        _form.RemoteRootPath = selected;
    }

    private async Task OpenLocalBrowserAsync()
    {
        _showLocalBrowser = true;
        var startPath = !string.IsNullOrWhiteSpace(_form.LocalRootPath)
            ? _form.LocalRootPath.Trim()
            : string.Empty;
        await LoadLocalDirectoriesAsync(startPath);
    }

    private void CloseLocalBrowser() => _showLocalBrowser = false;

    private async Task NavigateLocalParentAsync()
    {
        if (string.IsNullOrWhiteSpace(_localBrowseParent))
        {
            return;
        }

        await LoadLocalDirectoriesAsync(_localBrowseParent);
    }

    private async Task NavigateLocalDirectoryAsync(string childDirectoryName)
    {
        var nextPath = string.IsNullOrWhiteSpace(_localBrowsePath)
            ? childDirectoryName
            : Path.Combine(_localBrowsePath, childDirectoryName);
        await LoadLocalDirectoriesAsync(nextPath);
    }

    private void UseCurrentLocalDirectory()
    {
        if (string.IsNullOrWhiteSpace(_localBrowsePath))
        {
            return;
        }

        _form.LocalRootPath = _localBrowsePath;
        _showLocalBrowser = false;
    }

    private async Task LoadLocalDirectoriesAsync(string path)
    {
        _loadingLocalDirectories = true;
        _localBrowseError = string.Empty;
        try
        {
            var uri = string.IsNullOrWhiteSpace(path)
                ? "/api/system/local-directories"
                : $"/api/system/local-directories?path={Uri.EscapeDataString(path)}";

            using var request = new HttpRequestMessage(HttpMethod.Get, uri);
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _localBrowseError = $"Unable to browse local directories ({(int)response.StatusCode}).";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<LocalDirectoryBrowseResponse>();
            if (payload is null)
            {
                _localBrowseError = "Directory browser returned no payload.";
                return;
            }

            _localBrowsePath = payload.Path ?? string.Empty;
            _localBrowseParent = payload.ParentPath ?? string.Empty;
            _localBrowseDirectories.Clear();
            _localBrowseDirectories.AddRange(payload.Directories ?? []);
        }
        catch
        {
            _localBrowseError = "Failed to browse local directories.";
        }
        finally
        {
            _loadingLocalDirectories = false;
        }
    }

    private async Task SaveAsync()
    {
        if (!ValidateForm())
        {
            return;
        }

        _saving = true;
        try
        {
            if (_editingId is null)
            {
                var body = new CreateLibraryPathMappingRequest(_form.IntegrationId, _form.RemoteRootPath.Trim(), _form.LocalRootPath.Trim());
                using var request = new HttpRequestMessage(HttpMethod.Post, "/api/library-path-mappings")
                {
                    Content = JsonContent.Create(body)
                };
                await AttachBearerAsync(request);
                using var response = await Http.SendAsync(request);
                if (!response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Failed to add mapping ({(int)response.StatusCode}).", Severity.Error);
                    return;
                }
                Snackbar.Add("Library path mapping added.", Severity.Success);
            }
            else
            {
                var body = new UpdateLibraryPathMappingRequest(_form.RemoteRootPath.Trim(), _form.LocalRootPath.Trim());
                using var request = new HttpRequestMessage(HttpMethod.Put, $"/api/library-path-mappings/{_editingId.Value}")
                {
                    Content = JsonContent.Create(body)
                };
                await AttachBearerAsync(request);
                using var response = await Http.SendAsync(request);
                if (!response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Failed to update mapping ({(int)response.StatusCode}).", Severity.Error);
                    return;
                }
                Snackbar.Add("Library path mapping updated.", Severity.Success);
            }

            ResetForm();
            await LoadMappingsAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync(LibraryPathMappingResponse mapping)
    {
        using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/library-path-mappings/{mapping.Id}");
        await AttachBearerAsync(request);
        using var response = await Http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Failed to delete mapping ({(int)response.StatusCode}).", Severity.Error);
            return;
        }

        Snackbar.Add("Library path mapping deleted.", Severity.Success);
        if (_editingId == mapping.Id)
        {
            ResetForm();
        }
        await LoadMappingsAsync();
    }

    private async Task TestMappingAsync(LibraryPathMappingResponse mapping)
    {
        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/library-path-mappings/{mapping.Id}/test");
        await AttachBearerAsync(request);
        using var response = await Http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            _mappingTestSuccess = false;
            _mappingTestSummary = $"Mapping test failed ({(int)response.StatusCode}).";
            _mappingTestDeepAttempted = false;
            _mappingTestSourcePath = string.Empty;
            _mappingTestResolvedPath = string.Empty;
            _mappingTestResolvedExists = false;
            Snackbar.Add(_mappingTestSummary, Severity.Error);
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<LibraryPathMappingTestResponse>();
        if (payload is null)
        {
            _mappingTestSuccess = false;
            _mappingTestSummary = "Mapping test returned no message.";
            _mappingTestDeepAttempted = false;
            _mappingTestSourcePath = string.Empty;
            _mappingTestResolvedPath = string.Empty;
            _mappingTestResolvedExists = false;
            Snackbar.Add(_mappingTestSummary, Severity.Warning);
            return;
        }

        _mappingTestSuccess = payload.Success;
        _mappingTestSummary = payload.Message;
        _mappingTestDeepAttempted = payload.DeepTestAttempted;
        _mappingTestSourcePath = string.IsNullOrWhiteSpace(payload.SourceFilePath) ? "(none)" : payload.SourceFilePath;
        _mappingTestResolvedPath = string.IsNullOrWhiteSpace(payload.ResolvedLocalFilePath) ? "(none)" : payload.ResolvedLocalFilePath;
        _mappingTestResolvedExists = payload.ResolvedLocalFileExists;

        var snackbarMessage = payload.Success
            ? (payload.DeepTestAttempted ? "Mapping test passed. Deep file check passed." : "Mapping test passed.")
            : (payload.DeepTestAttempted ? "Mapping test failed. Deep file check failed." : "Mapping test failed.");

        Snackbar.Add(snackbarMessage, _mappingTestSuccess ? Severity.Success : Severity.Warning);
    }

    private async Task ReprobeMissingRuntimesAsync()
    {
        _reprobingMissingRuntimes = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/library/items/reprobe-missing-runtimes")
            {
                Content = JsonContent.Create(new BatchRuntimeReprobeRequest("Movie", 500))
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Reprobe failed ({(int)response.StatusCode}). Admin access may be required.", Severity.Error);
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<BatchRuntimeReprobeResponse>();
            if (payload is null)
            {
                Snackbar.Add("Reprobe completed with no result payload.", Severity.Warning);
                return;
            }

            Snackbar.Add($"Reprobe done: updated {payload.Updated}/{payload.Inspected}, missing files {payload.MissingFiles}, probe failures {payload.Failed}.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Reprobe failed.", Severity.Error);
        }
        finally
        {
            _reprobingMissingRuntimes = false;
        }
    }

    private bool ValidateForm()
    {
        if (_form.IntegrationId <= 0)
        {
            Snackbar.Add("Select an integration instance.", Severity.Warning);
            return false;
        }

        var remote = (_form.RemoteRootPath ?? string.Empty).Trim();
        var local = (_form.LocalRootPath ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(remote) || string.IsNullOrWhiteSpace(local))
        {
            Snackbar.Add("Remote and local root paths are required.", Severity.Warning);
            return false;
        }

        if (!local.StartsWith('/'))
        {
            Snackbar.Add("Local root path must be absolute.", Severity.Warning);
            return false;
        }

        if (!remote.StartsWith('/') && !remote.StartsWith('\\'))
        {
            Snackbar.Add("Remote root path must start with '/' or '\\'.", Severity.Warning);
            return false;
        }

        return true;
    }

    private void ResetForm()
    {
        _editingId = null;
        _form.IntegrationId = 0;
        _form.RemoteRootPath = string.Empty;
        _form.LocalRootPath = string.Empty;
        _remoteRootSuggestions.Clear();
        _remoteRootMessage = string.Empty;
        _mappingTestSummary = string.Empty;
        _mappingTestSuccess = false;
        _mappingTestDeepAttempted = false;
        _mappingTestResolvedExists = false;
        _mappingTestSourcePath = string.Empty;
        _mappingTestResolvedPath = string.Empty;
        UseCustomRemoteRoot = true;
        _showLocalBrowser = false;
        _localBrowsePath = string.Empty;
        _localBrowseParent = string.Empty;
        _localBrowseError = string.Empty;
        _localBrowseDirectories.Clear();
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private sealed class MappingForm
    {
        public long IntegrationId { get; set; }
        public string RemoteRootPath { get; set; } = string.Empty;
        public string LocalRootPath { get; set; } = string.Empty;
    }

    private sealed record BatchRuntimeReprobeRequest(string? MediaType, int Take = 200);
    private sealed record BatchRuntimeReprobeResponse(int Inspected, int Attempted, int Updated, int MissingFiles, int Failed);
}
