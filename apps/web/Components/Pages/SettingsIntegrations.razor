            "Attention needed" => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(185,28,28,0.28); color:#fecaca; border:1px solid rgba(248,113,113,0.55); font-size:0.78rem; font-weight:800;",
            _ => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(30,41,59,0.6); color:#cbd5e1; border:1px solid rgba(71,85,105,0.75); font-size:0.78rem; font-weight:800;"
