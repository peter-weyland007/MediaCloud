    private sealed record ServiceIntegrationGroup(
        string ServiceKey,
        string DisplayName,
        string RoleSummary,
        IReadOnlyList<IntegrationInstanceResponse> Items,
        int HealthyCount,
        int OperationalCount,
        int AttentionNeededCount,
        DateTimeOffset? LastSuccessfulAtUtc);

