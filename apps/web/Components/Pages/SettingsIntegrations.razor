@page "/settings/integrations"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar

<PageTitle>Integrations</PageTitle>

<p class="subtitle"><a href="/settings">Settings</a> / Integrations</p>
<h1>Integrations</h1>
<p class="subtitle">Manage named service instances, health, and sync actions from one control plane.</p>

<div class="card" style="margin-bottom: 1rem; display:grid; gap:0.85rem;">
    <p class="card-label">CONTROL PLANE SUMMARY</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:0.85rem;">
        <div>
            <p class="card-label">Configured</p>
            <p style="margin:0.35rem 0 0;">@_instances.Count</p>
        </div>
        <div>
            <p class="card-label">Enabled</p>
            <p style="margin:0.35rem 0 0;">@EnabledInstanceCount()</p>
        </div>
        <div>
            <p class="card-label">Attention needed</p>
            <p style="margin:0.35rem 0 0;">@AttentionNeededCount()</p>
        </div>
        <div>
            <p class="card-label">Prowlarr</p>
            <p style="margin:0.35rem 0 0;">@ProwlarrInstanceCount() instance(s)</p>
        </div>
    </div>
</div>

<div class="card" style="margin-bottom: 1rem;">
    <p class="card-label">@(_editingId is null ? "ADD INTEGRATION INSTANCE" : "EDIT INTEGRATION INSTANCE")</p>

    <EditForm Model="_form" FormName="integration-form" OnValidSubmit="SaveIntegrationAsync">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="integration-service">Service</label>
            <InputSelect id="integration-service" class="input" @bind-Value="_form.ServiceKey" disabled="@(_editingId is not null)">
                @foreach (var service in _services)
                {
                    <option value="@service.ServiceKey">@service.DisplayName</option>
                }
            </InputSelect>
        </div>

        <div class="form-group">
            <label for="integration-instance-name">Instance Name</label>
            <InputText id="integration-instance-name" class="input" @bind-Value="_form.InstanceName" />
            @if (ShowDuplicateInstanceValidationError())
            {
                <p class="error-text" style="margin-top:0.35rem;">An instance with this service + name already exists.</p>
            }
            else if (ShouldShowInstanceAvailabilityHint())
            {
                <p class="success-text" style="margin-top:0.35rem;">Instance name is available for this service.</p>
            }
        </div>

        <div class="form-group">
            <label for="integration-base-url">Base URL</label>
            <InputText id="integration-base-url" class="input" @bind-Value="_form.BaseUrl" />
            @if (ShowBaseUrlValidationError())
            {
                <p class="error-text" style="margin-top:0.35rem;">Base URL must be a valid absolute URL (e.g. http://localhost:7878).</p>
            }
        </div>

        <div class="form-group">
            <label for="integration-auth-type">Authentication</label>
            <InputSelect id="integration-auth-type" class="input" @bind-Value="_form.AuthType">
                @foreach (var auth in GetAuthOptions())
                {
                    <option value="@auth">@GetAuthLabel(auth)</option>
                }
            </InputSelect>
        </div>

        @if (IsAuthSelectionInvalid())
        {
            <p class="error-text" style="margin-top:-0.35rem; margin-bottom:0.6rem;">This service requires credentials. Select API Key/Token or Username + Password.</p>
        }

        @if (_form.AuthType == "ApiKey")
        {
            <div class="form-group">
                <label for="integration-api-key">API Key / Token</label>
                <InputText id="integration-api-key" class="input" @bind-Value="_form.ApiKey" />
                @if (ShowApiKeyValidationError())
                {
                    <p class="error-text" style="margin-top:0.35rem;">API key/token is required for API key authentication.</p>
                }
            </div>
        }
        else if (_form.AuthType == "Basic")
        {
            <div class="form-group">
                <label for="integration-username">Username</label>
                <InputText id="integration-username" class="input" @bind-Value="_form.Username" />
                @if (ShowBasicUsernameValidationError())
                {
                    <p class="error-text" style="margin-top:0.35rem;">Username is required for basic authentication.</p>
                }
            </div>
            <div class="form-group">
                <label for="integration-password">Password</label>
                <InputText id="integration-password" type="password" class="input" @bind-Value="_form.Password" />
                @if (ShowBasicPasswordValidationError())
                {
                    <p class="error-text" style="margin-top:0.35rem;">Password is required for basic authentication.</p>
                }
            </div>
        }

        <div style="display:flex; align-items:center; gap:0.55rem; margin-bottom:0.75rem;">
            <InputCheckbox id="integration-enabled" @bind-Value="_form.Enabled" />
            <label for="integration-enabled" style="margin:0;">Enabled</label>
        </div>

        <div style="display:flex; gap:0.5rem;">
            <button class="button-primary" disabled="@_saving">@(_saving ? "Saving..." : (_editingId is null ? "Add instance" : "Save changes"))</button>
            @if (_editingId is not null)
            {
                <button class="button-primary" type="button" style="background:#334155; border-color:#334155;" @onclick="ResetForm">Cancel edit</button>
            }
        </div>
    </EditForm>
</div>

<div class="card" style="margin-bottom: 1rem; display:grid; gap:0.85rem;">
    <p class="card-label">INTEGRATION PANELS</p>

    @if (_loading)
    {
        <p class="card-note">Loading integration instances…</p>
    }
    else if (_instances.Count == 0)
    {
        <p class="card-note">No integration instances configured yet.</p>
    }
    else
    {
        @foreach (var group in GroupInstancesByService())
        {
            <section class="integration-service-panel card">
                <button type="button"
                        class="integration-service-toggle"
                        @onclick='() => ToggleServicePanel(group.ServiceKey)'
                        aria-expanded="@IsServicePanelExpanded(group.ServiceKey)"
                        aria-controls="@($"integration-panel-{group.ServiceKey}")">
                    <span class="integration-service-summary-shell">
                        <span class="integration-service-summary-grid">
                            <span class="integration-service-identity-row">
                                <span class="integration-service-monogram">@GetServiceMonogram(group.DisplayName)</span>
                                <span class="integration-service-title-block">
                                    <span class="card-label">SERVICE PANEL</span>
                                    <span class="integration-service-title">@group.DisplayName</span>
                                    <span class="integration-service-role">@DisplayRoleSummary(group.RoleSummary)</span>
                                </span>
                            </span>
                            <span class="integration-service-status-cluster">
                                <span class="integration-service-status" style="@BuildGroupHealthPillStyle(group)">@GetGroupHealthLabel(group)</span>
                                <span class="integration-service-chevron">@(IsServicePanelExpanded(group.ServiceKey) ? "▾" : "▸")</span>
                            </span>
                        </span>
                        <span class="integration-service-metrics">
                            <span class="integration-service-metric-chip">@group.Items.Count instance(s)</span>
                            <span class="integration-service-metric-chip">Healthy: @group.HealthyCount</span>
                            <span class="integration-service-metric-chip">Attention needed: @group.AttentionNeededCount</span>
                        </span>
                    </span>
                </button>

                @if (IsServicePanelExpanded(group.ServiceKey))
                {
                    <div id="@($"integration-panel-{group.ServiceKey}")" class="integration-service-panel-body">
                        @if (string.Equals(group.ServiceKey, "prowlarr", StringComparison.OrdinalIgnoreCase))
                        {
                            var prowlarrSummary = group.Items.Select(item => item.ProwlarrSummary).FirstOrDefault(item => item is not null);
                            <div class="integration-prowlarr-summary-grid">
                                <div>
                                    <p class="card-label">PROWLARR DETAIL</p>
                                    <p style="margin:0.35rem 0 0;">Indexer control plane + search source orchestration</p>
                                </div>
                                <div>
                                    <p class="card-label">Configured indexers</p>
                                    <p style="margin:0.35rem 0 0;">@(prowlarrSummary?.ConfiguredIndexers ?? 0)</p>
                                </div>
                                <div>
                                    <p class="card-label">Unavailable indexers</p>
                                    <p style="margin:0.35rem 0 0;">@(prowlarrSummary?.UnavailableIndexers ?? 0)</p>
                                </div>
                                <div>
                                    <p class="card-label">Application links</p>
                                    <p style="margin:0.35rem 0 0;">@(prowlarrSummary?.ApplicationLinks ?? 0)</p>
                                </div>
                                <div>
                                    <p class="card-label">Health issues</p>
                                    <p style="margin:0.35rem 0 0;">@(prowlarrSummary?.HealthIssues ?? 0)</p>
                                    <p class="card-note" style="margin-top:0.25rem;">Warnings: @(prowlarrSummary?.WarningHealthIssues ?? 0) · Errors: @(prowlarrSummary?.ErrorHealthIssues ?? 0)</p>
                                </div>
                                <div>
                                    <p class="card-label">Last success</p>
                                    <p style="margin:0.35rem 0 0;">@FormatTimestamp(group.LastSuccessfulAtUtc)</p>
                                </div>
                            </div>
                        }

                        <div class="integration-instance-list">
                            @foreach (var item in group.Items)
                            {
                                <div class="integration-instance-card">
                                    <div class="integration-instance-heading">
                                        <div class="integration-instance-title-block">
                                            <strong>@item.InstanceName</strong>
                                            <a href="@item.BaseUrl" target="_blank" rel="noopener noreferrer" class="integration-instance-link">@item.BaseUrl</a>
                                            <span class="card-note">Auth: @item.AuthType · Enabled: @(item.Enabled ? "Yes" : "No") · Mode: @(item.SupportsSync ? "Sync-backed" : "Ops-only") · Updated: @FormatTimestamp(item.UpdatedAtUtc)</span>
                                        </div>
                                        <span class="integration-instance-health" style="@BuildHealthPillStyle(item)">@GetHealthLabel(item)</span>
                                    </div>

                                    <div class="integration-instance-detail-grid">
                                        <div>
                                            <p class="card-label">VERSION</p>
                                            <div class="integration-instance-version-row">
                                                <span>@DisplayVersionComparison(item.CurrentVersion, item.LatestReleaseVersion)</span>
                                                <span style="@BuildVersionStatusPillStyle(item.CurrentVersion, item.LatestReleaseVersion)">@GetVersionStatusLabel(item.CurrentVersion, item.LatestReleaseVersion)</span>
                                            </div>
                                        </div>
                                        <div>
                                            <p class="card-label">HEALTH</p>
                                            <p style="margin:0.35rem 0 0;">Last success: @FormatTimestamp(item.LastSuccessfulAtUtc)</p>
                                            <p class="card-note" style="margin-top:0.25rem;">Last attempt: @FormatTimestamp(item.LastAttemptedAtUtc)</p>
                                            @if (!string.IsNullOrWhiteSpace(item.LastError) && item.SupportsSync)
                                            {
                                                <p class="card-note" style="margin-top:0.25rem;">Error: @item.LastError</p>
                                            }
                                        </div>
                                    </div>

                                    <div class="integration-instance-actions">
                                        <button class="button-primary integration-action-button" @onclick="() => LoadForEdit(item)">Edit</button>
                                        @if (item.SupportsSync)
                                        {
                                            <button class="button-primary integration-action-button integration-action-button-sync" disabled="@(_syncingId == item.Id)" @onclick="() => SyncIntegrationAsync(item)">
                                                @(_syncingId == item.Id ? "Syncing..." : "Sync")
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="integration-ops-pill">Ops-only</span>
                                        }
                                        <button class="button-primary integration-action-button integration-action-button-secondary" disabled="@(_testingId == item.Id)" @onclick="() => TestIntegrationAsync(item)">
                                            @(_testingId == item.Id ? "Testing..." : "Test")
                                        </button>
                                        <button class="button-danger" disabled="@(_deletingId == item.Id)" @onclick="() => DeleteIntegrationAsync(item)">
                                            @(_deletingId == item.Id ? "Deleting..." : "Delete")
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </section>
        }
    }

</div>

@code {
    private readonly List<IntegrationServiceResponse> _services = [];
    private readonly List<IntegrationInstanceResponse> _instances = [];
    private readonly IntegrationFormModel _form = new();
    private readonly HashSet<string> _expandedServicePanels = new(StringComparer.OrdinalIgnoreCase);
    private bool _loading = true;
    private bool _saving;
    private long? _editingId;
    private long? _syncingId;
    private long? _testingId;
    private long? _deletingId;
    private bool _testSuccess;
    private bool _attemptedSave;
    private string _testMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadServicesAsync();
        await LoadInstancesAsync();
    }

    private async Task LoadServicesAsync()
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/integration-services");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load integration services ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var services = await response.Content.ReadFromJsonAsync<List<IntegrationServiceResponse>>();
            _services.Clear();
            if (services is not null)
            {
                _services.AddRange(services);
            }

            if (_services.Count > 0 && string.IsNullOrWhiteSpace(_form.ServiceKey))
            {
                _form.ServiceKey = _services[0].ServiceKey;
            }

            var selected = SelectedService();
            if (selected is not null && !selected.AllowedAuthTypes.Contains(_form.AuthType, StringComparer.OrdinalIgnoreCase))
            {
                _form.AuthType = selected.AllowedAuthTypes.FirstOrDefault() ?? "ApiKey";
            }
        }
        catch
        {
            Snackbar.Add("Failed to load integration services.", Severity.Error);
        }
    }

    private async Task LoadInstancesAsync()
    {
        _loading = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "/api/integrations");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load integrations ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var items = await response.Content.ReadFromJsonAsync<List<IntegrationInstanceResponse>>();
            _instances.Clear();
            if (items is not null)
            {
                _instances.AddRange(items);
            }
        }
        catch
        {
            Snackbar.Add("Failed to load integrations.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void LoadForEdit(IntegrationInstanceResponse item)
    {
        _attemptedSave = false;
        _editingId = item.Id;
        _form.ServiceKey = item.ServiceKey;
        _form.InstanceName = item.InstanceName;
        _form.BaseUrl = item.BaseUrl;
        _form.AuthType = item.AuthType;
        _form.ApiKey = item.ApiKey;
        _form.Username = item.Username;
        _form.Password = item.Password;
        _form.Enabled = item.Enabled;
    }

    private void ResetForm()
    {
        _attemptedSave = false;
        _editingId = null;
        _form.InstanceName = string.Empty;
        _form.BaseUrl = string.Empty;
        _form.AuthType = "ApiKey";
        _form.ApiKey = string.Empty;
        _form.Username = string.Empty;
        _form.Password = string.Empty;
        _form.Enabled = false;
        _testMessage = string.Empty;
    }

    private async Task SaveIntegrationAsync()
    {
        _attemptedSave = true;

        if (!CanSubmitForm())
        {
            Snackbar.Add(GetFormValidationMessage(), Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            if (_editingId is null)
            {
                var createRequest = new CreateIntegrationInstanceRequest(
                    _form.ServiceKey,
                    _form.InstanceName,
                    _form.BaseUrl,
                    _form.AuthType,
                    _form.ApiKey,
                    _form.Username,
                    _form.Password,
                    _form.Enabled);

                using var request = new HttpRequestMessage(HttpMethod.Post, "/api/integrations")
                {
                    Content = JsonContent.Create(createRequest)
                };
                await AttachBearerAsync(request);
                using var response = await Http.SendAsync(request);
                if (!response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Failed to create integration ({(int)response.StatusCode}).", Severity.Error);
                    return;
                }

                Snackbar.Add("Integration instance created.", Severity.Success);
            }
            else
            {
                var updateRequest = new UpdateIntegrationInstanceRequest(
                    _form.InstanceName,
                    _form.BaseUrl,
                    _form.AuthType,
                    _form.ApiKey,
                    _form.Username,
                    _form.Password,
                    _form.Enabled);

                using var request = new HttpRequestMessage(HttpMethod.Put, $"/api/integrations/{_editingId.Value}")
                {
                    Content = JsonContent.Create(updateRequest)
                };
                await AttachBearerAsync(request);
                using var response = await Http.SendAsync(request);
                if (!response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Failed to update integration ({(int)response.StatusCode}).", Severity.Error);
                    return;
                }

                Snackbar.Add("Integration instance updated.", Severity.Success);
            }

            ResetForm();
            await LoadInstancesAsync();
        }
        catch
        {
            Snackbar.Add("Failed to save integration instance.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task TestIntegrationAsync(IntegrationInstanceResponse item)
    {
        _testingId = item.Id;
        _testMessage = string.Empty;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/integrations/{item.Id}/test");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _testSuccess = false;
                _testMessage = $"Connection test failed ({(int)response.StatusCode}).";
                Snackbar.Add(_testMessage, _testSuccess ? Severity.Success : Severity.Error);
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<IntegrationTestResponse>();
            if (result is null)
            {
                _testSuccess = false;
                _testMessage = "Connection test returned no data.";
                Snackbar.Add(_testMessage, _testSuccess ? Severity.Success : Severity.Error);
                return;
            }

            _testSuccess = result.Success;
            _testMessage = result.Success
                ? $"{item.DisplayName} / {item.InstanceName}: connection successful ({result.StatusCode}){(string.IsNullOrWhiteSpace(result.Version) ? string.Empty : $" · version {result.Version}")}."
                : $"{item.DisplayName} / {item.InstanceName}: connection failed ({result.StatusCode}) — {result.Message}";
            Snackbar.Add(_testMessage, _testSuccess ? Severity.Success : Severity.Error);
            await LoadInstancesAsync();
        }
        catch
        {
            _testSuccess = false;
            _testMessage = "Connection test failed.";
            Snackbar.Add(_testMessage, _testSuccess ? Severity.Success : Severity.Error);
        }
        finally
        {
            _testingId = null;
        }
    }

    private async Task SyncIntegrationAsync(IntegrationInstanceResponse item)
    {
        _syncingId = item.Id;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/integrations/{item.Id}/sync")
            {
                Content = JsonContent.Create(new { ForceFullResync = false, MediaScope = (string?)null })
            };
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to sync integration ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<TriggerIntegrationSyncResponse>();
            Snackbar.Add(result?.Message ?? $"{item.DisplayName} sync completed.", result?.Accepted == true ? Severity.Success : Severity.Warning);
            await LoadInstancesAsync();
        }
        catch
        {
            Snackbar.Add("Failed to sync integration.", Severity.Error);
        }
        finally
        {
            _syncingId = null;
        }
    }

    private async Task DeleteIntegrationAsync(IntegrationInstanceResponse item)
    {
        _deletingId = item.Id;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/integrations/{item.Id}");
            await AttachBearerAsync(request);
            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to delete integration ({(int)response.StatusCode}).", Severity.Error);
                return;
            }

            Snackbar.Add("Integration instance deleted.", Severity.Success);
            await LoadInstancesAsync();
            if (_editingId == item.Id)
            {
                ResetForm();
            }
        }
        catch
        {
            Snackbar.Add("Failed to delete integration instance.", Severity.Error);
        }
        finally
        {
            _deletingId = null;
        }
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private IntegrationServiceResponse? SelectedService()
        => _services.FirstOrDefault(x => x.ServiceKey == _form.ServiceKey);

    private bool IsAuthSelectionInvalid()
    {
        var service = SelectedService();
        if (service is null) return false;
        if (!service.RequiresAuth) return false;
        return string.Equals(_form.AuthType, "None", StringComparison.OrdinalIgnoreCase);
    }

    private bool ShowApiKeyValidationError()
        => _attemptedSave
           && string.Equals(_form.AuthType, "ApiKey", StringComparison.OrdinalIgnoreCase)
           && string.IsNullOrWhiteSpace(_form.ApiKey);

    private bool ShowBasicUsernameValidationError()
        => _attemptedSave
           && string.Equals(_form.AuthType, "Basic", StringComparison.OrdinalIgnoreCase)
           && string.IsNullOrWhiteSpace(_form.Username);

    private bool ShowBasicPasswordValidationError()
        => _attemptedSave
           && string.Equals(_form.AuthType, "Basic", StringComparison.OrdinalIgnoreCase)
           && string.IsNullOrWhiteSpace(_form.Password);

    private bool ShowBaseUrlValidationError()
        => _attemptedSave && !IsBaseUrlValid();

    private bool ShowDuplicateInstanceValidationError()
        => _attemptedSave && IsDuplicateInstanceName();

    private bool ShouldShowInstanceAvailabilityHint()
    {
        var service = (_form.ServiceKey ?? string.Empty).Trim();
        var name = (_form.InstanceName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(service) || string.IsNullOrWhiteSpace(name))
        {
            return false;
        }

        return !IsDuplicateInstanceName();
    }

    private bool IsBaseUrlValid()
        => Uri.TryCreate((_form.BaseUrl ?? string.Empty).Trim(), UriKind.Absolute, out _);

    private bool IsDuplicateInstanceName()
    {
        var service = (_form.ServiceKey ?? string.Empty).Trim();
        var name = (_form.InstanceName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(service) || string.IsNullOrWhiteSpace(name))
        {
            return false;
        }

        return _instances.Any(x =>
            x.Id != (_editingId ?? 0) &&
            string.Equals(x.ServiceKey, service, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(x.InstanceName, name, StringComparison.OrdinalIgnoreCase));
    }

    private bool CanSubmitForm()
    {
        if (string.IsNullOrWhiteSpace(_form.ServiceKey)) return false;
        if (string.IsNullOrWhiteSpace(_form.InstanceName)) return false;
        if (string.IsNullOrWhiteSpace(_form.BaseUrl)) return false;
        if (!IsBaseUrlValid()) return false;
        if (IsDuplicateInstanceName()) return false;
        if (IsAuthSelectionInvalid()) return false;
        if (ShowApiKeyValidationError()) return false;
        if (ShowBasicUsernameValidationError()) return false;
        if (ShowBasicPasswordValidationError()) return false;
        return true;
    }

    private string GetFormValidationMessage()
    {
        if (string.IsNullOrWhiteSpace(_form.InstanceName)) return "Instance name is required.";
        if (string.IsNullOrWhiteSpace(_form.BaseUrl)) return "Base URL is required.";
        if (!IsBaseUrlValid()) return "Base URL must be a valid absolute URL.";
        if (IsDuplicateInstanceName()) return "An instance with this service + name already exists.";
        if (IsAuthSelectionInvalid()) return "This service requires credentials. Select API key or basic auth.";
        if (ShowApiKeyValidationError()) return "API key/token is required for API key authentication.";
        if (ShowBasicUsernameValidationError()) return "Username is required for basic authentication.";
        if (ShowBasicPasswordValidationError()) return "Password is required for basic authentication.";
        return "Please correct the form and try again.";
    }

    private IEnumerable<string> GetAuthOptions()
    {
        var service = SelectedService();
        if (service is null || service.AllowedAuthTypes is null || service.AllowedAuthTypes.Count == 0)
        {
            return new[] { "None", "ApiKey", "Basic" };
        }

        return service.AllowedAuthTypes;
    }

    private static string GetAuthLabel(string authType) => authType switch
    {
        "ApiKey" => "API Key / Token",
        "Basic" => "Username + Password",
        _ => "None"
    };

    private static string DisplayVersionComparison(string? currentVersion, string? latestReleaseVersion)
    {
        var current = string.IsNullOrWhiteSpace(currentVersion) ? "—" : currentVersion.Trim();
        var latest = string.IsNullOrWhiteSpace(latestReleaseVersion) ? "—" : latestReleaseVersion.Trim();
        return $"{current} / {latest}";
    }

    private static string GetVersionStatusLabel(string? currentVersion, string? latestReleaseVersion)
    {
        var current = (currentVersion ?? string.Empty).Trim();
        var latest = (latestReleaseVersion ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(current) || string.IsNullOrWhiteSpace(latest))
        {
            return "Unknown";
        }

        return string.Equals(current, latest, StringComparison.OrdinalIgnoreCase)
            ? "Up to date"
            : "Out of date";
    }

    private static string BuildVersionStatusPillStyle(string? currentVersion, string? latestReleaseVersion)
        => GetVersionStatusLabel(currentVersion, latestReleaseVersion) switch
        {
            "Up to date" => "display:inline-flex; align-items:center; gap:0.35rem; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(21,128,61,0.3); color:#dcfce7; border:1px solid rgba(74,222,128,0.55); box-shadow:inset 0 0 0 1px rgba(34,197,94,0.12); font-size:0.78rem; font-weight:800; letter-spacing:0.01em; white-space:nowrap;",
            "Out of date" => "display:inline-flex; align-items:center; gap:0.35rem; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(180,83,9,0.34); color:#fef3c7; border:1px solid rgba(251,191,36,0.58); box-shadow:inset 0 0 0 1px rgba(245,158,11,0.14); font-size:0.78rem; font-weight:800; letter-spacing:0.01em; white-space:nowrap;",
            _ => "display:inline-flex; align-items:center; gap:0.35rem; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(71,85,105,0.34); color:#e2e8f0; border:1px solid rgba(148,163,184,0.45); box-shadow:inset 0 0 0 1px rgba(226,232,240,0.06); font-size:0.78rem; font-weight:800; letter-spacing:0.01em; white-space:nowrap;"
        };

    private int EnabledInstanceCount()
        => _instances.Count(x => x.Enabled);

    private int AttentionNeededCount()
        => _instances.Count(x => x.Enabled && string.Equals(GetHealthLabel(x), "Attention needed", StringComparison.OrdinalIgnoreCase));

    private int ProwlarrInstanceCount()
        => _instances.Count(x => string.Equals(x.ServiceKey, "prowlarr", StringComparison.OrdinalIgnoreCase));

    private static string GetServiceMonogram(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName)) return "??";
        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part => !string.IsNullOrWhiteSpace(part))
            .ToArray();

        if (parts.Length == 1)
        {
            var token = parts[0];
            return token.Length >= 2
                ? token[..2].ToUpperInvariant()
                : token.ToUpperInvariant();
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private static string DisplayRoleSummary(string? value)
        => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatTimestamp(DateTimeOffset? value)
        => value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—";

    private static string GetHealthLabel(IntegrationInstanceResponse item)
    {
        if (!item.Enabled) return "Disabled";
        if (!string.IsNullOrWhiteSpace(item.LastError) || item.ConsecutiveFailureCount > 0) return "Attention needed";
        if (item.LastSuccessfulAtUtc.HasValue) return "Healthy";
        if (item.LastAttemptedAtUtc.HasValue) return "Awaiting success";
        if (!item.SupportsSync)
        {
            return item.ProwlarrSummary is not null ? "Operational" : "Ops-only";
        }

        return "Not checked";
    }

    private static string BuildHealthPillStyle(IntegrationInstanceResponse item)
        => GetHealthLabel(item) switch
        {
            "Healthy" => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(21,128,61,0.3); color:#dcfce7; border:1px solid rgba(74,222,128,0.55); font-size:0.78rem; font-weight:800;",
            "Operational" => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(14,116,144,0.3); color:#cffafe; border:1px solid rgba(34,211,238,0.55); font-size:0.78rem; font-weight:800;",
            "Attention needed" => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(185,28,28,0.28); color:#fecaca; border:1px solid rgba(248,113,113,0.55); font-size:0.78rem; font-weight:800;",
            "Awaiting success" => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(180,83,9,0.34); color:#fef3c7; border:1px solid rgba(251,191,36,0.58); font-size:0.78rem; font-weight:800;",
            "Disabled" => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(71,85,105,0.34); color:#e2e8f0; border:1px solid rgba(148,163,184,0.45); font-size:0.78rem; font-weight:800;",
            _ => "display:inline-flex; align-items:center; gap:0.35rem; width:max-content; padding:0.22rem 0.62rem; border-radius:999px; background:rgba(30,41,59,0.6); color:#cbd5e1; border:1px solid rgba(71,85,105,0.75); font-size:0.78rem; font-weight:800;"
        };

    private IReadOnlyList<ServiceIntegrationGroup> GroupInstancesByService()
        => _instances
            .GroupBy(x => new { x.ServiceKey, x.DisplayName })
            .OrderBy(g => g.Key.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select(g => new ServiceIntegrationGroup(
                g.Key.ServiceKey,
                g.Key.DisplayName,
                g.FirstOrDefault()?.RoleSummary ?? string.Empty,
                g.OrderBy(x => x.InstanceName, StringComparer.OrdinalIgnoreCase).ToList(),
                g.Count(x => string.Equals(GetHealthLabel(x), "Healthy", StringComparison.OrdinalIgnoreCase)),
                g.Count(x => string.Equals(GetHealthLabel(x), "Operational", StringComparison.OrdinalIgnoreCase)),
                g.Count(x => string.Equals(GetHealthLabel(x), "Attention needed", StringComparison.OrdinalIgnoreCase)),
                g.Where(x => x.LastSuccessfulAtUtc.HasValue).OrderByDescending(x => x.LastSuccessfulAtUtc).Select(x => x.LastSuccessfulAtUtc).FirstOrDefault()))
            .ToList();

    private void ToggleServicePanel(string serviceKey)
    {
        if (!_expandedServicePanels.Add(serviceKey))
        {
            _expandedServicePanels.Remove(serviceKey);
        }
    }

    private bool IsServicePanelExpanded(string serviceKey)
        => _expandedServicePanels.Contains(serviceKey);

    private static string GetGroupHealthLabel(ServiceIntegrationGroup group)
        => group.AttentionNeededCount > 0 ? "Attention needed" : group.HealthyCount > 0 ? "Healthy" : group.OperationalCount > 0 ? "Operational" : "Not checked";

    private static string BuildGroupHealthPillStyle(ServiceIntegrationGroup group)
        => GetGroupHealthLabel(group) switch
