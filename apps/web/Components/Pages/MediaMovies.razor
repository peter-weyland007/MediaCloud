@page "/media/movies"
@attribute [Authorize]
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject ISnackbar Snackbar

<PageTitle>Movies</PageTitle>

<div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.85rem; flex-wrap:wrap;">
    <div>
        <h1 style="margin:0;">Movies</h1>
        <p class="subtitle" style="margin:0.25rem 0 0;">Movie library view.</p>
    </div>

    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:0.35rem; min-width:360px;">
        <MudButtonGroup Class="movies-action-group" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
            <MudButton Class="movies-action-btn movies-action-btn--primary" OnClick="RefreshMoviesFromIntegrationsAsync" Disabled="@_isActionRunning">
                @(_syncingMovies ? "Refreshing movies..." : "Refresh from integrations")
            </MudButton>
            <MudButton Class="movies-action-btn movies-action-btn--secondary" OnClick="ReprobeAllMoviesAsync" Disabled="@_isActionRunning">
                @(_reprobingAllMovies ? "Reprobing runtimes..." : "Probe all runtimes")
            </MudButton>
            <MudButton Class="movies-action-btn movies-action-btn--danger" OnClick="PurgeMoviesAsync" Disabled="@_isActionRunning">
                @(_purgingMovies ? "Purging movies..." : "Purge movie data")
            </MudButton>
        </MudButtonGroup>

        <div class="movies-action-progress" role="status" aria-live="polite">
            @if (_isActionRunning && _actionProgressIndeterminate)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Class="movies-action-progress-bar" />
            }
            else
            {
                <MudProgressLinear Color="Color.Primary" Value="@_actionProgressPercent" Rounded="true" Class="movies-action-progress-bar" />
            }
            <div class="movies-action-progress-meta">
                <span class="movies-action-progress-text">@_actionStatusText (@ActionPercentLabel)</span>
            </div>
        </div>
    </div>
</div>

<MediaLibraryTable FixedMediaType="Movie" RefreshVersion="@_refreshVersion" />

<style>
    .movies-action-btn.mud-button-root {
        text-transform: none !important;
        font-weight: 600;
        min-height: 34px;
        padding-inline: 0.8rem;
    }

    .movies-action-btn--primary {
        background: var(--mud-palette-primary);
        color: var(--mud-palette-primary-text);
        border-color: var(--mud-palette-primary);
    }

    .movies-action-btn--secondary {
        background: var(--mud-palette-primary);
        color: var(--mud-palette-primary-text);
        border-color: var(--mud-palette-primary);
    }

    .movies-action-btn--danger {
        background: var(--mud-palette-error);
        color: var(--mud-palette-error-text);
        border-color: var(--mud-palette-error);
    }

    .movies-action-group {
        width: 100%;
    }

    .movies-action-progress {
        width: 100%;
        display: grid;
        gap: 0.35rem;
    }

    .movies-action-progress-bar {
        width: 100%;
    }

    .movies-action-progress-meta {
        display: flex;
        align-items: center;
        min-height: 1rem;
    }

    .movies-action-progress-text {
        color: var(--mud-palette-primary-text);
        font-size: 0.84rem;
        font-weight: 600;
        white-space: nowrap;
    }
</style>

@code {
    private bool _reprobingAllMovies;
    private bool _syncingMovies;
    private bool _purgingMovies;
    private int _refreshVersion;
    private bool _actionProgressIndeterminate;
    private double _actionProgressPercent;
    private string _actionStatusText = "Ready";

    private bool _isActionRunning => _syncingMovies || _reprobingAllMovies || _purgingMovies;
    private string ActionPercentLabel => _actionProgressIndeterminate && _isActionRunning ? "--" : $"{Math.Round(_actionProgressPercent),3}%";

    private async Task RefreshMoviesFromIntegrationsAsync()
    {
        _syncingMovies = true;
        await SetActionProgressAsync("Loading integrations...", 0, indeterminate: true);
        try
        {
            using var listRequest = new HttpRequestMessage(HttpMethod.Get, "/api/integrations");
            await AttachBearerAsync(listRequest);
            using var listResponse = await Http.SendAsync(listRequest);
            if (!listResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Failed to load integrations ({(int)listResponse.StatusCode}).", Severity.Error);
                return;
            }

            var integrations = await listResponse.Content.ReadFromJsonAsync<List<IntegrationInstanceResponse>>() ?? [];
            var movieIntegrations = integrations
                .Where(x => x.Enabled &&
                            (string.Equals(x.ServiceKey, "Plex", StringComparison.OrdinalIgnoreCase)
                             || string.Equals(x.ServiceKey, "Radarr", StringComparison.OrdinalIgnoreCase)
                             || string.Equals(x.ServiceKey, "Overseerr", StringComparison.OrdinalIgnoreCase)))
                .ToList();

            if (movieIntegrations.Count == 0)
            {
                Snackbar.Add("No enabled Plex/Radarr/Overseerr integrations found.", Severity.Warning);
                return;
            }

            var synced = 0;
            var failed = 0;
            var completed = 0;
            var total = movieIntegrations.Count;
            var failedMessages = new List<string>();
            await SetActionProgressAsync($"Syncing 0/{total} integrations...", 0, indeterminate: false);

            foreach (var integration in movieIntegrations)
            {
                using var syncRequest = new HttpRequestMessage(HttpMethod.Post, $"/api/integrations/{integration.Id}/sync")
                {
                    Content = JsonContent.Create(new TriggerIntegrationSyncRequest(false))
                };
                await AttachBearerAsync(syncRequest);
                using var syncResponse = await Http.SendAsync(syncRequest);

                if (!syncResponse.IsSuccessStatusCode)
                {
                    failed++;
                    failedMessages.Add($"{integration.InstanceName}: HTTP {(int)syncResponse.StatusCode}");
                }
                else
                {
                    var payload = await syncResponse.Content.ReadFromJsonAsync<TriggerIntegrationSyncResponse>();
                    if (payload?.Accepted == true)
                    {
                        synced++;
                    }
                    else
                    {
                        failed++;
                        failedMessages.Add($"{integration.InstanceName}: {payload?.Message ?? "sync not accepted"}");
                    }
                }

                completed++;
                var percent = total == 0 ? 0 : (completed * 100d) / total;
                await SetActionProgressAsync($"Syncing {completed}/{total} integrations ({Math.Round(percent)}%)...", percent, indeterminate: false);
            }

            await SetActionProgressAsync("Finalizing refresh...", 100, indeterminate: false);
            _refreshVersion++;
            Snackbar.Add($"Movie refresh complete. Synced {synced}, failed {failed}.", failed == 0 ? Severity.Success : Severity.Warning);
            if (failedMessages.Count > 0)
            {
                Snackbar.Add(string.Join(" | ", failedMessages.Take(2)), Severity.Warning);
            }
        }
        catch
        {
            Snackbar.Add("Movie refresh failed.", Severity.Error);
        }
        finally
        {
            _syncingMovies = false;
            ClearActionProgress();
        }
    }

    private async Task PurgeMoviesAsync()
    {
        _purgingMovies = true;
        await SetActionProgressAsync("Purging movie data...", 20, indeterminate: false);
        try
        {
            using var purgeRequest = new HttpRequestMessage(HttpMethod.Post, "/api/library/purge")
            {
                Content = JsonContent.Create(new PurgeLibraryRequest("Movie", true, true))
            };
            await AttachBearerAsync(purgeRequest);
            using var purgeResponse = await Http.SendAsync(purgeRequest);
            if (!purgeResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Purge failed ({(int)purgeResponse.StatusCode}).", Severity.Error);
                return;
            }

            var payload = await purgeResponse.Content.ReadFromJsonAsync<PurgeLibraryResponse>();
            await SetActionProgressAsync("Finalizing purge...", 100, indeterminate: false);
            _refreshVersion++;
            Snackbar.Add($"Purged movies: items {payload?.ItemsDeleted ?? 0}, links {payload?.SourceLinksDeleted ?? 0}, issues {payload?.IssuesDeleted ?? 0}.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Purge failed.", Severity.Error);
        }
        finally
        {
            _purgingMovies = false;
            ClearActionProgress();
        }
    }

    private async Task ReprobeAllMoviesAsync()
    {
        _reprobingAllMovies = true;
        await SetActionProgressAsync("Starting runtime probe job...", 0, indeterminate: true);
        try
        {
            using var startRequest = new HttpRequestMessage(HttpMethod.Post, "/api/library/items/reprobe-runtimes/jobs")
            {
                Content = JsonContent.Create(new BatchRuntimeReprobeRequest("Movie", 2000, true))
            };
            await AttachBearerAsync(startRequest);
            using var startResponse = await Http.SendAsync(startRequest);
            if (!startResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Bulk probe failed to start ({(int)startResponse.StatusCode}). Admin access may be required.", Severity.Error);
                return;
            }

            var startPayload = await startResponse.Content.ReadFromJsonAsync<StartRuntimeReprobeJobResponse>();
            if (startPayload is null || startPayload.JobId == Guid.Empty)
            {
                Snackbar.Add("Bulk probe failed to start (no job id returned).", Severity.Error);
                return;
            }

            while (true)
            {
                using var statusRequest = new HttpRequestMessage(HttpMethod.Get, $"/api/library/items/reprobe-runtimes/jobs/{startPayload.JobId}");
                await AttachBearerAsync(statusRequest);
                using var statusResponse = await Http.SendAsync(statusRequest);
                if (!statusResponse.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Bulk probe status check failed ({(int)statusResponse.StatusCode}).", Severity.Error);
                    return;
                }

                var status = await statusResponse.Content.ReadFromJsonAsync<RuntimeReprobeJobStatusResponse>();
                if (status is null)
                {
                    Snackbar.Add("Bulk probe status payload was empty.", Severity.Error);
                    return;
                }

                var message = string.IsNullOrWhiteSpace(status.Message)
                    ? "Runtime probe in progress..."
                    : status.Message;

                var percent = status.TotalCandidates <= 0
                    ? (status.Status.Equals("completed", StringComparison.OrdinalIgnoreCase) ? 100 : 0)
                    : Math.Min(100, (status.Inspected * 100d) / status.TotalCandidates);

                await SetActionProgressAsync(message, percent, indeterminate: false);

                if (status.Status.Equals("completed", StringComparison.OrdinalIgnoreCase))
                {
                    Snackbar.Add($"Bulk probe done: updated {status.Updated}/{status.Inspected}, missing files {status.MissingFiles}, probe failures {status.Failed}.", Severity.Success);
                    _refreshVersion++;
                    return;
                }

                if (status.Status.Equals("failed", StringComparison.OrdinalIgnoreCase))
                {
                    Snackbar.Add(status.Message, Severity.Error);
                    return;
                }

                await Task.Delay(700);
            }
        }
        catch
        {
            Snackbar.Add("Bulk probe failed.", Severity.Error);
        }
        finally
        {
            _reprobingAllMovies = false;
            ClearActionProgress();
        }
    }

    private async Task SetActionProgressAsync(string text, double percent, bool indeterminate)
    {
        _actionStatusText = text;
        _actionProgressPercent = Math.Clamp(percent, 0, 100);
        _actionProgressIndeterminate = indeterminate;
        await InvokeAsync(StateHasChanged);
    }

    private void ClearActionProgress()
    {
        _actionStatusText = "Ready";
        _actionProgressPercent = 0;
        _actionProgressIndeterminate = false;
    }

    private async Task AttachBearerAsync(HttpRequestMessage request)
    {
        var token = await TokenStore.GetTokenAsync();
        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private sealed record BatchRuntimeReprobeRequest(string? MediaType, int Take = 200, bool ForceAll = false);
    private sealed record StartRuntimeReprobeJobResponse(Guid JobId);
    private sealed record RuntimeReprobeJobStatusResponse(Guid JobId, string Status, string Message, int TotalCandidates, int Inspected, int Attempted, int Updated, int MissingFiles, int Failed, DateTimeOffset StartedAtUtc, DateTimeOffset? FinishedAtUtc);
    private sealed record TriggerIntegrationSyncRequest(bool ForceFullResync = false);
    private sealed record TriggerIntegrationSyncResponse(long IntegrationId, bool Accepted, string Message);
    private sealed record PurgeLibraryRequest(string? MediaType = null, bool ResetSyncState = true, bool ClearMonitoringState = true);
    private sealed record PurgeLibraryResponse(string MediaType, int ItemsDeleted, int SourceLinksDeleted, int IssuesDeleted, int MonitoringStateDeleted);
    private sealed record IntegrationInstanceResponse(long Id, string ServiceKey, string InstanceName, string BaseUrl, string AuthType, bool Enabled);
}
